<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Bem-vindo, <%= user ? user.nome : 'Visitante' %>!</h2>
            <p class="text-gray-500">Acompanhe as atividades de comunicação hoje.</p>
        </div>
        <div class="flex gap-2">
            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm">
                Nova Solicitação
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
            <p class="text-sm font-medium text-gray-400 uppercase">Solicitações Abertas</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">12</p>
            <div class="mt-4 flex items-center text-sm text-green-600 font-medium">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                +3 hoje
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
            <p class="text-sm font-medium text-gray-400 uppercase">Eventos na Semana</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">8</p>
            <div class="mt-4 flex items-center text-sm text-blue-600 font-medium">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                2 para hoje
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
            <p class="text-sm font-medium text-gray-400 uppercase">Releases Publicados</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">45</p>
            <div class="mt-4 flex items-center text-sm text-gray-500 font-medium font-mono">
                Total histórico
            </div>
        </div>
        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">
            <p class="text-sm font-medium text-gray-400 uppercase">Membros SECOM</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">15</p>
            <div class="mt-4 flex items-center text-sm text-green-600 font-medium">
                Online no sistema
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Upcoming Events -->
        <div class="lg:col-span-2 space-y-4">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900">Agenda Institucional</h3>
                <a href="/eventos" class="text-sm font-semibold text-blue-600 hover:underline">Ver tudo</a>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Evento</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Secretaria</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Data/Hora</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-semibold text-gray-900">Inauguração Unidade Básica</div>
                                <div class="text-xs text-gray-500">Local: Bairro Novo Horizonte</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded">Saúde</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900">05/05/2026</div>
                                <div class="text-xs text-gray-500">09:00 - 11:00</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-medium bg-green-100 text-green-800 rounded-full">Confirmado</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-semibold text-gray-900">Coletiva de Imprensa: IPTU 2026</div>
                                <div class="text-xs text-gray-500">Local: Gabinete do Prefeito</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-medium bg-red-100 text-red-800 rounded">Fazenda</span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900">06/05/2026</div>
                                <div class="text-xs text-gray-500">14:00 - 15:00</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 py-1 text-xs font-medium bg-yellow-100 text-yellow-800 rounded-full">Pendente</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Solicitations -->
        <div class="space-y-4">
            <h3 class="text-lg font-bold text-gray-900">Solicitações Recentes</h3>
            <div class="space-y-3">
                <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm space-y-3">
                    <div class="flex items-start justify-between">
                        <div class="space-y-1">
                            <p class="text-xs font-bold text-blue-600 uppercase">Social Media</p>
                            <h4 class="text-sm font-bold text-gray-900 leading-tight">Card Informativo: Vacinação Gripe</h4>
                        </div>
                        <span class="px-2 py-1 text-[10px] font-bold bg-orange-100 text-orange-800 rounded uppercase">Urgente</span>
                    </div>
                    <div class="pt-2 flex items-center justify-between border-t border-gray-100">
                        <div class="flex items-center gap-2">
                             <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-[10px] font-bold">S</div>
                             <p class="text-xs text-gray-500">Saúde</p>
                        </div>
                        <p class="text-[10px] text-gray-400 italic">Há 2h</p>
                    </div>
                </div>

                <div class="bg-white p-4 rounded-xl border border-gray-200 shadow-sm space-y-3 opacity-75">
                    <div class="flex items-start justify-between">
                        <div class="space-y-1">
                            <p class="text-xs font-bold text-purple-600 uppercase">Vídeo</p>
                            <h4 class="text-sm font-bold text-gray-900 leading-tight">Cobertura: Obras no Centro</h4>
                        </div>
                        <span class="px-2 py-1 text-[10px] font-bold bg-gray-100 text-gray-800 rounded uppercase">Normal</span>
                    </div>
                    <div class="pt-2 flex items-center justify-between border-t border-gray-100">
                        <div class="flex items-center gap-2">
                             <div class="w-6 h-6 rounded-full bg-gray-100 flex items-center justify-center text-[10px] font-bold">O</div>
                             <p class="text-xs text-gray-500">Obras</p>
                        </div>
                        <p class="text-[10px] text-gray-400 italic">Há 5h</p>
                    </div>
                </div>
            </div>
            <button class="w-full py-2 text-sm font-semibold text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition">
                Ver todas solicitações
            </button>
        </div>
    </div>
</div>
