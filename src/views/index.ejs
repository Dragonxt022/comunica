<%
// Eventos hoje e esta semana a partir do array já carregado
const agora = new Date();
const hojStr = agora.toDateString();
const semStr = new Date(agora.getTime() + 7 * 86400000).toDateString();
const eventosHoje = proximosEventos.filter(function(e) {
    return new Date(e.data_inicio).toDateString() === hojStr;
});
const eventosSemana = proximosEventos.filter(function(e) {
    const d = new Date(e.data_inicio);
    return d >= agora && d <= new Date(agora.getTime() + 7 * 86400000);
});
const totalAlertas = (solicitacoesPendentes > 0 ? 1 : 0) + (eventosHoje.length > 0 ? 1 : 0) + (acoesVencidasCount > 0 ? 1 : 0);
const dataSaudacao = agora.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long' });
const hora = agora.getHours();
const saudacao = hora < 12 ? 'Bom dia' : hora < 18 ? 'Boa tarde' : 'Boa noite';
%>

<div class="space-y-6">

    <!-- ── Cabeçalho ─────────────────────────────────────────────────────── -->
    <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
            <h1 class="text-xl font-bold text-gray-900"><%= saudacao %>, <%= user.nome.split(' ')[0] %></h1>
            <p class="text-sm text-gray-400 mt-0.5 capitalize"><%= dataSaudacao %></p>
        </div>
        <a href="/solicitacoes/nova"
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition shadow-sm shrink-0">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
            Nova Solicitação
        </a>
    </div>

    <!-- ── Acesso Rápido ──────────────────────────────────────────────────── -->
    <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Acesso Rápido</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">

            <a href="/solicitacoes/nova"
               class="group flex flex-col items-center gap-2 p-4 bg-blue-600 hover:bg-blue-700 rounded-xl text-white transition shadow-sm text-center">
                <div class="w-9 h-9 rounded-lg bg-white/20 flex items-center justify-center group-hover:bg-white/30 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                </div>
                <span class="text-xs font-semibold leading-tight">Abrir Chamado</span>
            </a>

            <a href="/eventos"
               class="group flex flex-col items-center gap-2 p-4 bg-white hover:bg-indigo-50 border border-gray-200 hover:border-indigo-300 rounded-xl transition text-center">
                <div class="w-9 h-9 rounded-lg bg-indigo-50 group-hover:bg-indigo-100 flex items-center justify-center transition">
                    <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 leading-tight">Calendário</span>
            </a>

            <a href="/planejamento"
               class="group flex flex-col items-center gap-2 p-4 bg-white hover:bg-violet-50 border border-gray-200 hover:border-violet-300 rounded-xl transition text-center">
                <div class="w-9 h-9 rounded-lg bg-violet-50 group-hover:bg-violet-100 flex items-center justify-center transition">
                    <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 leading-tight">Planejamento</span>
            </a>

            <a href="/solicitacoes"
               class="group flex flex-col items-center gap-2 p-4 bg-white hover:bg-orange-50 border border-gray-200 hover:border-orange-300 rounded-xl transition text-center">
                <div class="w-9 h-9 rounded-lg bg-orange-50 group-hover:bg-orange-100 flex items-center justify-center transition">
                    <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 leading-tight">Solicitações</span>
            </a>

            <a href="/biblioteca"
               class="group flex flex-col items-center gap-2 p-4 bg-white hover:bg-teal-50 border border-gray-200 hover:border-teal-300 rounded-xl transition text-center">
                <div class="w-9 h-9 rounded-lg bg-teal-50 group-hover:bg-teal-100 flex items-center justify-center transition">
                    <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 leading-tight">Biblioteca</span>
            </a>

            <% if(user.role !== 'secretaria') { %>
            <a href="/releases"
               class="group flex flex-col items-center gap-2 p-4 bg-white hover:bg-slate-50 border border-gray-200 hover:border-slate-300 rounded-xl transition text-center">
                <div class="w-9 h-9 rounded-lg bg-slate-50 group-hover:bg-slate-100 flex items-center justify-center transition">
                    <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM15 4v4h4"/></svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 leading-tight">Releases</span>
            </a>
            <% } else { %>
            <a href="/inscricoes"
               class="group flex flex-col items-center gap-2 p-4 bg-white hover:bg-emerald-50 border border-gray-200 hover:border-emerald-300 rounded-xl transition text-center">
                <div class="w-9 h-9 rounded-lg bg-emerald-50 group-hover:bg-emerald-100 flex items-center justify-center transition">
                    <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <span class="text-xs font-semibold text-gray-700 leading-tight">Inscrições</span>
            </a>
            <% } %>
        </div>
    </div>

    <!-- ── Alertas (só aparecem quando têm dados) ─────────────────────────── -->
    <% if (totalAlertas > 0) { %>
    <div>
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Atenção necessária</p>
        <div class="grid grid-cols-1 sm:grid-cols-<%= totalAlertas %> gap-3">

            <% if (solicitacoesPendentes > 0) { %>
            <a href="/solicitacoes"
               class="flex items-center gap-4 p-4 bg-orange-50 border border-orange-200 rounded-xl hover:bg-orange-100 transition">
                <div class="w-10 h-10 rounded-xl bg-orange-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <div>
                    <p class="text-lg font-bold text-orange-700 leading-none"><%= solicitacoesPendentes %></p>
                    <p class="text-xs text-orange-600 mt-0.5">solicitaç<%= solicitacoesPendentes === 1 ? 'ão pendente' : 'ões pendentes' %></p>
                </div>
            </a>
            <% } %>

            <% if (eventosHoje.length > 0) { %>
            <a href="/eventos"
               class="flex items-center gap-4 p-4 bg-blue-50 border border-blue-200 rounded-xl hover:bg-blue-100 transition">
                <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div>
                    <p class="text-lg font-bold text-blue-700 leading-none"><%= eventosHoje.length %></p>
                    <p class="text-xs text-blue-600 mt-0.5">evento<%= eventosHoje.length !== 1 ? 's' : '' %> hoje</p>
                </div>
            </a>
            <% } %>

            <% if (acoesVencidasCount > 0) { %>
            <a href="/planejamento"
               class="flex items-center gap-4 p-4 bg-red-50 border border-red-200 rounded-xl hover:bg-red-100 transition">
                <div class="w-10 h-10 rounded-xl bg-red-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                    <p class="text-lg font-bold text-red-700 leading-none"><%= acoesVencidasCount %></p>
                    <p class="text-xs text-red-600 mt-0.5">aç<%= acoesVencidasCount === 1 ? 'ão vencida' : 'ões vencidas' %> no planejamento</p>
                </div>
            </a>
            <% } %>
        </div>
    </div>
    <% } %>

    <!-- ── Grid principal ─────────────────────────────────────────────────── -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Coluna esquerda (2/3) -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Próximos eventos da semana -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
                    <h3 class="text-sm font-bold text-gray-900">Agenda da Semana</h3>
                    <a href="/eventos" class="text-xs font-medium text-blue-600 hover:underline">Ver calendário →</a>
                </div>
                <% if (eventosSemana.length === 0) { %>
                <div class="flex flex-col items-center justify-center py-10 text-center px-6">
                    <svg class="w-10 h-10 text-gray-200 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <p class="text-sm text-gray-400">Nenhum evento nos próximos 7 dias.</p>
                    <a href="/eventos/novo" class="mt-2 text-xs font-semibold text-blue-600 hover:underline">Agendar evento →</a>
                </div>
                <% } else { %>
                <div class="divide-y divide-gray-50">
                    <% eventosSemana.slice(0, 5).forEach(function(ev) {
                        const dEv = new Date(ev.data_inicio);
                        const isHoje = dEv.toDateString() === hojStr;
                        const diaLabel = isHoje ? 'Hoje' : dEv.toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: 'short' });
                        const horaLabel = dEv.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
                        const cor = ev.secretaria ? ev.secretaria.cor : '#6366f1';
                    %>
                    <a href="/eventos" class="flex items-center gap-4 px-5 py-3.5 hover:bg-gray-50 transition group">
                        <div class="shrink-0 w-12 text-center">
                            <p class="text-[10px] font-bold uppercase <%= isHoje ? 'text-blue-600' : 'text-gray-400' %>"><%= diaLabel.split(' ')[0] %></p>
                            <p class="text-lg font-bold <%= isHoje ? 'text-blue-700' : 'text-gray-800' %> leading-tight"><%= dEv.getDate() %></p>
                        </div>
                        <div class="w-0.5 h-10 rounded-full shrink-0" style="background:<%= cor %>20;border-left: 3px solid <%= cor %>"></div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-gray-900 truncate group-hover:text-blue-700 transition"><%= ev.titulo %></p>
                            <div class="flex items-center gap-2 mt-0.5 flex-wrap">
                                <span class="text-xs text-gray-400"><%= horaLabel %></span>
                                <% if (ev.local) { %><span class="text-xs text-gray-400">· <%= ev.local %></span><% } %>
                                <% if (ev.secretaria) { %>
                                <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded" style="background:<%= cor %>18;color:<%= cor %>"><%= ev.secretaria.nome %></span>
                                <% } %>
                            </div>
                        </div>
                        <% if (isHoje) { %>
                        <span class="shrink-0 text-[10px] font-bold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">HOJE</span>
                        <% } %>
                    </a>
                    <% }); %>
                    <% if (eventosSemana.length > 5) { %>
                    <div class="px-5 py-3 text-center">
                        <a href="/eventos" class="text-xs font-medium text-blue-600 hover:underline">+ <%= eventosSemana.length - 5 %> mais nesta semana →</a>
                    </div>
                    <% } %>
                </div>
                <% } %>
            </div>

            <!-- Gráfico semanal -->
            <% if(user.role === 'admin' || user.role === 'secom') { %>
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-3">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-gray-900">Volume de Solicitações — 8 Semanas</h3>
                    <a href="/relatorios" class="text-xs font-medium text-blue-600 hover:underline">Relatório →</a>
                </div>
                <canvas id="chartSemanal" height="80"></canvas>
            </div>
            <% } %>

            <!-- Metas do mês (admin/secom) -->
            <% if((user.role === 'admin' || user.role === 'secom') && metas && metas.length > 0) { %>
            <div x-data="metasDashboard()" x-init="verificarCelebracoes()">
                <div x-show="celebrando" x-transition.duration.500ms
                    class="relative mb-4 overflow-hidden rounded-xl border-2 border-emerald-400 bg-gradient-to-r from-emerald-50 to-green-50 p-5 shadow-md">
                    <div id="confetti-container" class="pointer-events-none absolute inset-0 overflow-hidden"></div>
                    <div class="relative flex items-center gap-4">
                        <div class="text-4xl animate-bounce">🎉</div>
                        <div>
                            <p class="text-lg font-bold text-emerald-800">Parabéns!</p>
                            <p class="text-sm text-emerald-700" x-text="mensagemCelebracao"></p>
                        </div>
                        <button @click="celebrando = false" class="ml-auto p-1 text-emerald-500 hover:text-emerald-700 transition">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        </button>
                    </div>
                </div>
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-sm font-bold text-gray-900">Metas do Mês</h3>
                        <span class="text-xs text-gray-400 capitalize"><%= new Date().toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }) %></span>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        <% metas.forEach(function(m) {
                            var progresso = metasProgresso[m.tipo_midia] || 0;
                            var pct = Math.min(100, Math.round(progresso / m.quantidade * 100));
                            var atingida = progresso >= m.quantidade;
                        %>
                        <div class="rounded-xl border p-3.5 space-y-2.5 transition-all
                            <%= atingida ? 'border-emerald-300 bg-gradient-to-br from-emerald-50 to-green-50' : 'border-gray-100' %>">
                            <div class="flex items-start justify-between gap-1">
                                <p class="text-xs font-semibold text-gray-600 leading-tight"><%= m.tipo_midia %></p>
                                <% if(atingida) { %>
                                <span class="shrink-0 inline-flex items-center gap-0.5 px-1.5 py-0.5 bg-emerald-100 text-emerald-700 text-[9px] font-bold rounded-full">
                                    <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                                    OK
                                </span>
                                <% } %>
                            </div>
                            <div class="flex justify-between items-baseline">
                                <span class="text-xl font-bold <%= atingida ? 'text-emerald-700' : 'text-gray-900' %>"><%= progresso %></span>
                                <span class="text-xs text-gray-400">/<%= m.quantidade %></span>
                            </div>
                            <div class="w-full h-1.5 bg-gray-100 rounded-full overflow-hidden">
                                <div class="h-full rounded-full transition-all duration-700
                                    <%= atingida ? 'bg-emerald-500' : pct >= 75 ? 'bg-blue-500' : pct >= 50 ? 'bg-indigo-400' : 'bg-gray-300' %>"
                                    style="width:<%= pct %>%"></div>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                </div>
            </div>
            <% } %>

        </div><!-- /col-esquerda -->

        <!-- Coluna direita (1/3) -->
        <div class="space-y-6">

            <!-- Resumo numérico (só mostra valores > 0 ou relevantes) -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm divide-y divide-gray-50">
                <div class="px-5 py-3.5 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-500">Solicitações pendentes</span>
                    <span class="text-sm font-bold <%= solicitacoesPendentes > 0 ? 'text-orange-600' : 'text-gray-400' %>"><%= solicitacoesPendentes %></span>
                </div>
                <div class="px-5 py-3.5 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-500">Em produção</span>
                    <span class="text-sm font-bold <%= solicitacoesEmProducao > 0 ? 'text-blue-600' : 'text-gray-400' %>"><%= solicitacoesEmProducao %></span>
                </div>
                <div class="px-5 py-3.5 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-500">Finalizadas este mês</span>
                    <span class="text-sm font-bold <%= finalizadasMes > 0 ? 'text-emerald-600' : 'text-gray-400' %>"><%= finalizadasMes %></span>
                </div>
                <div class="px-5 py-3.5 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-500">Eventos na semana</span>
                    <span class="text-sm font-bold <%= eventosNaSemana > 0 ? 'text-indigo-600' : 'text-gray-400' %>"><%= eventosNaSemana %></span>
                </div>
                <% if(user.role === 'admin' || user.role === 'secom') { %>
                <div class="px-5 py-3.5 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-500">Releases publicados</span>
                    <span class="text-sm font-bold <%= releasesPublicados > 0 ? 'text-slate-700' : 'text-gray-400' %>"><%= releasesPublicados %></span>
                </div>
                <div class="px-5 py-3.5 flex items-center justify-between">
                    <span class="text-xs font-semibold text-gray-500">Usuários ativos</span>
                    <span class="text-sm font-bold text-gray-700"><%= totalUsuativos %></span>
                </div>
                <% } %>
            </div>

            <!-- Top Secretarias (admin/secom) -->
            <% if(user.role !== 'secretaria' && topSecretarias.length > 0) { %>
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-3">
                <div class="flex items-center justify-between">
                    <h3 class="text-sm font-bold text-gray-900">Top Secretarias</h3>
                    <span class="text-[10px] font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">por demanda</span>
                </div>
                <div class="space-y-2.5">
                    <% var maxTotal = topSecretarias[0] ? topSecretarias[0].total : 1; %>
                    <% topSecretarias.forEach(function(sec, idx) { %>
                    <div class="space-y-1">
                        <div class="flex items-center justify-between text-xs">
                            <div class="flex items-center gap-2 min-w-0">
                                <span class="w-4 h-4 rounded-full shrink-0 flex items-center justify-center text-[10px] font-bold text-white"
                                      style="background:<%= sec.cor %>"><%= idx + 1 %></span>
                                <span class="font-medium text-gray-700 truncate"><%= sec.nome %></span>
                            </div>
                            <div class="flex items-center gap-1.5 shrink-0 ml-2">
                                <% if(sec.pendentes > 0) { %>
                                <span class="text-[10px] px-1.5 py-0.5 bg-orange-50 text-orange-600 rounded font-semibold"><%= sec.pendentes %> pend.</span>
                                <% } %>
                                <span class="font-bold text-gray-900"><%= sec.total %></span>
                            </div>
                        </div>
                        <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                            <div class="h-full rounded-full" style="width:<%= Math.round(sec.total / maxTotal * 100) %>%;background:<%= sec.cor %>"></div>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
            <% } %>

            <!-- Solicitações Recentes -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
                    <h3 class="text-sm font-bold text-gray-900">Solicitações Recentes</h3>
                    <a href="/solicitacoes" class="text-xs font-medium text-blue-600 hover:underline">Ver tudo</a>
                </div>
                <% if(solicitacoesRecentes.length === 0) { %>
                <div class="py-10 text-center px-5">
                    <svg class="w-8 h-8 mx-auto mb-2 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    <p class="text-sm text-gray-400">Nenhuma solicitação ainda.</p>
                    <a href="/solicitacoes/nova" class="mt-1.5 block text-xs font-semibold text-blue-600 hover:underline">Abrir chamado →</a>
                </div>
                <% } else { %>
                <div class="divide-y divide-gray-50">
                    <% solicitacoesRecentes.forEach(function(s) { %>
                    <a href="/solicitacoes" class="flex items-start gap-3 px-5 py-3 hover:bg-gray-50 transition group">
                        <div class="flex-1 min-w-0">
                            <p class="text-[10px] font-semibold text-gray-400 uppercase mb-0.5"><%= s.tipo_midia %></p>
                            <p class="text-sm font-medium text-gray-900 truncate group-hover:text-blue-700 transition"><%= s.titulo %></p>
                            <p class="text-xs text-gray-400 mt-0.5 truncate"><%= s.secretaria ? s.secretaria.nome : '—' %></p>
                        </div>
                        <% if(s.prioridade === 'alta') { %>
                        <span class="shrink-0 mt-0.5 px-1.5 py-0.5 text-[10px] font-bold rounded bg-red-50 text-red-600 border border-red-200 uppercase">alta</span>
                        <% } %>
                    </a>
                    <% }); %>
                </div>
                <% } %>
            </div>

        </div><!-- /col-direita -->

    </div><!-- /grid -->

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
(function() {
    var labels  = <%- JSON.stringify(semanaLabels) %>;
    var volumes = <%- JSON.stringify(volumeSemanal) %>;
    var ctx = document.getElementById('chartSemanal');
    if (!ctx) return;
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Solicitações',
                data: volumes,
                backgroundColor: volumes.map(function(_, i) {
                    return i === volumes.length - 1 ? '#3b82f6' : '#bfdbfe';
                }),
                borderRadius: 5,
                borderSkipped: false,
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        title: function(items) { return 'Semana de ' + items[0].label; },
                        label: function(item) { return item.raw + ' solicitaç' + (item.raw === 1 ? 'ão' : 'ões'); }
                    }
                }
            },
            scales: {
                y: { beginAtZero: true, ticks: { stepSize: 1, font: { size: 11 } }, grid: { color: '#f1f5f9' } },
                x: { ticks: { font: { size: 11 } }, grid: { display: false } }
            }
        }
    });
}());
</script>

<% if((user.role === 'admin' || user.role === 'secom') && metas && metas.length > 0) { %>
<script>
function metasDashboard() {
    var metasData = <%- JSON.stringify(metas) %>;
    var progressoData = <%- JSON.stringify(metasProgresso) %>;
    return {
        celebrando: false,
        mensagemCelebracao: '',
        verificarCelebracoes: function() {
            var atingidas = metasData.filter(function(m) { return (progressoData[m.tipo_midia] || 0) >= m.quantidade; });
            if (!atingidas.length) return;
            var chave = 'metas_celebradas_' + new Date().getFullYear() + '_' + new Date().getMonth();
            var jaCelebradas = JSON.parse(sessionStorage.getItem(chave) || '[]');
            var novas = atingidas.filter(function(m) { return !jaCelebradas.includes(m.tipo_midia); });
            if (!novas.length) return;
            sessionStorage.setItem(chave, JSON.stringify(jaCelebradas.concat(novas.map(function(m) { return m.tipo_midia; }))));
            this.mensagemCelebracao = novas.length === 1
                ? 'Meta de ' + novas[0].tipo_midia + ' atingida!'
                : novas.length + ' metas atingidas: ' + novas.map(function(m) { return m.tipo_midia; }).join(', ') + '!';
            this.celebrando = true;
            this.lancarConfetes();
            setTimeout(function() { this.celebrando = false; }.bind(this), 8000);
        },
        lancarConfetes: function() {
            var container = document.getElementById('confetti-container');
            if (!container) return;
            var cores = ['#10b981','#34d399','#fbbf24','#60a5fa','#a78bfa','#f472b6'];
            for (var i = 0; i < 60; i++) {
                (function(i) {
                    var p = document.createElement('div');
                    p.style.cssText = 'position:absolute;width:' + (Math.random()*8+4) + 'px;height:' + (Math.random()*8+4) + 'px;background:' + cores[i % cores.length] + ';border-radius:' + (Math.random() > 0.5 ? '50%' : '2px') + ';left:' + (Math.random()*100) + '%;top:-10px;opacity:0;transform:rotate(' + (Math.random()*360) + 'deg)';
                    container.appendChild(p);
                    setTimeout(function() {
                        p.style.transition = 'all ' + (2000 + Math.random()*2000) + 'ms ease-in';
                        p.style.top = '90%'; p.style.opacity = '1';
                        p.style.transform = 'rotate(' + (Math.random()*720) + 'deg)';
                        setTimeout(function() { if (p.parentNode) p.parentNode.removeChild(p); }, 4200);
                    }, Math.random() * 1500);
                })(i);
            }
        },
    };
}
</script>
<% } %>
