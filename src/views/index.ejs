<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">Bem-vindo, <%= user.nome.split(' ')[0] %></h2>
            <p class="text-sm text-gray-400 mt-0.5">Acompanhe as atividades de comunicação hoje.</p>
        </div>
        <a href="/solicitacoes/nova" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Nova Solicitação
        </a>
    </div>

    <!-- Stat cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">

        <!-- Solicitações Pendentes -->
        <div class="bg-white rounded-lg border border-gray-200 border-l-4 border-l-orange-400 p-5 flex items-center gap-4">
            <div class="bg-orange-50 rounded-lg p-2.5 shrink-0">
                <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div class="min-w-0">
                <p class="text-xs font-medium text-gray-400">Solicitações Pendentes</p>
                <p class="text-2xl font-bold text-gray-900 leading-tight"><%= solicitacoesPendentes %></p>
                <a href="/solicitacoes" class="text-xs text-orange-600 font-medium hover:underline">Ver solicitações &rarr;</a>
            </div>
        </div>

        <!-- Eventos na Semana -->
        <div class="bg-white rounded-lg border border-gray-200 border-l-4 border-l-blue-400 p-5 flex items-center gap-4">
            <div class="bg-blue-50 rounded-lg p-2.5 shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
            <div class="min-w-0">
                <p class="text-xs font-medium text-gray-400">Eventos nos Próximos 7 dias</p>
                <p class="text-2xl font-bold text-gray-900 leading-tight"><%= eventosNaSemana %></p>
                <a href="/eventos" class="text-xs text-blue-600 font-medium hover:underline">Ver calendário &rarr;</a>
            </div>
        </div>

        <!-- Releases Publicados -->
        <div class="bg-white rounded-lg border border-gray-200 border-l-4 border-l-indigo-400 p-5 flex items-center gap-4">
            <div class="bg-indigo-50 rounded-lg p-2.5 shrink-0">
                <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM15 4v4h4"></path></svg>
            </div>
            <div class="min-w-0">
                <p class="text-xs font-medium text-gray-400">Releases Publicados</p>
                <p class="text-2xl font-bold text-gray-900 leading-tight"><%= releasesPublicados %></p>
                <a href="/releases" class="text-xs text-indigo-600 font-medium hover:underline">Ver releases &rarr;</a>
            </div>
        </div>

        <!-- Usuários Ativos -->
        <div class="bg-white rounded-lg border border-gray-200 border-l-4 border-l-emerald-400 p-5 flex items-center gap-4">
            <div class="bg-emerald-50 rounded-lg p-2.5 shrink-0">
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            </div>
            <div class="min-w-0">
                <p class="text-xs font-medium text-gray-400">Usuários Ativos</p>
                <p class="text-2xl font-bold text-gray-900 leading-tight"><%= totalUsuativos %></p>
                <% if(user.role === 'admin') { %>
                <a href="/admin/usuarios" class="text-xs text-emerald-600 font-medium hover:underline">Gerenciar &rarr;</a>
                <% } else { %>
                <p class="text-xs text-gray-400">No sistema</p>
                <% } %>
            </div>
        </div>

    </div>

    <% if((user.role === 'admin' || user.role === 'secom') && metas && metas.length > 0) { %>
    <!-- Metas do Mês -->
    <div x-data="metasDashboard()" x-init="verificarCelebracoes()">

        <!-- Banner de parabéns (aparece quando alguma meta nova é atingida) -->
        <div x-show="celebrando" x-transition.duration.500ms
            class="relative mb-4 overflow-hidden rounded-xl border-2 border-emerald-400 bg-gradient-to-r from-emerald-50 via-green-50 to-emerald-50 p-5 shadow-md">
            <div id="confetti-container" class="pointer-events-none absolute inset-0 overflow-hidden"></div>
            <div class="relative flex items-center gap-4">
                <div class="text-4xl animate-bounce">🎉</div>
                <div>
                    <p class="text-lg font-bold text-emerald-800">Parabéns!</p>
                    <p class="text-sm text-emerald-700" x-text="mensagemCelebracao"></p>
                </div>
                <button @click="celebrando = false" class="ml-auto p-1 text-emerald-500 hover:text-emerald-700 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>

        <div class="flex items-center justify-between mb-3">
            <h3 class="text-sm font-semibold text-gray-900">Metas do Mês</h3>
            <span class="text-xs text-gray-400"><%= new Date().toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }) %></span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-3">
            <% metas.forEach(function(m) {
                var progresso = metasProgresso[m.tipo_midia] || 0;
                var pct = Math.min(100, Math.round(progresso / m.quantidade * 100));
                var atingida = progresso >= m.quantidade;
            %>
            <div class="rounded-xl border p-4 space-y-3 transition-all duration-300
                <%= atingida ? 'border-emerald-300 bg-gradient-to-br from-emerald-50 to-green-50 shadow-sm' : 'border-gray-200 bg-white' %>">
                <div class="flex items-start justify-between gap-2">
                    <p class="text-xs font-semibold text-gray-600 leading-tight"><%= m.tipo_midia %></p>
                    <% if(atingida) { %>
                    <span class="shrink-0 inline-flex items-center gap-1 px-1.5 py-0.5 bg-emerald-100 text-emerald-700 text-[10px] font-bold rounded-full">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        Atingida!
                    </span>
                    <% } %>
                </div>
                <div>
                    <div class="flex justify-between items-baseline mb-1.5">
                        <span class="text-2xl font-bold <%= atingida ? 'text-emerald-700' : 'text-gray-900' %>"><%= progresso %></span>
                        <span class="text-xs text-gray-400">meta: <%= m.quantidade %></span>
                    </div>
                    <div class="w-full h-2 bg-gray-100 rounded-full overflow-hidden">
                        <div class="h-full rounded-full transition-all duration-700 ease-out
                            <%= atingida ? 'bg-emerald-500' : pct >= 75 ? 'bg-blue-500' : pct >= 50 ? 'bg-indigo-400' : 'bg-gray-300' %>"
                            style="width: <%= pct %>%"></div>
                    </div>
                    <p class="text-[10px] text-gray-400 mt-1 text-right"><%= pct %>% concluído</p>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Calendário Geral de Eventos (somente leitura) -->
        <div class="lg:col-span-2 space-y-3" x-data="dashCalendar()">
            <div class="flex items-center justify-between flex-wrap gap-2">
                <div class="flex items-center gap-2">
                    <h3 class="text-sm font-semibold text-gray-900">Agenda de Eventos</h3>
                    <span class="text-[10px] font-medium text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">Todas as secretarias · somente leitura</span>
                </div>
                <a href="/eventos" class="text-xs font-medium text-blue-600 hover:underline">Ver calendário completo →</a>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
                <!-- Navegação do mês -->
                <div class="flex items-center justify-between px-4 py-2.5 border-b border-gray-100 bg-gray-50/80">
                    <button @click="prevMonth()" class="p-1.5 rounded-lg hover:bg-gray-200 transition text-gray-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <span class="text-sm font-bold text-gray-800 capitalize" x-text="monthLabel()"></span>
                    <button @click="nextMonth()" class="p-1.5 rounded-lg hover:bg-gray-200 transition text-gray-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
                <!-- Cabeçalho dos dias -->
                <div class="grid grid-cols-7 border-b border-gray-100 bg-gray-50">
                    <template x-for="d in ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb']">
                        <div class="py-1.5 text-center text-[10px] font-semibold text-gray-400 uppercase tracking-wider" x-text="d"></div>
                    </template>
                </div>
                <!-- Grade de dias -->
                <div class="grid grid-cols-7 divide-x divide-y divide-gray-100">
                    <template x-for="(day, idx) in calendarDays()" :key="idx">
                        <div class="min-h-[68px] p-1"
                            :class="{'bg-gray-50/50': !day.currentMonth, 'bg-blue-50/30': day.isToday}">
                            <div class="flex justify-end mb-0.5">
                                <span class="text-[11px] font-semibold w-5 h-5 flex items-center justify-center rounded-full"
                                    :class="{
                                        'text-gray-300': !day.currentMonth,
                                        'bg-blue-600 text-white': day.isToday,
                                        'text-gray-600': day.currentMonth && !day.isToday
                                    }" x-text="day.day"></span>
                            </div>
                            <div class="space-y-0.5">
                                <template x-for="e in getEventsForDay(day.date).slice(0, 2)" :key="e.id">
                                    <div class="px-1 py-0.5 rounded text-[10px] font-medium truncate leading-tight"
                                        :style="'background:' + (e.secretaria ? e.secretaria.cor : '#6366f1') + '20;color:' + (e.secretaria ? e.secretaria.cor : '#6366f1')"
                                        :title="e.titulo + (e.local ? ' · ' + e.local : '')"
                                        x-text="e.titulo"></div>
                                </template>
                                <div x-show="getEventsForDay(day.date).length > 2"
                                    class="text-[9px] text-gray-400 font-medium pl-0.5"
                                    x-text="'+' + (getEventsForDay(day.date).length - 2) + ' mais'"></div>
                            </div>
                        </div>
                    </template>
                </div>
                <!-- Legenda rápida: eventos do mês -->
                <div x-show="getEventsInMonth().length > 0" class="border-t border-gray-100 px-3 py-2 bg-gray-50/60">
                    <p class="text-[10px] font-semibold text-gray-400 uppercase tracking-widest mb-1.5">Eventos neste mês</p>
                    <div class="space-y-0.5 max-h-24 overflow-y-auto">
                        <template x-for="e in getEventsInMonth()" :key="e.id">
                            <div class="flex items-center gap-1.5 text-xs text-gray-600">
                                <span class="w-1.5 h-1.5 rounded-full shrink-0" :style="'background:' + (e.secretaria ? e.secretaria.cor : '#6366f1')"></span>
                                <span class="font-medium" x-text="fmtDay(e.data_inicio)"></span>
                                <span class="truncate" x-text="e.titulo"></span>
                                <span x-show="e.secretaria" class="shrink-0 text-[10px] font-semibold px-1.5 py-0.5 rounded"
                                    :style="'background:' + (e.secretaria ? e.secretaria.cor : '') + '20;color:' + (e.secretaria ? e.secretaria.cor : '')"
                                    x-text="e.secretaria ? e.secretaria.nome : ''"></span>
                            </div>
                        </template>
                    </div>
                </div>
                <div x-show="getEventsInMonth().length === 0" class="border-t border-gray-100 py-4 text-center text-xs text-gray-400">
                    Nenhum evento agendado neste mês.
                </div>
            </div>
        </div>

        <!-- Solicitações Recentes -->
        <div class="space-y-3">
            <div class="flex items-center justify-between">
                <h3 class="text-sm font-semibold text-gray-900">Solicitações Recentes</h3>
                <a href="/solicitacoes" class="text-xs font-medium text-blue-600 hover:underline">Ver tudo</a>
            </div>
            <% if(solicitacoesRecentes.length === 0) { %>
                <div class="bg-white rounded-lg border border-gray-200 py-14 text-center text-gray-400">
                    <svg class="w-10 h-10 mx-auto mb-2 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <p class="text-sm">Nenhuma solicitação ainda.</p>
                    <a href="/solicitacoes/nova" class="block mt-1 text-blue-600 font-medium hover:underline text-sm">Abrir chamado</a>
                </div>
            <% } else { %>
            <div class="space-y-2">
                <% solicitacoesRecentes.forEach(s => { %>
                <a href="/solicitacoes" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-gray-300 transition">
                    <div class="flex items-start justify-between gap-2">
                        <div class="min-w-0">
                            <p class="text-[11px] font-semibold text-gray-400 uppercase mb-0.5"><%= s.tipo_midia %></p>
                            <p class="text-sm font-medium text-gray-900 line-clamp-1"><%= s.titulo %></p>
                            <p class="text-xs text-gray-400 mt-0.5"><%= s.secretaria ? s.secretaria.nome : '—' %></p>
                        </div>
                        <% if(s.prioridade === 'alta') { %>
                        <span class="shrink-0 px-2 py-0.5 text-[10px] font-semibold rounded bg-red-50 text-red-600 border border-red-200 uppercase">
                            <%= s.prioridade %>
                        </span>
                        <% } else { %>
                        <span class="shrink-0 px-2 py-0.5 text-[10px] font-medium rounded bg-gray-100 text-gray-500 uppercase">
                            <%= s.prioridade %>
                        </span>
                        <% } %>
                    </div>
                </a>
                <% }) %>
            </div>
            <% } %>
        </div>

    </div>
</div>

<script>
(function() {
    var _DASH_EVENTOS = <%- JSON.stringify(proximosEventos.map(function(e) { return {
        id: e.id,
        titulo: e.titulo,
        local: e.local || '',
        data_inicio: e.data_inicio,
        status: e.status,
        secretaria: e.secretaria ? { id: e.secretaria.id, nome: e.secretaria.nome, cor: e.secretaria.cor } : null
    }; })) %>;

    document.addEventListener('alpine:init', function() {
        Alpine.data('dashCalendar', function() {
            return {
                eventos: _DASH_EVENTOS,
                calYear: new Date().getFullYear(),
                calMonth: new Date().getMonth(),

                monthLabel: function() {
                    return new Date(this.calYear, this.calMonth, 1)
                        .toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
                },
                prevMonth: function() {
                    if (this.calMonth === 0) { this.calMonth = 11; this.calYear--; }
                    else this.calMonth--;
                },
                nextMonth: function() {
                    if (this.calMonth === 11) { this.calMonth = 0; this.calYear++; }
                    else this.calMonth++;
                },
                calendarDays: function() {
                    var today = new Date();
                    var first = new Date(this.calYear, this.calMonth, 1);
                    var last  = new Date(this.calYear, this.calMonth + 1, 0);
                    var days  = [];
                    for (var i = 0; i < first.getDay(); i++) {
                        var d = new Date(this.calYear, this.calMonth, i - first.getDay() + 1);
                        days.push({ day: d.getDate(), date: d, currentMonth: false, isToday: false });
                    }
                    for (var i = 1; i <= last.getDate(); i++) {
                        var d = new Date(this.calYear, this.calMonth, i);
                        days.push({ day: i, date: d, currentMonth: true, isToday: d.toDateString() === today.toDateString() });
                    }
                    while (days.length < 42) {
                        var n = days.length - first.getDay() - last.getDate() + 1;
                        var d = new Date(this.calYear, this.calMonth + 1, n);
                        days.push({ day: d.getDate(), date: d, currentMonth: false, isToday: false });
                    }
                    return days;
                },
                getEventsForDay: function(date) {
                    return this.eventos.filter(function(e) {
                        var ed = new Date(e.data_inicio);
                        return ed.getFullYear() === date.getFullYear() &&
                               ed.getMonth()    === date.getMonth()    &&
                               ed.getDate()     === date.getDate();
                    });
                },
                getEventsInMonth: function() {
                    var y = this.calYear, m = this.calMonth;
                    return this.eventos.filter(function(e) {
                        var ed = new Date(e.data_inicio);
                        return ed.getFullYear() === y && ed.getMonth() === m;
                    });
                },
                fmtDay: function(d) {
                    return new Date(d).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
                }
            };
        });
    });
}());
</script>

<% if((user.role === 'admin' || user.role === 'secom') && metas && metas.length > 0) { %>
<script>
function metasDashboard() {
    var metasData = <%- JSON.stringify(metas) %>;
    var progressoData = <%- JSON.stringify(metasProgresso) %>;

    return {
        celebrando: false,
        mensagemCelebracao: '',

        verificarCelebracoes: function() {
            var atingidas = metasData.filter(function(m) {
                return (progressoData[m.tipo_midia] || 0) >= m.quantidade;
            });
            if (atingidas.length === 0) return;

            var chave = 'metas_celebradas_' + new Date().getFullYear() + '_' + new Date().getMonth();
            var jaCelebradas = JSON.parse(sessionStorage.getItem(chave) || '[]');
            var novas = atingidas.filter(function(m) { return !jaCelebradas.includes(m.tipo_midia); });
            if (novas.length === 0) return;

            sessionStorage.setItem(chave, JSON.stringify(jaCelebradas.concat(novas.map(function(m) { return m.tipo_midia; }))));
            this.mensagemCelebracao = novas.length === 1
                ? 'A meta de ' + novas[0].tipo_midia + ' foi atingida este mês!'
                : novas.length + ' metas foram atingidas este mês: ' + novas.map(function(m) { return m.tipo_midia; }).join(', ') + '!';
            this.celebrando = true;
            this.lancarConfetes();
            setTimeout(function() { this.celebrando = false; }.bind(this), 8000);
        },

        lancarConfetes: function() {
            var container = document.getElementById('confetti-container');
            if (!container) return;
            var cores = ['#10b981','#34d399','#6ee7b7','#fbbf24','#f59e0b','#60a5fa','#a78bfa','#f472b6'];
            for (var i = 0; i < 60; i++) {
                (function(i) {
                    var p = document.createElement('div');
                    var cor = cores[i % cores.length];
                    p.style.cssText = 'position:absolute;width:' + (Math.random()*8+4) + 'px;height:' + (Math.random()*8+4) + 'px;background:' + cor + ';border-radius:' + (Math.random() > 0.5 ? '50%' : '2px') + ';left:' + (Math.random()*100) + '%;top:-10px;opacity:0;transform:rotate(' + (Math.random()*360) + 'deg)';
                    container.appendChild(p);
                    var delay = Math.random() * 1500;
                    var duration = 2000 + Math.random() * 2000;
                    setTimeout(function() {
                        p.style.transition = 'all ' + duration + 'ms ease-in';
                        p.style.top = (80 + Math.random()*20) + '%';
                        p.style.left = (parseFloat(p.style.left) + (Math.random()*30 - 15)) + '%';
                        p.style.opacity = '1';
                        p.style.transform = 'rotate(' + (Math.random()*720) + 'deg)';
                        setTimeout(function() { p.style.opacity = '0'; }, duration * 0.7);
                        setTimeout(function() { if (p.parentNode) p.parentNode.removeChild(p); }, duration + 100);
                    }, delay);
                })(i);
            }
        },
    };
}
</script>
<% } %>
