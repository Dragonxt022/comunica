<style>
@keyframes imgShimmer {
  0%   { background-position: -200% 0; }
  100% { background-position:  200% 0; }
}
.img-skel {
  background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
  background-size: 200% 100%;
  animation: imgShimmer 1.4s ease-in-out infinite;
}
</style>
<div class="space-y-6" x-data="bibliotecaPage()">

    <!-- Cabeçalho -->
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">Biblioteca de Artes</h2>
            <p class="text-sm text-gray-400 mt-0.5">Acervo de todas as produções finalizadas</p>
        </div>
        <span class="text-sm font-medium text-gray-500 bg-gray-100 px-3 py-1.5 rounded-full">
            <%= totalGeral %> arte<%= totalGeral !== 1 ? 's' : '' %>
        </span>
    </div>

    <!-- Filtros -->
    <form method="GET" action="/biblioteca" class="bg-white rounded-xl border border-gray-200 p-4 flex flex-wrap gap-3 items-end">
        <% if(user.role !== 'secretaria') { %>
        <div class="flex-1 min-w-[160px]">
            <label class="block text-xs font-semibold text-gray-500 mb-1.5">Secretaria</label>
            <select name="secretaria_id"
                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">Todas as secretarias</option>
                <% secretarias.forEach(function(s) { %>
                <option value="<%= s.id %>" <%= filtros.secretaria_id == s.id ? 'selected' : '' %>><%= s.nome %></option>
                <% }) %>
            </select>
        </div>
        <% } %>

        <div class="flex-1 min-w-[160px]">
            <label class="block text-xs font-semibold text-gray-500 mb-1.5">Tipo de Mídia</label>
            <select name="tipo_midia"
                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
                <option value="">Todos os tipos</option>
                <% tipos.forEach(function(t) { %>
                <option value="<%= t %>" <%= filtros.tipo_midia === t ? 'selected' : '' %>><%= t %></option>
                <% }) %>
            </select>
        </div>

        <div class="min-w-[150px]">
            <label class="block text-xs font-semibold text-gray-500 mb-1.5">Mês</label>
            <input type="month" name="mes" value="<%= filtros.mes %>"
                class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <button type="submit"
            class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 010 2H4a1 1 0 01-1-1zM6 10h12M9 16h6"></path></svg>
            Filtrar
        </button>

        <% if (filtros.secretaria_id || filtros.tipo_midia || filtros.mes) { %>
        <a href="/biblioteca" class="px-4 py-2 text-sm text-gray-400 hover:text-gray-700 transition font-medium">
            Limpar filtros
        </a>
        <% } %>
    </form>

    <!-- Grade de artes -->
    <% if (artes.length === 0) { %>
    <div class="bg-white rounded-xl border border-gray-200 py-20 text-center">
        <svg class="w-12 h-12 mx-auto text-gray-200 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <p class="text-gray-400 font-medium">Nenhuma arte encontrada</p>
        <p class="text-sm text-gray-300 mt-1">Tente ajustar os filtros acima</p>
    </div>
    <% } else { %>

    <!-- Visualização: grade ou lista -->
    <div class="flex items-center justify-end gap-2">
        <button @click="view='grid'" :class="view==='grid' ? 'bg-blue-50 text-blue-600' : 'text-gray-400 hover:text-gray-600'"
            class="p-2 rounded-lg transition" title="Grade">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5 3a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2H5zm8 0a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2V5a2 2 0 00-2-2h-2zM5 11a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2H5zm8 0a2 2 0 00-2 2v2a2 2 0 002 2h2a2 2 0 002-2v-2a2 2 0 00-2-2h-2z"></path></svg>
        </button>
        <button @click="view='list'" :class="view==='list' ? 'bg-blue-50 text-blue-600' : 'text-gray-400 hover:text-gray-600'"
            class="p-2 rounded-lg transition" title="Lista">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
    </div>

    <!-- Modo grade -->
    <div x-show="view==='grid'" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
        <% artes.forEach(function(arte) { %>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 cursor-pointer group"
             @click="openLightbox('<%= arte.arte_final_url %>', '<%= (arte.titulo || '').replace(/'/g, "\\'") %>', '<%= arte.link_publicacao || '' %>')">
            <div class="aspect-square overflow-hidden relative img-skel">
                <img src="<%= arte.arte_final_url %>" alt="<%= arte.titulo %>"
                     class="relative w-full h-full object-cover group-hover:scale-105 transition-all duration-300"
                     style="opacity:0;transition:opacity .35s ease"
                     onload="this.style.opacity='1';this.parentElement.classList.remove('img-skel')"
                     onerror="this.style.display='none';this.parentElement.classList.remove('img-skel');this.nextElementSibling.style.display='flex'">
                <div class="absolute inset-0 hidden items-center justify-center text-gray-300 bg-gray-50">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <!-- Tipo badge -->
                <span class="absolute top-2 left-2 bg-white/90 text-gray-700 text-[9px] font-bold px-1.5 py-0.5 rounded-full backdrop-blur-sm truncate max-w-[80%]">
                    <%= arte.tipo_midia %>
                </span>
            </div>
            <div class="p-3 space-y-1.5">
                <p class="text-xs font-semibold text-gray-900 line-clamp-2 leading-tight"><%= arte.titulo %></p>
                <% if (arte.secretaria) { %>
                <span class="inline-block px-2 py-0.5 rounded-full text-[10px] font-bold leading-none"
                      style="background:<%= arte.secretaria.cor %>22;color:<%= arte.secretaria.cor %>">
                    <%= arte.secretaria.nome %>
                </span>
                <% } %>
                <p class="text-[10px] text-gray-400">
                    <%= new Date(arte.updatedAt).toLocaleDateString('pt-BR', { day:'2-digit', month:'short', year:'numeric' }) %>
                </p>
            </div>
        </div>
        <% }) %>
    </div>

    <!-- Modo lista -->
    <div x-show="view==='list'" class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide w-16">Arte</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Título</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide hidden md:table-cell">Secretaria</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide hidden lg:table-cell">Tipo</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide hidden lg:table-cell">Data</th>
                    <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <% artes.forEach(function(arte) { %>
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3">
                        <img src="<%= arte.arte_final_url %>" alt="" class="w-12 h-12 object-cover rounded-lg border border-gray-100 cursor-pointer hover:opacity-80"
                             @click="openLightbox('<%= arte.arte_final_url %>', '<%= (arte.titulo || '').replace(/'/g, "\\'") %>', '<%= arte.link_publicacao || '' %>')">
                    </td>
                    <td class="px-4 py-3">
                        <p class="font-medium text-gray-900 line-clamp-1"><%= arte.titulo %></p>
                        <% if (arte.prioridade === 'alta') { %>
                        <span class="text-[10px] text-red-500 font-semibold">● Alta prioridade</span>
                        <% } %>
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell">
                        <% if (arte.secretaria) { %>
                        <span class="inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold"
                              style="background:<%= arte.secretaria.cor %>22;color:<%= arte.secretaria.cor %>">
                            <%= arte.secretaria.nome %>
                        </span>
                        <% } else { %><span class="text-gray-300">—</span><% } %>
                    </td>
                    <td class="px-4 py-3 hidden lg:table-cell">
                        <span class="text-xs text-gray-500"><%= arte.tipo_midia %></span>
                    </td>
                    <td class="px-4 py-3 hidden lg:table-cell">
                        <span class="text-xs text-gray-400">
                            <%= new Date(arte.updatedAt).toLocaleDateString('pt-BR') %>
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-2">
                            <button @click="openLightbox('<%= arte.arte_final_url %>', '<%= (arte.titulo || '').replace(/'/g, "\\'") %>', '<%= arte.link_publicacao || '' %>')"
                                class="text-xs text-blue-600 hover:text-blue-800 font-medium transition">
                                Ver
                            </button>
                            <a href="<%= arte.arte_final_url %>" download target="_blank"
                               class="text-xs text-gray-400 hover:text-gray-700 font-medium transition">
                                Download
                            </a>
                            <% if (arte.link_publicacao) { %>
                            <a href="<%= arte.link_publicacao %>" target="_blank"
                               class="text-xs text-indigo-600 hover:text-indigo-800 font-medium transition">
                                Publicação
                            </a>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>

    <!-- Lightbox -->
    <div x-show="lightbox.open" x-cloak
         @keydown.escape.window="lightbox.open = false"
         class="fixed inset-0 z-50 flex items-center justify-center p-4"
         style="background:rgba(0,0,0,0.88);backdrop-filter:blur(4px)"
         @click.self="lightbox.open = false"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100">
        <div class="relative max-w-4xl w-full flex flex-col items-center gap-4">
            <!-- Fechar -->
            <button @click="lightbox.open = false"
                class="absolute -top-12 right-0 text-white/60 hover:text-white transition">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
            <!-- Imagem -->
            <img :src="lightbox.url" :alt="lightbox.titulo"
                 class="max-h-[75vh] max-w-full rounded-xl object-contain shadow-2xl">
            <!-- Info + ações -->
            <div class="flex items-center gap-4 bg-white/10 backdrop-blur-sm rounded-full px-5 py-2.5">
                <p class="text-white font-semibold text-sm" x-text="lightbox.titulo"></p>
                <a :href="lightbox.url" download target="_blank"
                   class="flex items-center gap-1.5 text-sm text-blue-300 hover:text-white transition font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    Download
                </a>
                <template x-if="lightbox.link">
                    <a :href="lightbox.link" target="_blank"
                       class="flex items-center gap-1.5 text-sm text-indigo-300 hover:text-white transition font-medium">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        Ver publicação
                    </a>
                </template>
            </div>
        </div>
    </div>

</div>

<script>
function bibliotecaPage() {
    return {
        view: localStorage.getItem('biblioteca_view') || 'grid',
        lightbox: { open: false, url: '', titulo: '', link: '' },

        openLightbox(url, titulo, link) {
            this.lightbox = { open: true, url, titulo, link };
        },

        init() {
            this.$watch('view', v => localStorage.setItem('biblioteca_view', v));
        }
    };
}
</script>
