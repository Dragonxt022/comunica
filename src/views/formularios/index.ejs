<div class="max-w-5xl mx-auto px-4 py-8">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Templates de Formulário</h1>
      <p class="text-sm text-gray-500 mt-0.5">Modelos de formulário para inscrições em eventos</p>
    </div>
    <a href="/formularios/novo" class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
      Novo Template
    </a>
  </div>

  <% if (templates.length === 0) { %>
  <div class="bg-white rounded-xl border border-dashed border-gray-300 p-12 text-center">
    <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
    <p class="text-gray-500 text-sm">Nenhum template criado ainda.</p>
    <a href="/formularios/novo" class="mt-3 inline-block text-sm text-blue-600 hover:underline font-medium">Criar primeiro template →</a>
  </div>
  <% } else { %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Nome</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Campos</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Criado por</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Data</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% templates.forEach(function(tpl) { %>
        <% let numCampos = 0; try { numCampos = JSON.parse(tpl.campos || '[]').length; } catch(e){} %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-4 py-3">
            <div class="font-medium text-gray-900"><%= tpl.nome %></div>
            <% if(tpl.descricao) { %><div class="text-xs text-gray-500 mt-0.5 line-clamp-1"><%= tpl.descricao %></div><% } %>
          </td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 bg-blue-50 text-blue-700 text-xs font-medium rounded-full"><%= numCampos %> campo<%= numCampos !== 1 ? 's' : '' %></span>
          </td>
          <td class="px-4 py-3 text-gray-600"><%= tpl.autor ? tpl.autor.nome : '—' %></td>
          <td class="px-4 py-3 text-gray-500"><%= new Date(tpl.createdAt).toLocaleDateString('pt-BR') %></td>
          <td class="px-4 py-3">
            <div class="flex items-center justify-end gap-2">
              <a href="/formularios/<%= tpl.id %>/editar" class="text-xs px-3 py-1.5 bg-gray-100 text-gray-700 rounded-md hover:bg-gray-200 transition font-medium">Editar</a>
              <button onclick="deletarTemplate(<%= tpl.id %>, '<%= tpl.nome.replace(/'/g, \"\\\\'\" ) %>')"
                class="text-xs px-3 py-1.5 bg-red-50 text-red-700 rounded-md hover:bg-red-100 transition font-medium">
                Excluir
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<script>
async function deletarTemplate(id, nome) {
  if (!confirm(`Excluir o template "${nome}"? Esta ação não pode ser desfeita.`)) return;
  const r = await fetch(`/formularios/${id}/deletar`, { method: 'POST' });
  if (r.ok) location.reload();
  else alert('Erro ao excluir template.');
}
</script>
