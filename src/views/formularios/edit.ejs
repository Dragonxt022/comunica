<%
  let camposIniciais = [];
  try { camposIniciais = JSON.parse(template.campos || '[]'); } catch(e) {}
  camposIniciais.forEach(function(c) { c.opcoes_raw = (c.opcoes || []).join('\n'); });
%>
<div class="max-w-4xl mx-auto px-4 py-8" x-data="formBuilder(<%= JSON.stringify(camposIniciais).replace(/</g,'\\u003c') %>)">
  <div class="flex items-center gap-3 mb-6">
    <a href="/formularios" class="text-gray-500 hover:text-gray-700 transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
    </a>
    <h1 class="text-xl font-bold text-gray-900">Editar Template</h1>
  </div>

  <form action="/formularios/<%= template.id %>" method="POST">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Painel esquerdo: campos -->
      <div class="lg:col-span-2 space-y-4">
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <h2 class="font-semibold text-gray-800 mb-4">Informações do Template</h2>
          <div class="space-y-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nome do template <span class="text-red-500">*</span></label>
              <input type="text" name="nome" required value="<%= template.nome %>" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Descrição</label>
              <input type="text" name="descricao" value="<%= template.descricao || '' %>" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
            </div>
          </div>
        </div>

        <!-- Builder de campos -->
        <div class="bg-white rounded-xl border border-gray-200 p-5">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-gray-800">Campos do Formulário</h2>
            <span class="text-xs text-gray-500">Nome, e-mail e telefone são incluídos automaticamente</span>
          </div>

          <div class="space-y-3 mb-4" x-show="campos.length > 0">
            <template x-for="(campo, idx) in campos" :key="campo.id">
              <div class="border border-gray-200 rounded-lg p-4 bg-gray-50">
                <div class="flex items-start gap-3">
                  <div class="flex flex-col gap-1 mt-1.5 shrink-0">
                    <button type="button" @click="moverCima(idx)" :disabled="idx === 0" class="text-gray-400 hover:text-gray-600 disabled:opacity-30 transition">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                    </button>
                    <button type="button" @click="moverBaixo(idx)" :disabled="idx === campos.length - 1" class="text-gray-400 hover:text-gray-600 disabled:opacity-30 transition">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                  </div>

                  <div class="flex-1 space-y-3">
                    <div class="grid grid-cols-2 gap-3">
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Tipo</label>
                        <select x-model="campo.tipo" class="w-full border border-gray-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                          <option value="text">Texto curto</option>
                          <option value="textarea">Texto longo</option>
                          <option value="email">E-mail</option>
                          <option value="phone">Telefone</option>
                          <option value="number">Número</option>
                          <option value="date">Data</option>
                          <option value="select">Lista (select)</option>
                          <option value="radio">Múltipla escolha (radio)</option>
                          <option value="checkbox">Caixas de seleção (checkbox)</option>
                        </select>
                      </div>
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Rótulo (label) <span class="text-red-500">*</span></label>
                        <input type="text" x-model="campo.label" placeholder="Ex: CPF, Instituição..." class="w-full border border-gray-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                      </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                      <div>
                        <label class="block text-xs font-medium text-gray-600 mb-1">Placeholder</label>
                        <input type="text" x-model="campo.placeholder" class="w-full border border-gray-300 rounded-md px-2 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                      </div>
                      <div class="flex items-end pb-1">
                        <label class="flex items-center gap-2 cursor-pointer">
                          <input type="checkbox" x-model="campo.required" class="w-4 h-4 accent-blue-600">
                          <span class="text-sm text-gray-700 font-medium">Campo obrigatório</span>
                        </label>
                      </div>
                    </div>

                    <div x-show="['select','radio','checkbox'].includes(campo.tipo)" class="space-y-2">
                      <label class="block text-xs font-medium text-gray-600">Opções (uma por linha)</label>
                      <textarea x-model="campo.opcoes_raw" rows="3" placeholder="Opção A&#10;Opção B&#10;Opção C"
                        @input="campo.opcoes = campo.opcoes_raw.split('\n').map(s => s.trim()).filter(Boolean)"
                        class="w-full border border-gray-300 rounded-md px-2 py-1.5 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-blue-500"></textarea>
                    </div>
                  </div>

                  <button type="button" @click="removerCampo(idx)" class="text-red-400 hover:text-red-600 transition mt-1 shrink-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  </button>
                </div>
              </div>
            </template>
          </div>

          <div x-show="campos.length === 0" class="text-center py-8 border-2 border-dashed border-gray-200 rounded-lg mb-4">
            <p class="text-sm text-gray-400">Nenhum campo adicionado.</p>
          </div>

          <button type="button" @click="adicionarCampo()"
            class="w-full py-2.5 border-2 border-dashed border-blue-300 text-blue-600 text-sm font-medium rounded-lg hover:bg-blue-50 transition flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Adicionar campo
          </button>

          <input type="hidden" name="campos" :value="JSON.stringify(campos.map(c => ({
            id: c.id, tipo: c.tipo, label: c.label, placeholder: c.placeholder,
            required: c.required, opcoes: c.opcoes, ordem: c.ordem
          })))">
        </div>
      </div>

      <!-- Painel direito -->
      <div>
        <div class="bg-white rounded-xl border border-gray-200 p-5 sticky top-4">
          <h2 class="font-semibold text-gray-800 mb-4">Pré-visualização</h2>
          <div class="space-y-3 text-sm">
            <div><label class="block text-xs font-semibold text-gray-700 mb-1">Nome completo <span class="text-red-500">*</span></label><div class="border border-gray-200 rounded-md px-3 py-2 text-gray-400 text-xs bg-gray-50">Campo padrão</div></div>
            <div><label class="block text-xs font-semibold text-gray-700 mb-1">E-mail <span class="text-red-500">*</span></label><div class="border border-gray-200 rounded-md px-3 py-2 text-gray-400 text-xs bg-gray-50">Campo padrão</div></div>
            <div><label class="block text-xs font-semibold text-gray-700 mb-1">Telefone</label><div class="border border-gray-200 rounded-md px-3 py-2 text-gray-400 text-xs bg-gray-50">Campo padrão</div></div>

            <template x-for="campo in campos" :key="campo.id">
              <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">
                  <span x-text="campo.label || '(sem rótulo)'"></span>
                  <span x-show="campo.required" class="text-red-500"> *</span>
                </label>
                <template x-if="!['textarea','select','radio','checkbox'].includes(campo.tipo)">
                  <div class="border border-gray-200 rounded-md px-3 py-2 bg-white text-gray-400 text-xs" x-text="campo.placeholder || 'Texto...'"></div>
                </template>
                <template x-if="campo.tipo === 'textarea'">
                  <div class="border border-gray-200 rounded-md px-3 py-2 h-14 bg-white text-gray-400 text-xs" x-text="campo.placeholder || 'Texto longo...'"></div>
                </template>
                <template x-if="campo.tipo === 'select'">
                  <div class="border border-gray-200 rounded-md px-3 py-2 bg-white text-gray-400 text-xs">Lista de opções ▼</div>
                </template>
                <template x-if="['radio','checkbox'].includes(campo.tipo)">
                  <div class="space-y-1">
                    <template x-for="opt in (campo.opcoes.length > 0 ? campo.opcoes.slice(0,3) : ['Opção A','Opção B'])" :key="opt">
                      <div class="flex items-center gap-2">
                        <div :class="campo.tipo === 'radio' ? 'w-3 h-3 rounded-full border border-gray-400' : 'w-3 h-3 rounded border border-gray-400'"></div>
                        <span class="text-xs text-gray-600" x-text="opt"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </div>
            </template>
          </div>

          <div class="mt-5 pt-4 border-t border-gray-100">
            <button type="submit" class="w-full py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition">
              Salvar Alterações
            </button>
            <a href="/formularios" class="mt-2 block text-center text-sm text-gray-500 hover:text-gray-700 transition">Cancelar</a>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
function formBuilder(camposIniciais) {
  return {
    campos: (camposIniciais || []).map(function(c) {
      return Object.assign({ opcoes_raw: (c.opcoes || []).join('\n') }, c);
    }),
    _counter: 0,

    adicionarCampo() {
      this._counter++;
      this.campos.push({
        id: 'campo_' + Date.now() + '_' + this._counter,
        tipo: 'text', label: '', placeholder: '',
        required: false, opcoes: [], opcoes_raw: '',
        ordem: this.campos.length,
      });
    },

    removerCampo(idx) {
      this.campos.splice(idx, 1);
      this.campos.forEach((c, i) => c.ordem = i);
    },

    moverCima(idx) {
      if (idx === 0) return;
      [this.campos[idx - 1], this.campos[idx]] = [this.campos[idx], this.campos[idx - 1]];
      this.campos.forEach((c, i) => c.ordem = i);
    },

    moverBaixo(idx) {
      if (idx === this.campos.length - 1) return;
      [this.campos[idx], this.campos[idx + 1]] = [this.campos[idx + 1], this.campos[idx]];
      this.campos.forEach((c, i) => c.ordem = i);
    },
  };
}
</script>
