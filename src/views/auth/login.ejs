<div class="min-h-screen flex">

    <!-- Painel esquerdo — Marca -->
    <div class="hidden lg:flex w-[460px] shrink-0 bg-slate-900 flex-col px-12 py-10 relative overflow-hidden">

        <!-- Padrão de pontos de fundo -->
        <div class="absolute inset-0 pointer-events-none"
             style="background-image:radial-gradient(rgba(255,255,255,0.055) 1px,transparent 1px);background-size:22px 22px;"></div>
        <!-- Degrade que apaga os pontos na base -->
        <div class="absolute inset-x-0 bottom-0 h-56 bg-gradient-to-t from-slate-900 to-transparent pointer-events-none"></div>

        <!-- Logo + nome -->
        <div class="relative z-10 flex items-center gap-3 mb-14">
            <img src="/icon.svg" alt="Comunica" class="w-10 h-10">
            <span class="text-white font-bold text-lg tracking-tight">Comunica</span>
        </div>

        <!-- Headline -->
        <div class="relative z-10 flex-1">
            <h1 class="text-[2.6rem] font-extrabold text-white leading-[1.15] tracking-tight">
                Comunicação<br>Institucional<br><span class="text-blue-400">unificada.</span>
            </h1>
            <p class="text-slate-400 text-[15px] leading-relaxed mt-5 max-w-[300px]">
                Gerencie eventos, releases para imprensa e chamados de comunicação em um só lugar.
            </p>

            <!-- Ícone central decorativo -->
            <div class="mt-14 relative w-48 h-36 opacity-20 select-none pointer-events-none">
                <svg viewBox="0 0 192 144" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
                    <path d="M4 120 A92 92 0 0 0 188 120" stroke="white" stroke-width="3" stroke-linecap="round" opacity="0.4"/>
                    <path d="M26 120 A70 70 0 0 0 166 120" stroke="white" stroke-width="3.5" stroke-linecap="round" opacity="0.6"/>
                    <path d="M50 120 A46 46 0 0 0 142 120" stroke="white" stroke-width="4" stroke-linecap="round" opacity="0.8"/>
                    <path d="M74 120 A22 22 0 0 0 118 120" stroke="white" stroke-width="5" stroke-linecap="round"/>
                    <circle cx="96" cy="120" r="7" fill="white"/>
                </svg>
            </div>
        </div>

        <!-- Features -->
        <div class="relative z-10 space-y-3 mb-10">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                </div>
                <span class="text-slate-300 text-sm">Agenda e kanban de eventos</span>
            </div>
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM15 4v4h4"></path></svg>
                </div>
                <span class="text-slate-300 text-sm">Releases para a imprensa</span>
            </div>
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-white/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <span class="text-slate-300 text-sm">Chamados entre secretarias</span>
            </div>
        </div>

        <p class="relative z-10 text-slate-600 text-xs border-t border-slate-800 pt-4">
            Secretaria de Comunicação Municipal
        </p>
    </div>

    <!-- Painel direito — Formulário -->
    <div class="flex-1 flex flex-col items-center justify-center bg-white px-8 py-12">

        <!-- Logo mobile (só aparece em telas pequenas) -->
        <div class="lg:hidden flex items-center gap-3 mb-12">
            <img src="/icon.svg" alt="Comunica" class="w-9 h-9">
            <span class="text-slate-900 font-bold text-lg tracking-tight">Comunica</span>
        </div>

        <div class="w-full max-w-[340px]">

            <!-- Cabeçalho do form -->
            <div class="mb-8">
                <h2 class="text-2xl font-bold text-gray-900 tracking-tight">Entrar na conta</h2>
                <p class="text-gray-400 text-sm mt-1.5">Acesso restrito a colaboradores autorizados.</p>
            </div>

            <!-- Erro de login -->
            <% if(error) { %>
            <div class="mb-6 px-4 py-3 bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl flex items-center gap-2.5">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <%= error %>
            </div>
            <% } %>

            <form action="/login" method="POST" class="space-y-4">

                <div>
                    <label for="email" class="text-[11px] font-bold text-gray-400 uppercase tracking-widest block mb-1.5">E-mail</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        autocomplete="email"
                        placeholder="voce@prefeitura.gov.br"
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent focus:bg-white transition">
                </div>

                <div>
                    <label for="senha" class="text-[11px] font-bold text-gray-400 uppercase tracking-widest block mb-1.5">Senha</label>
                    <input
                        type="password"
                        id="senha"
                        name="senha"
                        required
                        autocomplete="current-password"
                        placeholder="••••••••"
                        class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-transparent focus:bg-white transition">
                </div>

                <div class="pt-1">
                    <button type="submit"
                        class="w-full py-3 bg-slate-900 hover:bg-slate-800 active:bg-slate-950 text-white font-semibold rounded-xl transition text-sm tracking-wide flex items-center justify-center gap-2">
                        Acessar
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </div>

            </form>

            <p class="text-center text-xs text-gray-300 mt-10 leading-relaxed">
                Problemas com o acesso?<br>Entre em contato com o administrador do sistema.
            </p>
        </div>
    </div>

</div>
