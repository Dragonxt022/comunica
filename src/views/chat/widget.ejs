<%#
  Chat widget — rendered inside main.ejs layout (requires Alpine.js + ComunicaChat + EventSource já inicializado)
  Floats bottom-right on every page, shows unread badge, opens full panel.
%>

<!-- ══ Chat widget CSS ══════════════════════════════════════════════════ -->
<style>
  #chat-widget * { box-sizing: border-box; }
  #chat-panel {
    transition: transform .25s cubic-bezier(.4,0,.2,1), opacity .2s;
    transform-origin: bottom right;
  }
  #chat-panel.hidden-panel {
    transform: scale(.92) translateY(16px);
    opacity: 0;
    pointer-events: none;
  }
  .chat-msg-in  { border-radius: 4px 18px 18px 18px; }
  .chat-msg-out { border-radius: 18px 4px 18px 18px; }
  .chat-scroll { scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent; }
  .chat-scroll::-webkit-scrollbar { width: 4px; }
  .chat-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
  .emoji-grid { display: grid; grid-template-columns: repeat(8,1fr); gap: 2px; }
  .emoji-grid span { cursor: pointer; font-size: 1.4rem; text-align: center; padding: 2px; border-radius: 4px; }
  .emoji-grid span:hover { background: #e2e8f0; }
  @keyframes chatPop { from { transform: scale(.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .chat-pop { animation: chatPop .15s ease; }
  @keyframes audioPulse { 0%,100% { transform: scaleY(1); } 50% { transform: scaleY(1.8); } }
  .audio-bar { width: 3px; background: #3b82f6; border-radius: 2px; height: 12px; display: inline-block; }
  .audio-bar:nth-child(1) { animation: audioPulse .6s .0s infinite; }
  .audio-bar:nth-child(2) { animation: audioPulse .6s .1s infinite; }
  .audio-bar:nth-child(3) { animation: audioPulse .6s .2s infinite; }
  .audio-bar:nth-child(4) { animation: audioPulse .6s .15s infinite; }
</style>

<!-- ══ Alpine data definition ══════════════════════════════════════════ -->
<div id="chat-widget"
     x-data="chatWidget()"
     x-init="init()"
     @chat-msg.window="handleSSEMsg($event.detail)"
     @chat-conversa.window="handleSSEConversa($event.detail)"
     class="fixed bottom-6 right-6 z-[9800] flex flex-col items-end gap-3 select-none">

  <!-- Floating button — pill shape -->
  <button @click="togglePanel()"
          class="relative flex items-center gap-2 px-4 h-12 rounded-2xl bg-blue-600 hover:bg-blue-700 active:scale-95 transition-all shadow-xl text-white"
          title="Chat">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 15c0 1.1-.9 2-2 2h-5l-5 5v-5H5a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10z"/>
    </svg>
    <span class="text-sm font-semibold">Chat</span>
    <!-- unread badge -->
    <span x-show="unreadTotal > 0" x-cloak
          class="min-w-[18px] h-[18px] px-1 bg-red-500 rounded-full text-[10px] font-bold flex items-center justify-center chat-pop ml-0.5"
          x-text="unreadTotal > 99 ? '99+' : unreadTotal"></span>
  </button>

  <!-- Main panel — taller and wider for a more rectangular look -->
  <div id="chat-panel"
       :class="panelOpen ? '' : 'hidden-panel'"
       class="bg-white rounded-2xl shadow-2xl border border-gray-100 flex flex-col overflow-hidden"
       style="position:absolute;bottom:60px;right:0;width:430px;height:680px;max-height:80vh">

    <!-- ── Header ── -->
    <div class="flex items-center gap-2 px-4 py-3 bg-blue-600 text-white flex-shrink-0">
      <!-- back button (inside conversa) -->
      <button x-show="activeConversa" @click="fecharConversa()" class="mr-1 hover:bg-blue-700 p-1 rounded-lg transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <div class="flex-1 min-w-0">
        <span x-show="!activeConversa" class="font-semibold text-[15px]">Mensagens</span>
        <span x-show="activeConversa" class="font-semibold text-[15px] truncate block" x-text="activeConversa?.nome"></span>
        <!-- encryption indicator -->
        <span x-show="activeConversa?.tipo === 'dm'" class="text-[10px] text-blue-200 flex items-center gap-1">
          🔒 Criptografia de ponta a ponta
        </span>
        <span x-show="activeConversa?.tipo === 'grupo'" class="text-[10px] text-blue-200 flex items-center gap-1">
          👥 Conversa de grupo
        </span>
      </div>
      <!-- new DM / new group buttons -->
      <div x-show="!activeConversa" class="flex items-center gap-1">
        <button @click="abrirBuscaUsuarios('dm')"
                title="Nova conversa"
                class="w-7 h-7 hover:bg-blue-700 rounded-lg transition flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        </button>
        <button @click="abrirBuscaUsuarios('grupo')"
                title="Novo grupo"
                class="w-7 h-7 hover:bg-blue-700 rounded-lg transition flex items-center justify-center">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </button>
      </div>
      <button @click="panelOpen = false" class="w-7 h-7 hover:bg-blue-700 rounded-lg transition flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- ── Conversa list ── -->
    <div x-show="!activeConversa && !buscandoUsuarios" class="flex-1 overflow-y-auto chat-scroll">
      <!-- search filter -->
      <div class="px-3 pt-2 pb-1">
        <input x-model="filtroConversa" type="text" placeholder="Pesquisar…"
               class="w-full text-sm border border-gray-200 rounded-xl px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-400">
      </div>
      <template x-if="conversas.length === 0 && !carregando">
        <div class="flex flex-col items-center justify-center py-12 text-gray-400 gap-2">
          <svg class="w-10 h-10 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M21 15c0 1.1-.9 2-2 2h-5l-5 5v-5H5a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10z"/></svg>
          <span class="text-sm">Nenhuma conversa ainda</span>
          <span class="text-xs">Clique em + para iniciar</span>
        </div>
      </template>
      <div x-show="carregando" class="flex justify-center py-8">
        <svg class="animate-spin w-6 h-6 text-blue-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
      </div>
      <template x-for="c in conversasFiltradas" :key="c.id">
        <div @click="abrirConversa(c)"
             class="flex items-center gap-3 px-3 py-2.5 hover:bg-gray-50 cursor-pointer transition border-b border-gray-50">
          <!-- avatar -->
          <div class="relative flex-shrink-0">
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-base font-bold overflow-hidden">
              <template x-if="c.avatar"><img :src="c.avatar" class="w-full h-full object-cover"></template>
              <template x-if="!c.avatar"><span x-text="c.nome?.charAt(0)?.toUpperCase()"></span></template>
            </div>
            <span x-show="c.tipo === 'grupo'" class="absolute -bottom-0.5 -right-0.5 text-[10px]">👥</span>
          </div>
          <!-- info -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold text-gray-900 truncate" x-text="c.nome"></span>
              <span class="text-[10px] text-gray-400 ml-1 flex-shrink-0" x-text="formatTime(c.updatedAt)"></span>
            </div>
            <div class="text-xs text-gray-500 truncate mt-0.5" x-text="previewUltimaMsg(c)"></div>
          </div>
          <!-- unread badge -->
          <span x-show="c.nao_lidas > 0"
                class="min-w-[18px] h-[18px] px-1 bg-blue-600 rounded-full text-[10px] font-bold text-white flex items-center justify-center flex-shrink-0"
                x-text="c.nao_lidas > 99 ? '99+' : c.nao_lidas"></span>
        </div>
      </template>
    </div>

    <!-- ── Busca de usuários (novo DM / grupo) ── -->
    <div x-show="buscandoUsuarios" class="flex flex-col flex-1 overflow-hidden">
      <div class="px-3 pt-3 pb-2 border-b border-gray-100">
        <div class="flex items-center gap-2 mb-2">
          <button @click="buscandoUsuarios=false;grupoNome='';grupoSelecionados=[]" class="text-gray-400 hover:text-gray-600">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <span class="font-semibold text-sm text-gray-700" x-text="modoBusca==='grupo' ? 'Novo grupo' : 'Nova mensagem'"></span>
        </div>
        <template x-if="modoBusca === 'grupo'">
          <input x-model="grupoNome" type="text" placeholder="Nome do grupo…"
                 class="w-full text-sm border border-gray-200 rounded-xl px-3 py-1.5 mb-2 focus:outline-none focus:ring-2 focus:ring-blue-400">
        </template>
        <input x-model="filtroBusca" type="text" placeholder="Pesquisar pessoas…"
               class="w-full text-sm border border-gray-200 rounded-xl px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-400">
        <!-- selected for group -->
        <template x-if="modoBusca === 'grupo' && grupoSelecionados.length > 0">
          <div class="flex flex-wrap gap-1 mt-2">
            <template x-for="uid in grupoSelecionados" :key="uid">
              <span class="flex items-center gap-1 bg-blue-100 text-blue-700 text-xs rounded-full px-2 py-0.5">
                <span x-text="usuarioNome(uid)"></span>
                <button @click="grupoSelecionados=grupoSelecionados.filter(i=>i!==uid)" class="font-bold">×</button>
              </span>
            </template>
          </div>
        </template>
      </div>
      <div class="flex-1 overflow-y-auto chat-scroll">
        <template x-for="u in usuariosFiltrados" :key="u.id">
          <div @click="selecionarUsuario(u)"
               :class="grupoSelecionados.includes(u.id) ? 'bg-blue-50' : 'hover:bg-gray-50'"
               class="flex items-center gap-3 px-3 py-2.5 cursor-pointer transition border-b border-gray-50">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-400 to-indigo-500 flex items-center justify-center text-white text-sm font-bold overflow-hidden flex-shrink-0">
              <template x-if="u.avatar"><img :src="u.avatar" class="w-full h-full object-cover"></template>
              <template x-if="!u.avatar"><span x-text="u.nome?.charAt(0)?.toUpperCase()"></span></template>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-gray-900 truncate" x-text="u.nome"></div>
              <div class="text-xs text-gray-400 truncate" x-text="u.secretaria?.nome || u.role"></div>
            </div>
            <template x-if="modoBusca === 'grupo'">
              <div :class="grupoSelecionados.includes(u.id) ? 'bg-blue-600 border-blue-600' : 'border-gray-300'"
                   class="w-5 h-5 rounded-full border-2 flex items-center justify-center flex-shrink-0">
                <svg x-show="grupoSelecionados.includes(u.id)" class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
            </template>
          </div>
        </template>
      </div>
      <template x-if="modoBusca === 'grupo' && grupoSelecionados.length > 0">
        <div class="p-3 border-t border-gray-100">
          <button @click="criarGrupo()"
                  class="w-full py-2 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition">
            Criar grupo (<span x-text="grupoSelecionados.length"></span> pessoas)
          </button>
        </div>
      </template>
    </div>

    <!-- ── Mensagens ── -->
    <div x-show="activeConversa" class="flex flex-col flex-1 overflow-hidden">
      <!-- messages list -->
      <div id="chat-msgs-list"
           class="flex-1 overflow-y-auto chat-scroll px-3 py-2 flex flex-col gap-1"
           @scroll="onScroll($event)">
        <!-- load more -->
        <div x-show="hasMore" class="flex justify-center py-1">
          <button @click="carregarMaisAntigas()" class="text-xs text-blue-500 hover:underline">Carregar anteriores</button>
        </div>
        <div x-show="carregandoMsgs" class="flex justify-center py-2">
          <svg class="animate-spin w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
        </div>
        <template x-for="(msg, idx) in mensagens" :key="msg.id">
          <div :class="msg.user_id === myUserId ? 'items-end' : 'items-start'" class="flex flex-col gap-0.5">
            <!-- sender name (not own, not DM) -->
            <template x-if="msg.user_id !== myUserId && activeConversa?.tipo === 'grupo' && (idx === 0 || mensagens[idx-1]?.user_id !== msg.user_id)">
              <span class="text-[10px] text-gray-500 px-1" x-text="msg.remetente?.nome"></span>
            </template>
            <div class="max-w-[80%] group relative">
              <template x-if="msg.excluido">
                <div :class="msg.user_id === myUserId ? 'bg-gray-200 chat-msg-out' : 'bg-gray-100 chat-msg-in'"
                     class="px-3 py-1.5 text-xs text-gray-400 italic">Mensagem excluída</div>
              </template>
              <template x-if="!msg.excluido">
                <div>
                  <!-- text -->
                  <template x-if="msg.tipo === 'texto'">
                    <div :class="msg.user_id === myUserId ? 'bg-blue-600 text-white chat-msg-out' : 'bg-gray-100 text-gray-900 chat-msg-in'"
                         class="px-3 py-2 text-sm leading-snug break-words whitespace-pre-wrap"
                         x-text="msg._texto || '🔒 …'"></div>
                  </template>
                  <!-- image -->
                  <template x-if="msg.tipo === 'imagem'">
                    <div :class="msg.user_id === myUserId ? 'chat-msg-out' : 'chat-msg-in'" class="overflow-hidden max-w-[240px]">
                      <img :src="msg.arquivo_url" class="rounded-xl object-cover max-h-48 w-full cursor-pointer"
                           @click="window.open(msg.arquivo_url,'_blank')" loading="lazy">
                    </div>
                  </template>
                  <!-- audio -->
                  <template x-if="msg.tipo === 'audio'">
                    <div :class="msg.user_id === myUserId ? 'bg-blue-600 text-white chat-msg-out' : 'bg-gray-100 chat-msg-in'"
                         class="px-3 py-2">
                      <audio controls class="h-8" style="max-width:200px"><source :src="msg.arquivo_url"></audio>
                    </div>
                  </template>
                  <!-- file -->
                  <template x-if="msg.tipo === 'arquivo'">
                    <a :href="msg.arquivo_url" target="_blank"
                       :class="msg.user_id === myUserId ? 'bg-blue-600 text-white chat-msg-out' : 'bg-gray-100 text-gray-900 chat-msg-in'"
                       class="flex items-center gap-2 px-3 py-2 text-sm no-underline">
                      📎 <span x-text="msg.arquivo_nome" class="truncate max-w-[140px]"></span>
                    </a>
                  </template>
                </div>
              </template>
              <!-- delete own -->
              <template x-if="msg.user_id === myUserId && !msg.excluido">
                <button @click="excluirMensagem(msg)"
                        class="absolute -top-1 -left-6 opacity-0 group-hover:opacity-100 transition w-5 h-5 text-gray-400 hover:text-red-500 flex items-center justify-center text-xs">✕</button>
              </template>
            </div>
            <span :class="msg.user_id === myUserId ? 'text-right' : 'text-left'"
                  class="text-[9px] text-gray-400 px-1" x-text="formatTime(msg.createdAt)"></span>
          </div>
        </template>
        <div id="chat-bottom-anchor"></div>
      </div>

      <!-- emoji picker -->
      <div x-show="showEmoji" x-cloak
           class="absolute bottom-[110px] right-3 bg-white border border-gray-200 rounded-xl shadow-xl p-2 z-[9900] w-[280px]">
        <div class="flex gap-1 mb-1 text-xs text-gray-500">
          <button class="hover:bg-gray-100 px-1 rounded" @click="emojiTab='smileys'" :class="emojiTab==='smileys'?'bg-gray-100':''">😀</button>
          <button class="hover:bg-gray-100 px-1 rounded" @click="emojiTab='nature'" :class="emojiTab==='nature'?'bg-gray-100':''">🐶</button>
          <button class="hover:bg-gray-100 px-1 rounded" @click="emojiTab='food'" :class="emojiTab==='food'?'bg-gray-100':''">🍕</button>
          <button class="hover:bg-gray-100 px-1 rounded" @click="emojiTab='activity'" :class="emojiTab==='activity'?'bg-gray-100':''">⚽</button>
          <button class="hover:bg-gray-100 px-1 rounded" @click="emojiTab='symbols'" :class="emojiTab==='symbols'?'bg-gray-100':''">❤️</button>
        </div>
        <div class="emoji-grid max-h-[140px] overflow-y-auto chat-scroll">
          <template x-for="e in EMOJIS[emojiTab]" :key="e">
            <span @click="inserirEmoji(e)" x-text="e"></span>
          </template>
        </div>
      </div>

      <!-- input area -->
      <div class="flex-shrink-0 border-t border-gray-100 px-2 py-2 flex flex-col gap-1.5">
        <!-- media previews -->
        <template x-if="mediaPreview">
          <div class="flex items-center gap-2 bg-blue-50 rounded-xl px-3 py-1.5 text-xs text-blue-700">
            <template x-if="mediaPreview.tipo === 'imagem'">
              <img :src="mediaPreview.src" class="h-8 w-8 object-cover rounded">
            </template>
            <template x-if="mediaPreview.tipo === 'audio'">
              <span>🎤 Áudio gravado</span>
            </template>
            <span x-text="mediaPreview.nome" class="flex-1 truncate"></span>
            <button @click="cancelarMedia()" class="font-bold text-blue-400 hover:text-red-500">✕</button>
          </div>
        </template>

        <!-- audio recording bar -->
        <template x-if="gravando">
          <div class="flex items-center gap-3 bg-red-50 rounded-xl px-3 py-1.5">
            <div class="flex items-end gap-[3px] h-5">
              <span class="audio-bar"></span>
              <span class="audio-bar"></span>
              <span class="audio-bar"></span>
              <span class="audio-bar"></span>
            </div>
            <span class="text-xs text-red-600 font-medium flex-1" x-text="formatGravacaoTempo()"></span>
            <button @click="cancelarGravacao()" class="text-xs text-gray-400 hover:text-red-600 px-2">Cancelar</button>
            <button @click="pararGravacao()" class="text-xs bg-red-500 text-white px-3 py-1 rounded-lg font-medium hover:bg-red-600 transition">Enviar</button>
          </div>
        </template>

        <div class="flex items-end gap-1.5">
          <!-- emoji btn -->
          <button @click="showEmoji=!showEmoji" class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-blue-500 transition text-lg flex-shrink-0 mb-0.5">😊</button>
          <!-- text input -->
          <textarea x-model="inputText"
                    @keydown.enter.exact.prevent="enviarTexto()"
                    @keydown.enter.shift.prevent="inputText+='\n'"
                    @input="autoResize($event)"
                    placeholder="Mensagem…"
                    rows="1"
                    class="flex-1 text-sm border border-gray-200 rounded-xl px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none overflow-hidden leading-snug max-h-24"></textarea>
          <!-- image attach -->
          <label class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-blue-500 transition cursor-pointer flex-shrink-0 mb-0.5" title="Anexar imagem">
            <input type="file" accept="image/*" class="hidden" @change="onFileSelect($event)">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </label>
          <!-- audio record -->
          <button @click="alternarGravacao()" title="Gravar áudio"
                  :class="gravando ? 'text-red-500' : 'text-gray-400 hover:text-blue-500'"
                  class="w-8 h-8 flex items-center justify-center transition flex-shrink-0 mb-0.5">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          </button>
          <!-- send -->
          <button @click="enviar()"
                  :disabled="enviando"
                  class="w-8 h-8 rounded-full bg-blue-600 hover:bg-blue-700 disabled:opacity-50 transition flex items-center justify-center text-white flex-shrink-0 mb-0.5 active:scale-95">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </button>
        </div>
      </div>
    </div>

  </div><!-- /panel -->
</div><!-- /widget -->

<!-- ══ Alpine component ════════════════════════════════════════════════ -->
<script>
const MY_USER_ID = <%= user.id %>;

const EMOJIS = {
  smileys:  ['😀','😃','😄','😁','😆','😅','🤣','😂','🙂','🙃','😉','😊','😇','🥰','😍','🤩','😘','😗','😚','😙','😋','😛','😜','🤪','😝','🤑','🤗','🤭','🤫','🤔','🤐','🤨','😐','😑','😶','😏','😒','🙄','😬','🤥','😌','😔','😪','🤤','😴','😷','🤒','🤕','🤢','🤮','🤧','🥵','🥶','😵','🤯','🤠','🥳','😎','🤓','🧐','😕','😟','🙁','☹️','😮','😯','😲','😳','🥺','😦','😧','😨','😰','😥','😢','😭','😱','😖','😣','😞','😓','😩','😫','🥱','😤','😡','😠','🤬','😈','👿'],
  nature:   ['🐶','🐱','🐭','🐹','🐰','🦊','🐻','🐼','🐨','🐯','🦁','🐮','🐷','🐸','🐵','🙈','🙉','🙊','🐔','🐧','🐦','🦆','🦅','🦉','🦇','🐺','🦮','🐗','🐴','🦄','🐝','🐛','🦋','🐌','🐞','🐜','🦟','🦗','🕷','🦂','🐢','🦎','🐍','🦕','🦖','🦔','🐾','🐉','🌿','🍃','🌱','🌲','🌳','🌴','🌵','🎄','🌾','🍀','🌺','🌸','🌼','🌻','🌞','🌝','🌛','🌜','🌚','🌕','🌙','🌟','⭐','🌈','☁️','⛅','🌤','🌈','🌊','💧','❄️','🌪','🌩','⛈','🔥'],
  food:     ['🍕','🍔','🌮','🌯','🥗','🍝','🍜','🍛','🍣','🍱','🍤','🍙','🍚','🍘','🍥','🥮','🍢','🧁','🎂','🍰','🍮','🍭','🍬','🍫','🍿','🍩','🍪','🌰','🥜','🍯','🥐','🥖','🥨','🥯','🧀','🥚','🍳','🥞','🧇','🥓','🌭','🥪','🥙','🧆','🥚','🍿','🥤','🧃','☕','🍵','🍺','🍻','🥂','🍷','🥃','🍸','🍹','🍾','🧊'],
  activity: ['⚽','🏀','🏈','⚾','🥎','🏐','🏉','🎾','🥏','🎳','🏏','🏑','🏒','🥍','🏓','🏸','🥊','🎯','🎱','🏹','🎣','🤿','🥅','⛳','🏋','🤸','⛷','🏂','🪂','🏊','🤽','🚣','🧘','🏇','🏋','🤼','🤺','🥋','🎽','🛹','🛼','🛷','⛸','🤸','🤻','🤾','🤹','🎪','🥊','🥁','🎸','🎹','🎻','🎺','🎷','🪗','🎤','🎧','🎼'],
  symbols:  ['❤️','🧡','💛','💚','💙','💜','🖤','🤍','🤎','💕','💞','💓','💗','💖','💘','💝','💟','☮️','✝️','☯️','🙏','👍','👎','👊','✊','🤛','🤜','🤞','✌️','🤟','🤘','🤙','👈','👉','👆','👇','☝️','👋','🤚','✋','🖖','🖐','💪','🦾','🙌','👏','🙏','🫶','🤝','👌','🤌','🤏','🤞','🤟','🤘','👍','💯','✅','❌','⭕','🔴','🟡','🟢','🔵','🟣','⚫','⚪','🔺','🔻','💠','🔷','🔶','🔸','🔹','▶️','⏩','⏪','⏫','⏬','🔔','🔕','📢','📣'],
};

function chatWidget() {
  return {
    myUserId: MY_USER_ID,
    EMOJIS,
    panelOpen: false,
    carregando: false,
    conversas: [],
    filtroConversa: '',
    activeConversa: null,
    mensagens: [],
    carregandoMsgs: false,
    hasMore: false,
    inputText: '',
    enviando: false,
    showEmoji: false,
    emojiTab: 'smileys',
    unreadTotal: 0,
    buscandoUsuarios: false,
    modoBusca: 'dm',
    filtroBusca: '',
    grupoNome: '',
    grupoSelecionados: [],
    todosUsuarios: [],
    mediaPreview: null,
    mediaFile: null,
    gravando: false,
    mediaRecorder: null,
    audioChunks: [],
    gravacaoInicio: null,
    gravacaoTimer: null,

    get conversasFiltradas() {
      const q = this.filtroConversa.toLowerCase().trim();
      if (!q) return this.conversas;
      return this.conversas.filter(c => c.nome?.toLowerCase().includes(q));
    },
    get usuariosFiltrados() {
      const q = this.filtroBusca.toLowerCase().trim();
      if (!q) return this.todosUsuarios;
      return this.todosUsuarios.filter(u => u.nome?.toLowerCase().includes(q) || u.secretaria?.nome?.toLowerCase().includes(q));
    },

    async init() {
      // Kickoff E2E crypto engine
      if (window.ComunicaChat) await window.ComunicaChat.init();

      // Register SSE message handler
      if (window.ComunicaChat) {
        window.ComunicaChat._onMsg = (data) => window.dispatchEvent(new CustomEvent('chat-msg', { detail: data }));
        window.ComunicaChat._onConversa = (data) => window.dispatchEvent(new CustomEvent('chat-conversa', { detail: data }));
      }

      await this.carregarConversas();
      await this.atualizarUnread();
    },

    async carregarConversas() {
      this.carregando = true;
      try {
        const r = await fetch('/chat/conversas');
        const d = await r.json();
        this.conversas = d.conversas || [];
      } catch(e) {} finally { this.carregando = false; }
    },

    async atualizarUnread() {
      try {
        const r = await fetch('/chat/unread');
        const d = await r.json();
        this.unreadTotal = d.total || 0;
      } catch(e) {}
    },

    async togglePanel() {
      this.panelOpen = !this.panelOpen;
      if (this.panelOpen && !this.activeConversa) {
        await this.carregarConversas();
      }
    },

    async abrirConversa(c) {
      this.activeConversa = c;
      this.mensagens = [];
      this.hasMore = false;
      this.inputText = '';
      await this.carregarMensagens();
      this.$nextTick(() => this.scrollBottom());
      // mark read
      fetch('/chat/conversas/' + c.id + '/lida', { method: 'POST' }).catch(() => {});
      c.nao_lidas = 0;
      this.atualizarUnread();
    },

    fecharConversa() {
      this.activeConversa = null;
      this.mensagens = [];
      this.showEmoji = false;
      this.mediaPreview = null;
      this.mediaFile = null;
    },

    async carregarMensagens(cursor = null) {
      if (!this.activeConversa) return;
      this.carregandoMsgs = true;
      try {
        let url = '/chat/conversas/' + this.activeConversa.id + '/mensagens';
        if (cursor) url += '?cursor=' + encodeURIComponent(cursor);
        const r = await fetch(url);
        const d = await r.json();
        let msgs = d.mensagens || [];

        // Decrypt text messages
        if (window.ComunicaChat) {
          msgs = await window.ComunicaChat.decryptMensagens(msgs, this.activeConversa);
        }

        if (cursor) {
          this.mensagens = [...msgs, ...this.mensagens];
        } else {
          this.mensagens = msgs;
        }
        this.hasMore = d.hasMore || false;
      } catch(e) {} finally { this.carregandoMsgs = false; }
    },

    async carregarMaisAntigas() {
      if (!this.mensagens.length) return;
      const cursor = this.mensagens[0].createdAt;
      const topEl = document.getElementById('chat-msgs-list');
      const prevH = topEl ? topEl.scrollHeight : 0;
      await this.carregarMensagens(cursor);
      this.$nextTick(() => {
        if (topEl) topEl.scrollTop = topEl.scrollHeight - prevH;
      });
    },

    async enviar() {
      if (this.mediaFile) {
        await this.enviarArquivo();
      } else {
        await this.enviarTexto();
      }
    },

    async enviarTexto() {
      const txt = this.inputText.trim();
      if (!txt || !this.activeConversa || this.enviando) return;
      this.enviando = true;
      this.inputText = '';
      this.$nextTick(() => this.autoResizeReset());
      try {
        let payload = { tipo: 'texto', conteudo_enc: '', iv_hex: null };
        if (window.ComunicaChat) {
          const enc = await window.ComunicaChat.encryptTexto(txt, this.activeConversa);
          payload.conteudo_enc = enc.conteudo_enc;
          payload.iv_hex = enc.iv_hex;
        } else {
          payload.conteudo_enc = btoa(unescape(encodeURIComponent(txt)));
        }
        const r = await fetch('/chat/conversas/' + this.activeConversa.id + '/mensagens', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const d = await r.json();
        if (d.ok) {
          const msg = Object.assign({}, d.mensagem, { _texto: txt });
          this.mensagens.push(msg);
          this.$nextTick(() => this.scrollBottom());
        }
      } catch(e) {} finally { this.enviando = false; }
    },

    async enviarArquivo() {
      if (!this.mediaFile || !this.activeConversa || this.enviando) return;
      this.enviando = true;
      try {
        const uploadData = await window.ComunicaChat.uploadArquivo(this.mediaFile);
        const tipo = this.mediaFile.type.startsWith('image') ? 'imagem'
                   : this.mediaFile.type.startsWith('audio') ? 'audio' : 'arquivo';
        const r = await fetch('/chat/conversas/' + this.activeConversa.id + '/mensagens', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tipo,
            arquivo_url: uploadData.url,
            arquivo_nome: uploadData.nome,
            arquivo_tamanho: uploadData.tamanho,
            arquivo_mime: uploadData.mime,
          }),
        });
        const d = await r.json();
        if (d.ok) {
          this.mensagens.push(d.mensagem);
          this.$nextTick(() => this.scrollBottom());
        }
        this.cancelarMedia();
      } catch(e) { alert('Falha no upload'); } finally { this.enviando = false; }
    },

    onFileSelect(e) {
      const file = e.target.files[0];
      if (!file) return;
      this.mediaFile = file;
      const tipo = file.type.startsWith('image') ? 'imagem' : 'arquivo';
      if (tipo === 'imagem') {
        const reader = new FileReader();
        reader.onload = (ev) => { this.mediaPreview = { tipo: 'imagem', src: ev.target.result, nome: file.name }; };
        reader.readAsDataURL(file);
      } else {
        this.mediaPreview = { tipo: 'arquivo', nome: file.name };
      }
      e.target.value = '';
    },

    cancelarMedia() {
      this.mediaFile = null;
      this.mediaPreview = null;
    },

    // ── Audio recording ────────────────────────────────────────────────

    async alternarGravacao() {
      if (this.gravando) { this.pararGravacao(); return; }
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
        this.audioChunks = [];
        this.mediaRecorder = new MediaRecorder(stream, { mimeType: MediaRecorder.isTypeSupported('audio/webm;codecs=opus') ? 'audio/webm;codecs=opus' : 'audio/ogg' });
        this.mediaRecorder.ondataavailable = (e) => { if (e.data.size) this.audioChunks.push(e.data); };
        this.mediaRecorder.onstop = () => this.finalizarGravacao();
        this.mediaRecorder.start(200);
        this.gravando = true;
        this.gravacaoInicio = Date.now();
        this.gravacaoTimer = setInterval(() => this.$nextTick(() => {}), 1000);
      } catch(e) { alert('Microfone não disponível'); }
    },

    pararGravacao() {
      if (this.mediaRecorder) { this.mediaRecorder.stop(); this.mediaRecorder.stream?.getTracks().forEach(t => t.stop()); }
      this.gravando = false;
      clearInterval(this.gravacaoTimer);
    },

    cancelarGravacao() {
      this.audioChunks = [];
      this.pararGravacao();
    },

    finalizarGravacao() {
      if (!this.audioChunks.length) return;
      const mime = this.audioChunks[0].type || 'audio/webm';
      const blob = new Blob(this.audioChunks, { type: mime });
      const ext  = mime.includes('ogg') ? '.ogg' : '.webm';
      this.mediaFile = new File([blob], 'audio' + ext, { type: mime });
      this.mediaPreview = { tipo: 'audio', nome: 'Áudio gravado' };
      this.audioChunks = [];
    },

    formatGravacaoTempo() {
      if (!this.gravacaoInicio) return '00:00';
      const s = Math.floor((Date.now() - this.gravacaoInicio) / 1000);
      return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0');
    },

    // ── Emoji ──────────────────────────────────────────────────────────

    inserirEmoji(e) {
      this.inputText += e;
      this.showEmoji = false;
    },

    // ── User search / DM / Group ───────────────────────────────────────

    async abrirBuscaUsuarios(modo) {
      this.modoBusca = modo;
      this.buscandoUsuarios = true;
      this.filtroBusca = '';
      this.grupoNome = '';
      this.grupoSelecionados = [];
      if (!this.todosUsuarios.length) {
        const r = await fetch('/chat/usuarios');
        const d = await r.json();
        this.todosUsuarios = d.usuarios || [];
      }
    },

    async selecionarUsuario(u) {
      if (this.modoBusca === 'dm') {
        // Open or create DM
        const r = await fetch('/chat/conversas/dm', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: u.id }),
        });
        const d = await r.json();
        this.buscandoUsuarios = false;
        // Reload conversas and open the DM
        await this.carregarConversas();
        const conv = this.conversas.find(c => c.id === d.conversa_id);
        if (conv) await this.abrirConversa(conv);
      } else {
        // Group: toggle selection
        if (this.grupoSelecionados.includes(u.id)) {
          this.grupoSelecionados = this.grupoSelecionados.filter(i => i !== u.id);
        } else {
          this.grupoSelecionados.push(u.id);
        }
      }
    },

    async criarGrupo() {
      if (!this.grupoNome.trim() || !this.grupoSelecionados.length) return;
      const r = await fetch('/chat/conversas/grupo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome: this.grupoNome.trim(), participantes: this.grupoSelecionados }),
      });
      const d = await r.json();
      this.buscandoUsuarios = false;
      await this.carregarConversas();
      const conv = this.conversas.find(c => c.id === d.conversa_id);
      if (conv) await this.abrirConversa(conv);
    },

    usuarioNome(uid) {
      return this.todosUsuarios.find(u => u.id === uid)?.nome || uid;
    },

    async excluirMensagem(msg) {
      if (!confirm('Excluir esta mensagem?')) return;
      await fetch('/chat/mensagens/' + msg.id, { method: 'DELETE' });
      msg.excluido = true;
    },

    // ── SSE handlers ───────────────────────────────────────────────────

    async handleSSEMsg(data) {
      // Update unread badge
      if (data.type === 'excluida') {
        const m = this.mensagens.find(x => x.id === data.id);
        if (m) m.excluido = true;
        return;
      }

      // Decrypt if needed
      let msg = Object.assign({}, data);
      if (this.activeConversa && data.conversa_id === this.activeConversa.id) {
        if (msg.tipo === 'texto' && window.ComunicaChat) {
          msg._texto = await window.ComunicaChat.decryptTexto(msg, this.activeConversa);
        }
        this.mensagens.push(msg);
        this.$nextTick(() => this.scrollBottom());
        // mark read
        fetch('/chat/conversas/' + data.conversa_id + '/lida', { method: 'POST' }).catch(() => {});
      } else {
        // bump unread in list
        const conv = this.conversas.find(c => c.id === data.conversa_id);
        if (conv) {
          conv.nao_lidas = (conv.nao_lidas || 0) + 1;
          conv.ultima_msg = data;
          conv.updatedAt = data.createdAt;
          // move to top
          this.conversas = [conv, ...this.conversas.filter(c => c.id !== conv.id)];
        } else {
          // unknown conv — reload list
          await this.carregarConversas();
        }
        this.unreadTotal = (this.unreadTotal || 0) + 1;
      }
    },

    async handleSSEConversa(data) {
      // New conversation notification
      await this.carregarConversas();
      this.unreadTotal = (this.unreadTotal || 0) + 1;
    },

    // ── Helpers ────────────────────────────────────────────────────────

    previewUltimaMsg(c) {
      if (!c.ultima_msg) return 'Nenhuma mensagem';
      if (window.ComunicaChat) return window.ComunicaChat.previewMsg(c.ultima_msg, c.tipo);
      const m = c.ultima_msg;
      if (m.tipo === 'imagem') return '📷 Imagem';
      if (m.tipo === 'audio')  return '🎤 Áudio';
      if (m.tipo === 'arquivo') return '📎 Arquivo';
      return '💬 …';
    },

    formatTime(dateStr) {
      if (!dateStr) return '';
      const d = new Date(dateStr);
      const now = new Date();
      const diffH = (now - d) / 3600000;
      if (diffH < 24 && now.getDate() === d.getDate()) {
        return d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
      }
      if (diffH < 48) return 'ontem';
      return d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
    },

    scrollBottom() {
      const el = document.getElementById('chat-bottom-anchor');
      if (el) el.scrollIntoView({ behavior: 'smooth' });
    },

    onScroll(e) {
      // close emoji on scroll
      if (this.showEmoji) this.showEmoji = false;
    },

    autoResize(e) {
      const el = e.target;
      el.style.height = 'auto';
      el.style.height = Math.min(el.scrollHeight, 96) + 'px';
    },

    autoResizeReset() {
      const el = this.$el.querySelector('textarea');
      if (el) { el.style.height = 'auto'; }
    },
  };
}
</script>
