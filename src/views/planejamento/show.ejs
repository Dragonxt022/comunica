<%
const acoes = plano.acoes || [];
const indicadores = plano.indicadores || [];
const totalAcoes = acoes.length;
const concluidas = acoes.filter(function(a) { return a.status === 'concluido'; }).length;
const emAndamento = acoes.filter(function(a) { return a.status === 'em_andamento'; }).length;
const naoIniciadas = acoes.filter(function(a) { return a.status === 'nao_iniciado'; }).length;
const canceladas = acoes.filter(function(a) { return a.status === 'cancelado'; }).length;
const pct = totalAcoes > 0 ? Math.round((concluidas / totalAcoes) * 100) : 0;
const dtInicio = new Date(plano.periodo_inicio + 'T00:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
const dtFim = new Date(plano.periodo_fim + 'T00:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
const statusCorPlano = { ativo: 'bg-emerald-100 text-emerald-700', concluido: 'bg-blue-100 text-blue-700', suspenso: 'bg-amber-100 text-amber-700' };
const statusLabelPlano = { ativo: 'Ativo', concluido: 'Concluído', suspenso: 'Suspenso' };
const priorCores = { alta: 'bg-red-100 text-red-700', media: 'bg-amber-100 text-amber-700', baixa: 'bg-green-100 text-green-700' };
const priorLabels = { alta: 'Alta', media: 'Média', baixa: 'Baixa' };
const statusAcaoCores = {
  nao_iniciado: 'bg-gray-100 text-gray-600',
  em_andamento: 'bg-blue-100 text-blue-700',
  concluido: 'bg-emerald-100 text-emerald-700',
  cancelado: 'bg-red-100 text-red-600'
};
const statusAcaoLabels = {
  nao_iniciado: 'Não iniciado',
  em_andamento: 'Em andamento',
  concluido: 'Concluído',
  cancelado: 'Cancelado'
};
%>

<div x-data="planShow()">
<div class="space-y-6">

    <!-- Header do Plano -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="flex items-start gap-3 min-w-0">
                <a href="/planejamento" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition shrink-0 mt-0.5">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <div class="min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                        <h1 class="text-lg font-bold text-gray-900"><%= plano.titulo %></h1>
                        <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full <%= statusCorPlano[plano.status] || 'bg-gray-100 text-gray-600' %>">
                            <%= statusLabelPlano[plano.status] || plano.status %>
                        </span>
                    </div>
                    <div class="flex items-center gap-3 mt-1 flex-wrap">
                        <% if (plano.secretaria) { %>
                        <span class="flex items-center gap-1.5 text-xs text-gray-500">
                            <span class="w-2 h-2 rounded-full" style="background:<%= plano.secretaria.cor || '#6366f1' %>"></span>
                            <%= plano.secretaria.nome %>
                        </span>
                        <% } %>
                        <span class="text-xs text-gray-400"><%= dtInicio %> → <%= dtFim %></span>
                    </div>
                    <% if (plano.descricao) { %>
                    <p class="text-sm text-gray-500 mt-2 leading-relaxed"><%= plano.descricao %></p>
                    <% } %>
                </div>
            </div>
            <div class="flex items-center gap-2 shrink-0 flex-wrap">
                <a href="/planejamento/<%= plano.id %>/imprimir" target="_blank"
                   class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                    </svg>
                    Exportar PDF
                </a>
                <a href="/planejamento/<%= plano.id %>/editar"
                   class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Editar
                </a>
                <% if (user && (user.role === 'admin' || user.role === 'secom')) { %>
                <button @click="excluirPlano()"
                    class="inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-red-600 border border-red-200 rounded-lg hover:bg-red-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Excluir
                </button>
                <% } %>
            </div>
        </div>

        <!-- Progresso geral -->
        <div class="mt-5 pt-5 border-t border-gray-100">
            <div class="flex items-center justify-between text-sm mb-2">
                <span class="font-medium text-gray-700">Progresso geral</span>
                <span class="font-bold text-indigo-600"><%= pct %>%</span>
            </div>
            <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-indigo-500 rounded-full transition-all" style="width:<%= pct %>%"></div>
            </div>
            <div class="flex gap-4 mt-3 flex-wrap">
                <span class="text-xs text-gray-500"><span class="font-semibold text-gray-700"><%= concluidas %></span> concluída<%= concluidas !== 1 ? 's' : '' %></span>
                <span class="text-xs text-gray-500"><span class="font-semibold text-blue-600"><%= emAndamento %></span> em andamento</span>
                <span class="text-xs text-gray-500"><span class="font-semibold text-gray-500"><%= naoIniciadas %></span> não iniciada<%= naoIniciadas !== 1 ? 's' : '' %></span>
                <% if (canceladas > 0) { %>
                <span class="text-xs text-gray-500"><span class="font-semibold text-red-500"><%= canceladas %></span> cancelada<%= canceladas !== 1 ? 's' : '' %></span>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Indicadores / KPIs -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-bold text-gray-900">Indicadores e Metas</h2>
            <button @click="abrirModalIndicador(null)"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-indigo-700 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                </svg>
                Adicionar Meta
            </button>
        </div>

        <% if (indicadores.length === 0) { %>
        <p class="text-sm text-gray-400 text-center py-6">Nenhum indicador cadastrado ainda.</p>
        <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
            <% indicadores.forEach(function(ind) {
                const pctInd = ind.valor_meta > 0 ? Math.min(Math.round((ind.valor_atual / ind.valor_meta) * 100), 100) : 0;
                const pctColor = pctInd >= 100 ? 'bg-emerald-500' : pctInd >= 60 ? 'bg-blue-500' : pctInd >= 30 ? 'bg-amber-500' : 'bg-red-400';
            %>
            <div class="border border-gray-100 rounded-xl p-4 space-y-2.5">
                <div class="flex items-start justify-between gap-2">
                    <span class="text-sm font-semibold text-gray-800 leading-snug"><%= ind.indicador %></span>
                    <div class="flex gap-1 shrink-0">
                        <button @click="abrirModalIndicador(<%= JSON.stringify(ind).replace(/</g, '\\u003c') %>)"
                            class="p-1 text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-md transition" title="Editar">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                            </svg>
                        </button>
                        <form action="/planejamento/<%= plano.id %>/indicadores/<%= ind.id %>/excluir" method="POST" onsubmit="return confirm('Excluir este indicador?')">
                            <button type="submit" class="p-1 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-md transition" title="Excluir">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
                <% if (ind.descricao) { %>
                <p class="text-xs text-gray-400 leading-snug"><%= ind.descricao %></p>
                <% } %>
                <div class="flex items-end gap-1">
                    <span class="text-2xl font-bold text-gray-900"><%= ind.valor_atual %></span>
                    <span class="text-sm text-gray-400 mb-0.5">/ <%= ind.valor_meta %> <%= ind.unidade %></span>
                </div>
                <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full <%= pctColor %> rounded-full transition-all" style="width:<%= pctInd %>%"></div>
                </div>
                <p class="text-xs text-right text-gray-400 font-medium"><%= pctInd %>% da meta</p>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>

    <!-- Ações — Tabs Lista / Timeline -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
            <div class="flex items-center gap-1 bg-gray-100 rounded-lg p-1">
                <button @click="tab = 'lista'"
                    :class="tab === 'lista' ? 'bg-white shadow text-indigo-700 font-semibold' : 'text-gray-500 hover:text-gray-700'"
                    class="px-3 py-1.5 text-xs rounded-md transition">
                    Lista
                </button>
                <button @click="tab = 'gantt'"
                    :class="tab === 'gantt' ? 'bg-white shadow text-indigo-700 font-semibold' : 'text-gray-500 hover:text-gray-700'"
                    class="px-3 py-1.5 text-xs rounded-md transition">
                    Timeline
                </button>
            </div>
            <button @click="abrirModalAcao(null)"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold text-indigo-700 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                </svg>
                Nova Ação
            </button>
        </div>

        <!-- Tab: Lista -->
        <div x-show="tab === 'lista'" x-cloak>
        <% if (acoes.length === 0) { %>
        <div class="text-center py-10">
            <svg class="w-10 h-10 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 8h6m-6 4h4"/>
            </svg>
            <p class="text-sm text-gray-400">Nenhuma ação cadastrada. Clique em "Nova Ação" para começar.</p>
        </div>
        <% } else { %>
        <div class="space-y-3">
            <% acoes.forEach(function(acao) {
                const corPrior = priorCores[acao.prioridade] || 'bg-gray-100 text-gray-600';
                const labelPrior = priorLabels[acao.prioridade] || acao.prioridade;
                const corStatus = statusAcaoCores[acao.status] || 'bg-gray-100 text-gray-600';
                const labelStatus = statusAcaoLabels[acao.status] || acao.status;
                const eventoVinculado = acao.evento_id && eventosMap[acao.evento_id];
                const hoje = new Date(); hoje.setHours(0,0,0,0);
                const prazoDate = acao.prazo ? new Date(acao.prazo + 'T00:00:00') : null;
                const vencida = prazoDate && prazoDate < hoje && acao.status !== 'concluido' && acao.status !== 'cancelado';
                const prazoFmt = prazoDate ? prazoDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) : null;
            %>
            <div class="flex items-start gap-3 p-4 border border-gray-100 rounded-xl hover:border-indigo-200 hover:bg-indigo-50/30 transition group"
                 x-data="{ expanded: false }">
                <!-- Status toggle rápido -->
                <button type="button"
                    @click="toggleStatusAcao(<%= acao.id %>, '<%= acao.status %>')"
                    class="shrink-0 mt-0.5 w-5 h-5 rounded-full border-2 flex items-center justify-center transition
                        <%= acao.status === 'concluido' ? 'bg-emerald-500 border-emerald-500 text-white' : 'border-gray-300 hover:border-emerald-400' %>"
                    title="Marcar como concluído">
                    <% if (acao.status === 'concluido') { %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                    <% } %>
                </button>

                <div class="flex-1 min-w-0">
                    <div class="flex items-start gap-2 flex-wrap">
                        <span class="text-sm font-semibold text-gray-900 flex-1 <%= acao.status === 'concluido' ? 'line-through text-gray-400' : '' %>">
                            <%= acao.titulo %>
                        </span>
                        <div class="flex items-center gap-1.5 shrink-0 flex-wrap">
                            <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full <%= corPrior %>"><%= labelPrior %></span>
                            <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full <%= corStatus %>"><%= labelStatus %></span>
                        </div>
                    </div>

                    <div class="flex items-center gap-3 mt-1.5 flex-wrap">
                        <% if (acao.responsavel_nome) { %>
                        <span class="text-xs text-gray-500 flex items-center gap-1">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            <%= acao.responsavel_nome %>
                        </span>
                        <% } %>
                        <% if (prazoFmt) { %>
                        <span class="text-xs flex items-center gap-1 <%= vencida ? 'text-red-500 font-semibold' : 'text-gray-500' %>">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            <%= vencida ? 'Vencida — ' : '' %><%= prazoFmt %>
                        </span>
                        <% } %>
                    </div>

                    <!-- Evento vinculado -->
                    <% if (eventoVinculado) { %>
                    <div class="mt-2 flex items-center gap-2">
                        <a href="/eventos" class="inline-flex items-center gap-1.5 text-xs font-medium text-blue-600 bg-blue-50 hover:bg-blue-100 px-2.5 py-1 rounded-lg transition">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            <%= eventoVinculado.titulo %>
                        </a>
                        <button @click="desvincularEvento(<%= acao.id %>)" class="text-xs text-gray-400 hover:text-red-500 transition" title="Desvincular evento">×</button>
                    </div>
                    <% } %>

                    <!-- Expandido: descrição + objetivo + botões -->
                    <div x-show="expanded" x-cloak class="mt-3 space-y-2 pt-3 border-t border-gray-100">
                        <% if (acao.descricao) { %>
                        <p class="text-xs text-gray-600 leading-relaxed"><%= acao.descricao %></p>
                        <% } %>
                        <% if (acao.objetivo) { %>
                        <p class="text-xs text-gray-500"><span class="font-semibold text-gray-700">Objetivo:</span> <%= acao.objetivo %></p>
                        <% } %>
                        <div class="flex gap-2 pt-1 flex-wrap">
                            <button @click="abrirModalAcao(<%= JSON.stringify(acao).replace(/</g, '\\u003c') %>)"
                                class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium text-indigo-700 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                Editar
                            </button>
                            <% if (!acao.evento_id) { %>
                            <a href="<%= '/eventos/novo?titulo=' + encodeURIComponent(acao.titulo) + '&descricao=' + encodeURIComponent(acao.objetivo || acao.descricao || '') + '&secretaria_id=' + plano.secretaria_id + '&acao_id=' + acao.id + '&plano_id=' + plano.id %>"
                               class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 hover:bg-blue-100 rounded-lg transition">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                Gerar Evento
                            </a>
                            <% } %>
                            <form action="/planejamento/<%= plano.id %>/acoes/<%= acao.id %>/excluir" method="POST" onsubmit="return confirm('Excluir esta ação?')">
                                <button type="submit" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-medium text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                    Excluir
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Expand toggle -->
                <button @click="expanded = !expanded"
                    class="shrink-0 p-1 text-gray-300 hover:text-gray-500 transition mt-0.5"
                    :title="expanded ? 'Recolher' : 'Expandir'">
                    <svg class="w-4 h-4 transition-transform" :class="expanded ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
            </div>
            <% }); %>
        </div>
        <% } %>
        </div><!-- fim tab lista -->

        <!-- Tab: Timeline / Gantt -->
        <div x-show="tab === 'gantt'" x-cloak>
        <%
        const planStart = new Date(plano.periodo_inicio + 'T00:00:00').getTime();
        const planEnd   = new Date(plano.periodo_fim   + 'T00:00:00').getTime();
        const planSpan  = planEnd - planStart || 1;
        const acoesComPrazo = acoes.filter(function(a){ return a.prazo; });
        %>
        <% if (acoesComPrazo.length === 0) { %>
        <div class="text-center py-10 text-sm text-gray-400">
            Nenhuma ação com prazo definido. Adicione prazos às ações para visualizar a timeline.
        </div>
        <% } else { %>
        <!-- Cabeçalho com meses -->
        <%
        const meses = [];
        const cur = new Date(planStart);
        cur.setDate(1);
        while (cur.getTime() <= planEnd) {
            const left = Math.max(0, Math.min(100, ((cur.getTime() - planStart) / planSpan) * 100));
            meses.push({ label: cur.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' }), left: left.toFixed(1) });
            cur.setMonth(cur.getMonth() + 1);
        }
        %>
        <div class="overflow-x-auto">
        <div style="min-width:600px">
            <!-- Régua de meses -->
            <div class="relative h-7 mb-2 border-b border-gray-200">
                <% meses.forEach(function(m){ %>
                <span class="absolute text-[10px] text-gray-400 font-medium -translate-x-1/2" style="left:<%= m.left %>%"><%= m.label %></span>
                <% }); %>
                <!-- Linha hoje -->
                <%
                const hoje2 = new Date(); hoje2.setHours(0,0,0,0);
                const hojePct = Math.max(0, Math.min(100, ((hoje2.getTime() - planStart) / planSpan) * 100)).toFixed(1);
                %>
                <div class="absolute top-0 bottom-0 w-px bg-red-400 z-10" style="left:<%= hojePct %>%" title="Hoje">
                    <span class="absolute -top-4 -translate-x-1/2 text-[9px] text-red-500 font-bold">HOJE</span>
                </div>
            </div>

            <!-- Barras das ações -->
            <div class="space-y-2 pb-2">
            <% acoesComPrazo.forEach(function(acao) {
                const prazoTs = new Date(acao.prazo + 'T00:00:00').getTime();
                const barEnd  = Math.max(0, Math.min(100, ((prazoTs - planStart) / planSpan) * 100));
                const barStart = 0;
                const barW    = Math.max(1, barEnd - barStart);
                const ganttColors = {
                    concluido:    '#10b981',
                    em_andamento: '#3b82f6',
                    nao_iniciado: '#94a3b8',
                    cancelado:    '#f87171',
                };
                const barColor = ganttColors[acao.status] || '#94a3b8';
                const vencidaG = prazoTs < hoje2.getTime() && acao.status !== 'concluido' && acao.status !== 'cancelado';
            %>
            <div class="flex items-center gap-3">
                <div class="w-36 shrink-0 text-xs text-gray-700 truncate font-medium text-right pr-2" title="<%= acao.titulo %>">
                    <%= acao.titulo %>
                </div>
                <div class="flex-1 relative h-7 bg-gray-100 rounded-md overflow-hidden">
                    <div class="absolute top-1 bottom-1 rounded-md flex items-center px-2 overflow-hidden"
                         style="left:<%= barStart %>%;width:<%= barW %>%;background:<%= barColor %><%= vencidaG ? '' : '' %>;opacity:<%= acao.status === 'cancelado' ? '0.5' : '1' %>">
                        <span class="text-white text-[10px] font-semibold truncate whitespace-nowrap">
                            <%= new Date(acao.prazo + 'T00:00:00').toLocaleDateString('pt-BR', { day:'2-digit', month:'short' }) %>
                            <%= vencidaG ? ' ⚠' : '' %>
                        </span>
                    </div>
                    <!-- Linha vertical no prazo -->
                    <div class="absolute top-0 bottom-0 w-0.5 opacity-60" style="left:<%= barEnd %>%;background:<%= barColor %>"></div>
                </div>
            </div>
            <% }); %>
            </div>

            <!-- Legenda -->
            <div class="flex gap-4 mt-3 pt-3 border-t border-gray-100 flex-wrap">
                <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-3 h-3 rounded-sm bg-emerald-500 inline-block"></span>Concluído</span>
                <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-3 h-3 rounded-sm bg-blue-500 inline-block"></span>Em andamento</span>
                <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-3 h-3 rounded-sm bg-slate-400 inline-block"></span>Não iniciado</span>
                <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-3 h-3 rounded-sm bg-red-400 inline-block"></span>Cancelado</span>
                <span class="flex items-center gap-1.5 text-xs text-gray-500"><span class="w-px h-3 bg-red-400 inline-block"></span>Hoje</span>
            </div>
        </div>
        </div>
        <% } %>
        </div><!-- fim tab gantt -->
    </div>
</div><!-- fim space-y-6 -->


<!-- ─── Modal: Nova / Editar Ação ─────────────────────────────────────────── -->
<div x-show="modalAcao" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center p-4"
     style="background:rgba(15,23,42,0.6);backdrop-filter:blur(4px)"
     @click.self="modalAcao = false">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden" @click.stop>
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="text-base font-bold text-gray-900" x-text="acaoEditando ? 'Editar Ação' : 'Nova Ação'"></h3>
            <button @click="modalAcao = false" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form :action="acaoEditando ? '/planejamento/<%= plano.id %>/acoes/' + acaoEditando.id + '/editar' : '/planejamento/<%= plano.id %>/acoes'"
              method="POST" class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Título <span class="text-red-500">*</span></label>
                <input type="text" name="titulo" required :value="acaoEditando ? acaoEditando.titulo : ''"
                    class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Objetivo</label>
                <textarea name="objetivo" rows="2" :value="acaoEditando ? (acaoEditando.objetivo || '') : ''"
                    placeholder="O que se pretende alcançar com esta ação?"
                    class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm resize-none"></textarea>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descrição / Detalhes</label>
                <textarea name="descricao" rows="2" :value="acaoEditando ? (acaoEditando.descricao || '') : ''"
                    class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm resize-none"></textarea>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Responsável</label>
                    <input type="text" name="responsavel_nome" :value="acaoEditando ? (acaoEditando.responsavel_nome || '') : ''"
                        placeholder="Nome do responsável"
                        class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Prazo</label>
                    <input type="date" name="prazo" :value="acaoEditando ? (acaoEditando.prazo || '') : ''"
                        class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Prioridade</label>
                    <select name="prioridade" class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                        <option value="baixa" :selected="acaoEditando && acaoEditando.prioridade === 'baixa'">Baixa</option>
                        <option value="media" :selected="!acaoEditando || acaoEditando.prioridade === 'media'">Média</option>
                        <option value="alta" :selected="acaoEditando && acaoEditando.prioridade === 'alta'">Alta</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select name="status" class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                        <option value="nao_iniciado" :selected="!acaoEditando || acaoEditando.status === 'nao_iniciado'">Não iniciado</option>
                        <option value="em_andamento" :selected="acaoEditando && acaoEditando.status === 'em_andamento'">Em andamento</option>
                        <option value="concluido" :selected="acaoEditando && acaoEditando.status === 'concluido'">Concluído</option>
                        <option value="cancelado" :selected="acaoEditando && acaoEditando.status === 'cancelado'">Cancelado</option>
                    </select>
                </div>
            </div>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button" @click="modalAcao = false"
                    class="px-4 py-2.5 rounded-lg border border-gray-300 text-gray-600 text-sm font-medium hover:bg-gray-50 transition">Cancelar</button>
                <button type="submit"
                    class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 transition shadow-sm">Salvar</button>
            </div>
        </form>
    </div>
</div>


<!-- ─── Modal: Nova / Editar Indicador ────────────────────────────────────── -->
<div x-show="modalIndicador" x-cloak
     class="fixed inset-0 z-50 flex items-center justify-center p-4"
     style="background:rgba(15,23,42,0.6);backdrop-filter:blur(4px)"
     @click.self="modalIndicador = false">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden" @click.stop>
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="text-base font-bold text-gray-900" x-text="indEditando ? 'Editar Indicador' : 'Nova Meta / Indicador'"></h3>
            <button @click="modalIndicador = false" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form :action="indEditando ? '/planejamento/<%= plano.id %>/indicadores/' + indEditando.id + '/editar' : '/planejamento/<%= plano.id %>/indicadores'"
              method="POST" class="p-6 space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Indicador <span class="text-red-500">*</span></label>
                <input type="text" name="indicador" required :value="indEditando ? indEditando.indicador : ''"
                    placeholder="Ex: Eventos realizados, Releases publicados..."
                    class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descrição <span class="text-gray-400 font-normal">(opcional)</span></label>
                <textarea name="descricao" rows="2" :value="indEditando ? (indEditando.descricao || '') : ''"
                    class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm resize-none"></textarea>
            </div>
            <div class="grid grid-cols-3 gap-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Meta <span class="text-red-500">*</span></label>
                    <input type="number" name="valor_meta" required min="0" step="any" :value="indEditando ? indEditando.valor_meta : ''"
                        class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Atual</label>
                    <input type="number" name="valor_atual" min="0" step="any" :value="indEditando ? indEditando.valor_atual : '0'"
                        class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Unidade</label>
                    <input type="text" name="unidade" :value="indEditando ? indEditando.unidade : 'unidades'"
                        placeholder="eventos, %..."
                        class="w-full px-3.5 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
            </div>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button" @click="modalIndicador = false"
                    class="px-4 py-2.5 rounded-lg border border-gray-300 text-gray-600 text-sm font-medium hover:bg-gray-50 transition">Cancelar</button>
                <button type="submit"
                    class="px-5 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 transition shadow-sm">Salvar</button>
            </div>
        </form>
    </div>
</div>


<script>
function planShow() {
    return {
        tab: 'lista',
        modalAcao: false,
        acaoEditando: null,
        modalIndicador: false,
        indEditando: null,

        abrirModalAcao(acao) {
            this.acaoEditando = acao;
            this.modalAcao = true;
        },

        abrirModalIndicador(ind) {
            this.indEditando = ind;
            this.modalIndicador = true;
        },

        async toggleStatusAcao(id, statusAtual) {
            var novoStatus = statusAtual === 'concluido' ? 'nao_iniciado' : 'concluido';
            try {
                var r = await fetch('/planejamento/<%= plano.id %>/acoes/' + id + '/status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: novoStatus }),
                });
                if ((await r.json()).ok) window.location.reload();
            } catch(e) {}
        },

        async desvincularEvento(acaoId) {
            if (!confirm('Desvincular o evento desta ação?')) return;
            try {
                var r = await fetch('/planejamento/<%= plano.id %>/acoes/' + acaoId + '/desvincular-evento', { method: 'POST' });
                if ((await r.json()).ok) window.location.reload();
            } catch(e) {}
        },

        async excluirPlano() {
            if (!confirm('Excluir este plano e todas as suas ações e indicadores? Esta ação é irreversível.')) return;
            try {
                var r = await fetch('/planejamento/<%= plano.id %>/excluir', { method: 'POST' });
                if ((await r.json()).ok) window.location.href = '/planejamento';
            } catch(e) {}
        },
    };
}
</script>
</div><!-- fim x-data planShow -->
