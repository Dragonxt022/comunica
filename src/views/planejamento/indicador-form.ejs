<%
const indEdit = typeof indicador !== 'undefined' ? indicador : null;
const isEdit = !!indEdit;
const formAction = isEdit
    ? '/planejamento/' + plano.id + '/indicadores/' + indEdit.id + '/editar'
    : '/planejamento/' + plano.id + '/indicadores';
const pageTitle = isEdit ? 'Editar Indicador' : 'Nova Meta / Indicador';
%>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
<style>
.ql-toolbar.ql-snow { border: 1px solid #d1d5db; border-bottom: none; border-radius: 0.5rem 0.5rem 0 0; background: #f9fafb; padding: 6px 10px; }
.ql-container.ql-snow { border: 1px solid #d1d5db; border-radius: 0 0 0.5rem 0.5rem; font-size: 0.875rem; font-family: inherit; }
.ql-editor { min-height: 180px; padding: 12px 14px; }
.ql-editor.ql-blank::before { color: #9ca3af; font-style: normal; }
.ql-toolbar.ql-snow .ql-formats { margin-right: 6px; }
</style>

<div class="max-w-2xl mx-auto space-y-5">

    <!-- Header -->
    <div class="flex items-center gap-3">
        <a href="/planejamento/<%= plano.id %>"
           class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition shrink-0"
           title="Voltar ao plano">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>
        <div class="min-w-0">
            <h1 class="text-xl font-bold text-gray-900"><%= pageTitle %></h1>
            <p class="text-sm text-gray-500 mt-0.5">
                Plano: <a href="/planejamento/<%= plano.id %>" class="font-medium text-indigo-600 hover:underline"><%= plano.titulo %></a>
            </p>
        </div>
    </div>

    <!-- Form -->
    <form action="<%= formAction %>" method="POST" id="form-ind"
          class="bg-white rounded-xl border border-gray-200 shadow-sm">

        <div class="p-6 space-y-5">

            <!-- Nome do Indicador -->
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                    Indicador <span class="text-red-500">*</span>
                </label>
                <input type="text" name="indicador" required
                    value="<%= indEdit ? indEdit.indicador : '' %>"
                    placeholder="Ex: Eventos realizados, Releases publicados..."
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
            </div>

            <!-- Meta + Atual + Unidade -->
            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                        Meta <span class="text-red-500">*</span>
                    </label>
                    <input type="number" name="valor_meta" required min="0" step="any"
                        value="<%= indEdit ? indEdit.valor_meta : '' %>"
                        placeholder="100"
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Valor Atual</label>
                    <input type="number" name="valor_atual" min="0" step="any"
                        value="<%= indEdit ? indEdit.valor_atual : '0' %>"
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Unidade</label>
                    <input type="text" name="unidade"
                        value="<%= indEdit ? (indEdit.unidade || 'unidades') : 'unidades' %>"
                        placeholder="eventos, %, posts..."
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition text-sm">
                </div>
            </div>

            <!-- Preview de progresso (se editando) -->
            <% if (indEdit && indEdit.valor_meta > 0) { %>
            <%
            const pctPrev = Math.min(Math.round((indEdit.valor_atual / indEdit.valor_meta) * 100), 100);
            const pctColor = pctPrev >= 100 ? 'bg-emerald-500' : pctPrev >= 60 ? 'bg-blue-500' : pctPrev >= 30 ? 'bg-amber-500' : 'bg-red-400';
            %>
            <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
                <div class="flex items-center justify-between text-xs text-gray-500 mb-2">
                    <span class="font-medium">Progresso atual</span>
                    <span class="font-bold text-gray-700"><%= pctPrev %>%</span>
                </div>
                <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full <%= pctColor %> rounded-full" style="width:<%= pctPrev %>%"></div>
                </div>
                <p class="text-xs text-gray-400 mt-2">
                    <%= indEdit.valor_atual %> de <%= indEdit.valor_meta %> <%= indEdit.unidade %>
                </p>
            </div>
            <% } %>

            <!-- Descrição -->
            <div>
                <div class="flex items-center justify-between mb-1.5">
                    <label class="block text-sm font-semibold text-gray-700">
                        Descrição <span class="text-gray-400 font-normal text-xs">(opcional)</span>
                    </label>
                    <span class="text-xs text-gray-400">Suporta formatação</span>
                </div>
                <div id="quill-ind-editor"></div>
                <input type="hidden" name="descricao" id="input-ind-descricao">
            </div>

        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between bg-gray-50 rounded-b-xl">
            <a href="/planejamento/<%= plano.id %>"
               class="px-4 py-2.5 rounded-lg border border-gray-300 text-gray-600 text-sm font-medium hover:bg-white transition">
                Cancelar
            </a>
            <button type="submit"
                class="px-6 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700 active:scale-95 transition shadow-sm">
                <%= isEdit ? 'Salvar Alterações' : 'Criar Indicador' %>
            </button>
        </div>
    </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
(function() {
    var quill = new Quill('#quill-ind-editor', {
        theme: 'snow',
        placeholder: 'Contexto, método de medição, fonte dos dados...',
        modules: {
            toolbar: [
                [{ header: [2, 3, false] }],
                ['bold', 'italic', 'underline'],
                [{ color: [] }],
                [{ align: [] }],
                [{ list: 'ordered' }, { list: 'bullet' }],
                ['clean']
            ]
        }
    });

    <% if (indEdit && indEdit.descricao) { %>
    quill.root.innerHTML = <%- JSON.stringify(indEdit.descricao) %>;
    <% } %>

    document.getElementById('form-ind').addEventListener('submit', function() {
        var html = quill.root.innerHTML;
        document.getElementById('input-ind-descricao').value = html === '<p><br></p>' ? '' : html;
    });
}());
</script>
