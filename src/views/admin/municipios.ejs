<div class="space-y-6">

    <!-- Cabeçalho -->
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Municípios</h2>
            <p class="text-sm text-gray-500 mt-1">Gestão de municípios atendidos pelo sistema.</p>
        </div>
        <a href="/admin/municipios/novo"
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 transition shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Novo Município
        </a>
    </div>

    <!-- Busca -->
    <div class="flex items-center gap-3">
        <div class="relative flex-1 max-w-sm">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            <input id="mun-search" type="text" placeholder="Buscar por nome ou estado..."
                class="w-full pl-9 pr-4 py-2 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
        </div>
        <select id="mun-status-filter" class="px-3 py-2 rounded-lg border border-gray-200 bg-white text-sm text-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition">
            <option value="">Todos os status</option>
            <option value="ativo">Ativo</option>
            <option value="inativo">Inativo</option>
        </select>
    </div>

    <% if (locals.query && locals.query.erro === 'municipio_com_dados') { %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
        Não é possível excluir um município que possui secretarias vinculadas. Remova as secretarias primeiro.
    </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
    <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
        <% errors.forEach(e => { %><p><%= e %></p><% }) %>
    </div>
    <% } %>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <% if (counts.length === 0) { %>
        <div class="p-12 text-center text-gray-400">
            <svg class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <p class="text-sm font-medium">Nenhum município cadastrado</p>
        </div>
        <% } else { %>
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Município</th>
                    <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Estado</th>
                    <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Secretarias</th>
                    <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Usuários</th>
                    <th class="text-center px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <% counts.forEach(({ municipio, qtdSecretarias, qtdUsuarios }) => { %>
                <tr class="hover:bg-gray-50 transition" data-search="<%= (municipio.nome + ' ' + municipio.estado).toLowerCase() %>" data-status="<%= municipio.ativo ? 'ativo' : 'inativo' %>">
                    <td class="px-5 py-3.5 font-medium text-gray-800"><%= municipio.nome %></td>
                    <td class="px-5 py-3.5 text-gray-500"><%= municipio.estado %></td>
                    <td class="px-5 py-3.5 text-center text-gray-600"><%= qtdSecretarias %></td>
                    <td class="px-5 py-3.5 text-center text-gray-600"><%= qtdUsuarios %></td>
                    <td class="px-5 py-3.5 text-center">
                        <% if (municipio.ativo) { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Ativo</span>
                        <% } else { %>
                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">Inativo</span>
                        <% } %>
                    </td>
                    <td class="px-5 py-3.5">
                        <div class="flex items-center justify-end gap-2">
                            <a href="/admin/municipios/<%= municipio.id %>/editar"
                                class="px-3 py-1.5 text-xs font-medium text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-lg transition">
                                Editar
                            </a>
                            <% if (qtdSecretarias === 0 && qtdUsuarios === 0) { %>
                            <form action="/admin/municipios/<%= municipio.id %>/excluir" method="POST"
                                onsubmit="return confirm('Excluir município <%= municipio.nome %>?')">
                                <button type="submit"
                                    class="px-3 py-1.5 text-xs font-medium text-red-600 hover:text-red-800 hover:bg-red-50 rounded-lg transition">
                                    Excluir
                                </button>
                            </form>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>

</div>

<script>
(function() {
    var searchInput = document.getElementById('mun-search');
    var statusFilter = document.getElementById('mun-status-filter');
    function filtrar() {
        var q = searchInput ? searchInput.value.toLowerCase() : '';
        var st = statusFilter ? statusFilter.value : '';
        document.querySelectorAll('tbody tr[data-search]').forEach(function(row) {
            var okSearch = !q || row.dataset.search.includes(q);
            var okStatus = !st || row.dataset.status === st;
            row.style.display = okSearch && okStatus ? '' : 'none';
        });
    }
    if (searchInput) searchInput.addEventListener('input', filtrar);
    if (statusFilter) statusFilter.addEventListener('change', filtrar);
}());
</script>
