<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold text-gray-900">Configurações do Site</h2>
        <p class="text-gray-500">Informações gerais exibidas nas páginas públicas.</p>
    </div>

    <% if(success) { %>
        <div class="p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700 flex items-center gap-2">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Configurações salvas com sucesso.
        </div>
    <% } %>

    <form action="/admin/configuracoes" method="POST" class="space-y-6">

        <!-- Identidade do site -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
            <h3 class="text-base font-semibold text-gray-800 flex items-center gap-2">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                Identidade
            </h3>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Título do site</label>
                <input type="text" name="titulo_site" value="<%= config ? config.titulo_site : '' %>"
                    placeholder="Ex: Prefeitura Municipal de Exemplo"
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Subtítulo</label>
                <input type="text" name="subtitulo_site" value="<%= config ? config.subtitulo_site : '' %>"
                    placeholder="Ex: Secretaria de Comunicação"
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descrição</label>
                <textarea name="descricao_site" rows="3"
                    placeholder="Breve descrição da prefeitura ou da plataforma..."
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition resize-none"><%= config ? config.descricao_site : '' %></textarea>
            </div>
        </div>

        <!-- Contato -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
            <h3 class="text-base font-semibold text-gray-800 flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                Contato
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">E-mail de contato</label>
                    <input type="email" name="email_contato" value="<%= config ? config.email_contato : '' %>"
                        placeholder="comunicacao@prefeitura.gov.br"
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Telefone</label>
                    <input type="text" name="telefone_contato" value="<%= config ? config.telefone_contato : '' %>"
                        placeholder="(XX) XXXX-XXXX"
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
                </div>
            </div>
        </div>

        <!-- Redes Sociais -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
            <h3 class="text-base font-semibold text-gray-800 flex items-center gap-2">
                <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path></svg>
                Redes Sociais e Links
            </h3>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    <span class="inline-flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-pink-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                        Instagram
                    </span>
                </label>
                <div class="flex items-center gap-2">
                    <span class="px-3 py-2.5 bg-gray-100 border border-gray-300 border-r-0 rounded-l-lg text-gray-500 text-sm">instagram.com/</span>
                    <input type="text" name="instagram" value="<%= config ? config.instagram : '' %>"
                        placeholder="prefeitura.exemplo"
                        class="flex-1 px-4 py-2.5 rounded-r-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
                </div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Site oficial</label>
                <input type="url" name="site_oficial" value="<%= config ? config.site_oficial : '' %>"
                    placeholder="https://www.prefeitura.gov.br"
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
            </div>
        </div>

        <!-- Status de Eventos -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
            <h3 class="text-base font-semibold text-gray-800 flex items-center gap-2">
                <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path></svg>
                Status de Eventos
            </h3>
            <p class="text-sm text-gray-500">Defina os status disponíveis no calendário institucional. A ordem aqui reflete o fluxo do processo.</p>

            <div id="status-list" class="space-y-2"></div>

            <div class="flex gap-2 pt-3 border-t border-gray-100">
                <input id="new-status-label" type="text" placeholder="Nome do novo status…"
                    class="flex-1 px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 outline-none">
                <input id="new-status-cor" type="color" value="#6366f1"
                    class="h-10 w-12 rounded-lg border border-gray-300 cursor-pointer p-1">
                <button type="button" onclick="addStatus()"
                    class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition inline-flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
                    Adicionar
                </button>
            </div>
            <input type="hidden" name="status_eventos_json" id="status-eventos-json">
        </div>

        <!-- Metas por Tipo de Mídia -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4" x-data="metasConfig()">
            <h3 class="text-base font-semibold text-gray-800 flex items-center gap-2">
                <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                Metas Mensais por Tipo de Mídia
            </h3>
            <p class="text-sm text-gray-500">Defina quantas solicitações concluídas por tipo de mídia devem ser atingidas por mês. Deixe 0 para desativar a meta desse tipo.</p>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                <template x-for="item in tiposMidia" :key="item">
                    <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg bg-gray-50">
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-700 truncate" x-text="item"></p>
                        </div>
                        <input type="number" min="0" max="999"
                            :value="getMeta(item)"
                            @input="setMeta(item, $event.target.value)"
                            class="w-20 px-2 py-1.5 text-sm text-center rounded-lg border border-gray-300 focus:ring-2 focus:ring-emerald-500 outline-none">
                    </div>
                </template>
            </div>

            <input type="hidden" name="metas_midia_json" x-model="metasJson">
        </div>

        <div class="flex justify-end">
            <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Salvar Configurações
            </button>
        </div>
    </form>
</div>

<script>
function metasConfig() {
    var inicial = <%- JSON.stringify(metas) %>;
    var tiposMidia = ['Fotografia','Vídeo','Cobertura jornalística','Nota à imprensa','Release','Arte gráfica','Transmissão ao vivo','Post para Redes Sociais','Outros'];
    var map = {};
    inicial.forEach(function(m) { if (m.quantidade > 0) map[m.tipo_midia] = m.quantidade; });

    return {
        tiposMidia: tiposMidia,
        map: map,
        get metasJson() {
            var arr = tiposMidia
                .map(function(t) { return { tipo_midia: t, quantidade: parseInt(map[t] || 0) }; })
                .filter(function(m) { return m.quantidade > 0; });
            return JSON.stringify(arr);
        },
        getMeta: function(tipo) { return map[tipo] || 0; },
        setMeta: function(tipo, val) {
            var n = parseInt(val) || 0;
            if (n > 0) map[tipo] = n; else delete map[tipo];
        },
    };
}
</script>

<script>
(function() {
    var statuses = <%- JSON.stringify(statusEventos) %>;

    function keyFromLabel(label) {
        return label.toLowerCase()
            .normalize('NFD').replace(/[̀-ͯ]/g, '')
            .replace(/\s+/g, '_')
            .replace(/[^a-z0-9_]/g, '');
    }

    function renderStatuses() {
        var list = document.getElementById('status-list');
        if (statuses.length === 0) {
            list.innerHTML = '<p class="text-sm text-gray-400 italic py-2">Nenhum status cadastrado.</p>';
            return;
        }
        list.innerHTML = statuses.map(function(s, i) {
            return '<div class="flex items-center gap-3 bg-gray-50 rounded-lg px-3 py-2.5">' +
                '<span class="w-3 h-3 rounded-full flex-shrink-0" style="background:' + s.cor + '"></span>' +
                '<span class="flex-1 text-sm font-medium text-gray-800">' + escHtml(s.label) + '</span>' +
                '<span class="text-xs text-gray-400 font-mono">' + escHtml(s.key) + '</span>' +
                '<input type="color" value="' + s.cor + '" title="Cor" ' +
                    'onchange="updateCor(' + i + ', this.value)" ' +
                    'class="h-7 w-8 rounded border border-gray-200 cursor-pointer p-0.5">' +
                '<button type="button" onclick="removeStatus(' + i + ')" ' +
                    'class="p-1 text-gray-400 hover:text-red-500 transition" title="Remover">' +
                    '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">' +
                    '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>' +
                '</button>' +
            '</div>';
        }).join('');
    }

    function escHtml(str) {
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    window.addStatus = function() {
        var label = document.getElementById('new-status-label').value.trim();
        var cor   = document.getElementById('new-status-cor').value;
        if (!label) { document.getElementById('new-status-label').focus(); return; }
        var key = keyFromLabel(label);
        if (!key) { alert('Nome inválido.'); return; }
        if (statuses.find(function(s) { return s.key === key; })) {
            alert('Já existe um status com este nome.'); return;
        }
        statuses.push({ key: key, label: label, cor: cor });
        document.getElementById('new-status-label').value = '';
        renderStatuses();
    };

    window.removeStatus = function(i) {
        statuses.splice(i, 1);
        renderStatuses();
    };

    window.updateCor = function(i, cor) {
        statuses[i].cor = cor;
        renderStatuses();
    };

    document.querySelector('form').addEventListener('submit', function() {
        document.getElementById('status-eventos-json').value = JSON.stringify(statuses);
    });

    renderStatuses();
}());
</script>
</div>
