<div class="space-y-6" x-data="{ deleteId: null, deleteName: '' }">

    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Secretarias</h2>
            <p class="text-gray-500">Gerencie as secretarias e órgãos municipais.</p>
        </div>
        <a href="/admin/secretarias/nova"
            class="px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Nova Secretaria
        </a>
    </div>

    <!-- Modal: Confirmar Exclusão -->
    <template x-if="deleteId !== null">
        <div @click.self="deleteId = null" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.5)">
            <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 space-y-4">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </div>
                    <div>
                        <h3 class="text-base font-bold text-gray-900">Excluir secretaria?</h3>
                        <p class="text-sm text-gray-500">Esta ação não pode ser desfeita.</p>
                    </div>
                </div>
                <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-800 font-medium" x-text="deleteName"></div>
                <div class="flex gap-3">
                    <button @click="deleteId = null"
                        class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition font-medium">
                        Cancelar
                    </button>
                    <form :action="'/admin/secretarias/' + deleteId + '/excluir'" method="POST" class="flex-1">
                        <button type="submit"
                            class="w-full px-4 py-2.5 bg-red-600 text-white rounded-lg text-sm hover:bg-red-700 transition font-semibold">
                            Sim, excluir
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </template>

    <!-- Tabela -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <% if(secretarias.length === 0) { %>
            <div class="py-20 text-center">
                <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                <p class="text-gray-400 font-medium">Nenhuma secretaria cadastrada.</p>
                <a href="/admin/secretarias/nova" class="mt-2 inline-block text-blue-600 text-sm font-medium hover:underline">Criar a primeira</a>
            </div>
        <% } else { %>
        <table class="min-w-full divide-y divide-gray-100">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Secretaria</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
                    <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 text-sm">
                <% secretarias.forEach(s => { %>
                <tr class="hover:bg-gray-50/70 transition group">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-4 h-4 rounded-full flex-shrink-0" style="background-color:<%= s.cor %>"></div>
                            <span class="font-semibold text-gray-900"><%= s.nome %></span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-gray-500 font-mono text-xs"><%= s.slug %></td>
                    <td class="px-6 py-4">
                        <% if(s.ativo) { %>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-bold bg-green-100 text-green-700 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Ativa
                            </span>
                        <% } else { %>
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-bold bg-gray-100 text-gray-500 rounded-full">
                                <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Inativa
                            </span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex justify-end items-center gap-1 opacity-60 group-hover:opacity-100 transition">
                            <a href="/admin/secretarias/<%= s.id %>/editar"
                                title="Editar"
                                class="p-1.5 rounded-lg text-gray-500 hover:text-blue-600 hover:bg-blue-50 transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                            </a>
                            <button
                                @click="deleteId = <%= s.id %>; deleteName = '<%= s.nome.replace(/'/g, "\\'") %>'"
                                title="Excluir"
                                class="p-1.5 rounded-lg text-gray-500 hover:text-red-600 hover:bg-red-50 transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
            <%= secretarias.length %> secretaria<%= secretarias.length !== 1 ? 's' : '' %> cadastrada<%= secretarias.length !== 1 ? 's' : '' %>
        </div>
        <% } %>
    </div>
</div>
