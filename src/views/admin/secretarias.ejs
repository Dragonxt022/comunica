<div class="space-y-6" x-data="{ showCreate: false, editId: null, editData: {} }">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Secretarias</h2>
            <p class="text-gray-500">Gerencie as secretarias e órgãos municipais.</p>
        </div>
        <button @click="showCreate = true" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Nova Secretaria
        </button>
    </div>

    <% if(errors && errors.length > 0) { %>
        <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
            <% errors.forEach(e => { %><p><%= e %></p><% }) %>
        </div>
    <% } %>

    <!-- Modal Criar -->
    <div x-show="showCreate" x-cloak @click.self="showCreate = false" class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(0,0,0,0.4)">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 space-y-4">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900">Nova Secretaria</h3>
                <button @click="showCreate = false" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/admin/secretarias" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nome <span class="text-red-500">*</span></label>
                    <input type="text" name="nome" required placeholder="Ex: Secretaria de Saúde"
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Cor de identificação</label>
                    <div class="flex items-center gap-3">
                        <input type="color" name="cor" value="#3b82f6" class="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer p-1">
                        <span class="text-xs text-gray-500">Usada para diferenciar a secretaria nos filtros</span>
                    </div>
                </div>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" @click="showCreate = false" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition">Cancelar</button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">Salvar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal Editar -->
    <div x-show="editId !== null" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(0,0,0,0.4)">
        <div @click.outside="editId = null" class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6 space-y-4">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900">Editar Secretaria</h3>
                <button @click="editId = null" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form :action="'/admin/secretarias/' + editId" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nome</label>
                    <input type="text" name="nome" :value="editData.nome" required
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Cor</label>
                    <input type="color" name="cor" :value="editData.cor"
                        class="w-12 h-10 rounded-lg border border-gray-300 cursor-pointer p-1">
                </div>
                <div class="flex items-center gap-2">
                    <input type="checkbox" name="ativo" id="editAtivo" :checked="editData.ativo" class="w-4 h-4 accent-blue-600">
                    <label for="editAtivo" class="text-sm text-gray-700">Secretaria ativa</label>
                </div>
                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" @click="editId = null" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-600 hover:bg-gray-50 transition">Cancelar</button>
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium">Salvar</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabela -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <% if(secretarias.length === 0) { %>
            <div class="py-20 text-center text-gray-400">Nenhuma secretaria cadastrada.</div>
        <% } else { %>
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Secretaria</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slug</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200 text-sm">
                <% secretarias.forEach(s => { %>
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-4 h-4 rounded-full flex-shrink-0" style="background-color: <%= s.cor %>"></div>
                            <span class="font-semibold text-gray-900"><%= s.nome %></span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-gray-500 font-mono text-xs"><%= s.slug %></td>
                    <td class="px-6 py-4">
                        <% if(s.ativo) { %>
                            <span class="px-2.5 py-1 text-xs font-bold bg-green-100 text-green-700 rounded-full">Ativa</span>
                        <% } else { %>
                            <span class="px-2.5 py-1 text-xs font-bold bg-gray-100 text-gray-500 rounded-full">Inativa</span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end items-center gap-2">
                            <button @click="editId = <%= s.id %>; editData = { nome: '<%= s.nome.replace(/'/g, "\\'") %>', cor: '<%= s.cor %>', ativo: <%= s.ativo %> }"
                                class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 transition">Editar</button>
                            <form action="/admin/secretarias/<%= s.id %>/excluir" method="POST" onsubmit="return confirm('Excluir esta secretaria?')">
                                <button type="submit" class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
