<div class="max-w-5xl mx-auto space-y-6">

    <!-- Cabeçalho -->
    <div class="flex items-center gap-3">
        <a href="/solicitacoes" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </a>
        <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
                <h2 class="text-2xl font-bold text-gray-900 truncate"><%= sol.titulo %></h2>
                <span class="text-sm font-bold text-gray-400">#<%= sol.id %></span>
            </div>
            <p class="text-sm text-gray-500 mt-0.5">Aberta em <%= new Date(sol.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %></p>
        </div>
        <a href="/solicitacoes/<%= sol.id %>/editar" class="hidden sm:inline-flex items-center gap-2 px-3 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            Editar
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Conteúdo principal -->
        <div class="lg:col-span-2 space-y-5">

            <!-- Descrição / Briefing -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-3">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Briefing / Descrição</h3>
                <p class="text-gray-700 leading-relaxed whitespace-pre-wrap text-sm"><%= sol.descricao %></p>
            </div>

            <!-- Linha do tempo de status -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Fluxo de Status</h3>
                <div class="flex items-center gap-0">
                    <%
                        var etapas = [
                            { key: 'pendente',   label: 'Pendente'   },
                            { key: 'aprovado',   label: 'Aprovado'   },
                            { key: 'produção',   label: 'Produção'   },
                            { key: 'concluído',  label: 'Concluído'  },
                            { key: 'finalizado', label: 'Finalizado' },
                        ];
                        var statusIndex = etapas.findIndex(function(e){ return e.key === sol.status; });
                    %>
                    <% etapas.forEach(function(etapa, i) {
                        var isDone   = i < statusIndex;
                        var isActive = i === statusIndex;
                        var isCanceled = sol.status === 'cancelado';
                    %>
                    <div class="flex items-center flex-1">
                        <div class="flex flex-col items-center gap-1.5 flex-1">
                            <div id="tl-dot-<%= i %>" class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold border-2 transition
                                <%= isCanceled ? 'border-gray-200 bg-gray-50 text-gray-300' :
                                   isDone   ? 'border-green-500 bg-green-500 text-white' :
                                   isActive ? 'border-blue-500 bg-blue-500 text-white' :
                                              'border-gray-200 bg-white text-gray-300' %>">
                                <% if(!isCanceled && isDone) { %>
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                <% } else { %>
                                    <%= i + 1 %>
                                <% } %>
                            </div>
                            <span id="tl-label-<%= i %>" class="text-[10px] font-bold uppercase tracking-wide
                                <%= isCanceled ? 'text-gray-300' :
                                   isDone   ? 'text-green-600' :
                                   isActive ? 'text-blue-600'  :
                                              'text-gray-400'  %>">
                                <%= etapa.label %>
                            </span>
                        </div>
                        <% if(i < etapas.length - 1) { %>
                        <div id="tl-line-<%= i %>" class="h-0.5 flex-1 mx-1 mb-5
                            <%= isCanceled ? 'bg-gray-100' : isDone ? 'bg-green-400' : 'bg-gray-200' %>"></div>
                        <% } %>
                    </div>
                    <% }) %>
                </div>
                <% if(sol.status === 'cancelado') { %>
                <div id="banner-cancelado" class="flex items-center gap-2 mt-2 px-3 py-2 bg-red-50 border border-red-200 rounded-lg">
                    <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="text-sm font-semibold text-red-700">Esta solicitação foi cancelada.</span>
                </div>
                <% } %>
                <% if(sol.status === 'finalizado') { %>
                <div id="banner-finalizado" class="flex items-center gap-2 mt-2 px-3 py-2 bg-green-50 border border-green-200 rounded-lg">
                    <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="text-sm font-semibold text-green-700">Solicitação finalizada e aprovada com sucesso.</span>
                </div>
                <% } %>
            </div>

            <!-- Alterar status (admin/secom) -->
            <% if(user && user.role !== 'secretaria') { %>
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-4" id="status-panel">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Atualizar Status</h3>
                <div class="flex flex-wrap gap-2">
                    <%
                        var statusOpts = [
                            { key: 'pendente',   label: 'Pendente',    cls: 'border-yellow-400 text-yellow-700 hover:bg-yellow-50'  },
                            { key: 'aprovado',   label: 'Aprovado',    cls: 'border-blue-400   text-blue-700   hover:bg-blue-50'    },
                            { key: 'produção',   label: 'Em Produção', cls: 'border-indigo-400 text-indigo-700 hover:bg-indigo-50'  },
                            { key: 'concluído',  label: 'Concluído',   cls: 'border-teal-400   text-teal-700   hover:bg-teal-50'    },
                            { key: 'finalizado', label: 'Finalizado',  cls: 'border-green-400  text-green-700  hover:bg-green-50'   },
                            { key: 'cancelado',  label: 'Cancelado',   cls: 'border-red-300    text-red-600    hover:bg-red-50'     },
                        ];
                    %>
                    <% statusOpts.forEach(function(opt) { %>
                    <button type="button"
                        onclick="setStatus('<%= opt.key %>')"
                        class="px-4 py-2 rounded-lg border-2 text-sm font-semibold transition <%= opt.cls %>
                            <%= sol.status === opt.key ? 'ring-2 ring-offset-1 ring-current opacity-100' : 'opacity-70' %>"
                        id="btn-<%= opt.key %>">
                        <%= opt.label %>
                        <% if(sol.status === opt.key) { %>
                            <svg class="inline w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        <% } %>
                    </button>
                    <% }) %>
                </div>
                <p id="status-msg" class="hidden text-sm font-medium text-green-700 flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                    Status atualizado com sucesso!
                </p>
            </div>
            <% } %>
            <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- Feed de Atividade                                               -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm" id="feed">

        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
            <h3 class="text-sm font-bold text-gray-800 flex items-center gap-2">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
                Histórico de Atividade
            </h3>
            <span class="text-xs text-gray-400 font-medium"><%= comentarios.length %> entradas</span>
        </div>

        <div class="p-6 space-y-4">

            <% if(comentarios.length === 0) { %>
            <p class="text-center text-sm text-gray-400 py-6">Nenhuma atividade ainda.</p>
            <% } %>

            <% comentarios.forEach(function(c) {
                var fmtDate = new Date(c.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })
                            + ' às '
                            + new Date(c.createdAt).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
            %>

                <% if(c.tipo === 'evento') { %>
                <!-- ─── Evento de sistema ─── -->
                <div class="flex items-center gap-3 py-0.5">
                    <div class="flex-1 h-px bg-gray-100"></div>
                    <span class="shrink-0 text-[10px] text-gray-400 font-medium px-2 py-1 bg-gray-50 rounded-full border border-gray-100">
                        <%= c.texto %> · <span class="font-bold"><%= c.autor ? c.autor.nome : '' %></span> · <%= fmtDate %>
                    </span>
                    <div class="flex-1 h-px bg-gray-100"></div>
                </div>

                <% } else if(c.tipo === 'aprovacao') { %>
                <!-- ─── Aprovação ─── -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <div class="flex-1">
                        <div class="bg-green-50 border border-green-200 rounded-xl rounded-tl-none p-4 space-y-1.5">
                            <div class="flex items-center justify-between flex-wrap gap-1">
                                <span class="font-bold text-sm text-green-800 flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    Material Aprovado
                                </span>
                                <span class="text-[10px] text-green-500"><%= c.autor ? c.autor.nome : '' %> · <%= fmtDate %></span>
                            </div>
                            <p class="text-sm text-green-700"><%= c.texto %></p>
                        </div>
                    </div>
                </div>

                <% } else if(c.tipo === 'revisao') { %>
                <!-- ─── Revisão solicitada ─── -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-orange-100 flex items-center justify-center shrink-0 mt-0.5">
                        <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    </div>
                    <div class="flex-1">
                        <div class="bg-orange-50 border border-orange-200 rounded-xl rounded-tl-none p-4 space-y-1.5">
                            <div class="flex items-center justify-between flex-wrap gap-1">
                                <span class="font-bold text-sm text-orange-800">Revisão Solicitada</span>
                                <span class="text-[10px] text-orange-400"><%= c.autor ? c.autor.nome : '' %> · <%= fmtDate %></span>
                            </div>
                            <p class="text-sm text-orange-700 whitespace-pre-wrap"><%= c.texto %></p>
                        </div>
                    </div>
                </div>

                <% } else if(c.tipo === 'anexo') { %>
                <!-- ─── Anexo ─── -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-0.5 text-blue-700 text-xs font-black">
                        <%= c.autor ? c.autor.nome.charAt(0).toUpperCase() : '?' %>
                    </div>
                    <div class="flex-1">
                        <div class="bg-blue-50 border border-blue-200 rounded-xl rounded-tl-none p-4 space-y-2.5">
                            <div class="flex items-center justify-between flex-wrap gap-1">
                                <span class="font-semibold text-sm text-blue-900"><%= c.autor ? c.autor.nome : '' %></span>
                                <span class="text-[10px] text-blue-400"><%= fmtDate %></span>
                            </div>
                            <% if(c.texto) { %>
                            <p class="text-sm text-blue-800 whitespace-pre-wrap"><%= c.texto %></p>
                            <% } %>
                            <a href="<%= c.arquivo_url %>" target="_blank"
                               class="flex items-center gap-3 p-3 bg-white border border-blue-100 hover:border-blue-300 rounded-lg transition group">
                                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
                                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs font-bold text-blue-700 group-hover:text-blue-900 transition truncate"><%= c.arquivo_nome %></p>
                                    <p class="text-[10px] text-blue-400">Clique para baixar</p>
                                </div>
                                <svg class="w-4 h-4 text-blue-400 group-hover:text-blue-600 transition shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>

                <% } else { %>
                <!-- ─── Comentário padrão ─── -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center shrink-0 mt-0.5 text-gray-600 text-xs font-black">
                        <%= c.autor ? c.autor.nome.charAt(0).toUpperCase() : '?' %>
                    </div>
                    <div class="flex-1">
                        <div class="bg-gray-50 border border-gray-200 rounded-xl rounded-tl-none p-4 space-y-1.5">
                            <div class="flex items-center justify-between flex-wrap gap-1">
                                <span class="font-semibold text-sm text-gray-800"><%= c.autor ? c.autor.nome : '' %></span>
                                <span class="text-[10px] text-gray-400"><%= fmtDate %></span>
                            </div>
                            <p class="text-sm text-gray-700 whitespace-pre-wrap leading-relaxed"><%= c.texto %></p>
                        </div>
                    </div>
                </div>
                <% } %>

            <% }) %>

            <!-- ═══ Aprovação / Revisão (para secretaria quando status = concluído) ═══ -->
            <% if(sol.status === 'concluído' && user.role === 'secretaria') { %>
            <div class="bg-teal-50 border-2 border-teal-300 rounded-xl p-5 space-y-4">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <h4 class="font-bold text-teal-800">Material disponível para revisão</h4>
                </div>
                <p class="text-sm text-teal-700">O material foi entregue pela equipe de comunicação. Revise e dê seu parecer.</p>
                <div class="flex flex-col sm:flex-row gap-3" x-data="{ revisaoOpen: false }">
                    <!-- Aprovar -->
                    <form action="/solicitacoes/<%= sol.id %>/aprovar" method="POST" class="flex-1">
                        <button type="submit"
                            class="w-full px-4 py-2.5 bg-green-600 text-white rounded-lg font-semibold hover:bg-green-700 transition inline-flex items-center justify-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                            Aprovar e Finalizar
                        </button>
                    </form>
                    <!-- Pedir revisão (Alpine collapsible) -->
                    <div class="flex-1 space-y-2">
                        <button type="button" @click="revisaoOpen = !revisaoOpen"
                            class="w-full px-4 py-2.5 bg-orange-100 text-orange-700 border border-orange-300 rounded-lg font-semibold hover:bg-orange-200 transition inline-flex items-center justify-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            Pedir Revisão
                        </button>
                        <div x-show="revisaoOpen" x-transition>
                            <form action="/solicitacoes/<%= sol.id %>/revisao" method="POST" class="space-y-2">
                                <textarea name="texto" required rows="3"
                                    placeholder="Descreva o que precisa ser ajustado ou corrigido..."
                                    class="w-full px-3 py-2.5 rounded-lg border border-orange-200 focus:ring-2 focus:ring-orange-400 outline-none text-sm resize-none bg-white"></textarea>
                                <div class="flex gap-2 justify-end">
                                    <button type="button" @click="revisaoOpen = false"
                                        class="px-4 py-2 text-sm font-medium text-gray-600 border border-gray-300 rounded-lg hover:bg-gray-50 transition">Cancelar</button>
                                    <button type="submit"
                                        class="px-4 py-2 text-sm font-semibold bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition">Enviar Revisão</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>

            <!-- ═══ Formulário de comentário ═══ -->
            <% if(sol.status !== 'finalizado' && sol.status !== 'cancelado') { %>
            <div class="pt-2 border-t border-gray-100">
                <form action="/solicitacoes/<%= sol.id %>/comentarios" method="POST" enctype="multipart/form-data">
                    <div class="flex gap-3">
                        <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center shrink-0 mt-0.5 text-white text-xs font-black">
                            <%= user.nome ? user.nome.charAt(0).toUpperCase() : 'U' %>
                        </div>
                        <div class="flex-1 space-y-2">
                            <textarea name="texto" rows="2" id="comment-textarea"
                                placeholder="Adicionar comentário, instrução ou informação..."
                                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none text-sm resize-none transition"></textarea>

                            <!-- File preview -->
                            <div id="file-preview" class="hidden flex items-center gap-2 px-3 py-2 bg-blue-50 border border-blue-200 rounded-lg text-xs font-medium text-blue-700">
                                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
                                <span id="file-name" class="truncate flex-1"></span>
                                <button type="button" onclick="clearFile()" class="text-blue-400 hover:text-blue-700 transition">✕</button>
                            </div>

                            <div class="flex items-center justify-between">
                                <label for="arquivo-input" class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-500 hover:text-gray-700 cursor-pointer transition px-2 py-1 rounded-lg hover:bg-gray-100">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path></svg>
                                    Anexar arquivo
                                </label>
                                <input type="file" name="arquivo" id="arquivo-input" class="hidden" onchange="showFilePreview(this)">
                                <button type="submit"
                                    class="px-5 py-2 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 transition inline-flex items-center gap-1.5">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                                    Enviar
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <% } else { %>
            <div class="pt-2 border-t border-gray-100 text-center py-4">
                <p class="text-sm text-gray-400">
                    <% if(sol.status === 'finalizado') { %>Esta solicitação foi finalizada. O histórico está arquivado acima.<% } %>
                    <% if(sol.status === 'cancelado') { %>Esta solicitação foi cancelada.<% } %>
                </p>
            </div>
            <% } %>

        </div>
    </div>

        </div>

        <!-- Sidebar de metadados -->
        <div class="space-y-5">

            <!-- Status atual -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-4">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Informações</h3>

                <div class="space-y-3">
                    <div>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Status</p>
                        <%
                            var statusColor = {
                                pendente:   'bg-yellow-100 text-yellow-800',
                                aprovado:   'bg-blue-100 text-blue-800',
                                'produção': 'bg-indigo-100 text-indigo-800',
                                'concluído':'bg-teal-100 text-teal-800',
                                finalizado: 'bg-green-100 text-green-800',
                                cancelado:  'bg-red-100 text-red-700',
                            };
                        %>
                        <span id="status-badge" class="inline-flex px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide
                            <%= statusColor[sol.status] || 'bg-gray-100 text-gray-700' %>">
                            <%= sol.status %>
                        </span>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Prioridade</p>
                        <span class="inline-flex items-center gap-1.5 text-sm font-semibold
                            <%= sol.prioridade === 'alta' ? 'text-red-600' : sol.prioridade === 'media' ? 'text-yellow-600' : 'text-gray-500' %>">
                            <% if(sol.prioridade === 'alta') { %>
                                <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
                            <% } else if(sol.prioridade === 'media') { %>
                                <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
                            <% } else { %>
                                <span class="w-2 h-2 rounded-full bg-gray-300"></span>
                            <% } %>
                            <%= sol.prioridade === 'alta' ? 'Alta — Urgente' : sol.prioridade === 'media' ? 'Média' : 'Baixa' %>
                        </span>
                    </div>

                    <div>
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Tipo de Mídia</p>
                        <span class="inline-flex px-2.5 py-1 bg-gray-100 text-gray-700 rounded-lg text-xs font-bold uppercase tracking-wide">
                            <%= sol.tipo_midia %>
                        </span>
                    </div>

                    <div class="pt-2 border-t border-gray-100">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Secretaria</p>
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-xs font-black"
                                 style="background-color: <%= sol.secretaria ? sol.secretaria.cor : '#6b7280' %>">
                                <%= sol.secretaria ? sol.secretaria.nome.charAt(0) : '?' %>
                            </div>
                            <span class="text-sm font-semibold text-gray-800"><%= sol.secretaria ? sol.secretaria.nome : '—' %></span>
                        </div>
                    </div>

                    <div class="pt-2 border-t border-gray-100">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Solicitado por</p>
                        <div class="flex items-center gap-2">
                            <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 text-xs font-black">
                                <%= sol.autor ? sol.autor.nome.charAt(0).toUpperCase() : '?' %>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-gray-800"><%= sol.autor ? sol.autor.nome : '—' %></p>
                                <p class="text-[10px] text-gray-400"><%= sol.autor ? sol.autor.email : '' %></p>
                            </div>
                        </div>
                    </div>

                    <div class="pt-2 border-t border-gray-100">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Criado em</p>
                        <p class="text-sm font-medium text-gray-700">
                            <%= new Date(sol.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
                        </p>
                        <p class="text-xs text-gray-400">
                            <%= new Date(sol.createdAt).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>
                        </p>
                    </div>

                    <% if(sol.updatedAt && sol.updatedAt !== sol.createdAt) { %>
                    <div class="pt-2 border-t border-gray-100">
                        <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Última atualização</p>
                        <p class="text-sm font-medium text-gray-700">
                            <%= new Date(sol.updatedAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                            às <%= new Date(sol.updatedAt).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }) %>
                        </p>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- Ações rápidas -->
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 space-y-2">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Ações</h3>
                <a href="/solicitacoes" class="flex items-center gap-2 w-full px-3 py-2 text-sm font-medium text-gray-600 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
                    Ver todas as solicitações
                </a>
                <a href="/solicitacoes/nova" class="flex items-center gap-2 w-full px-3 py-2 text-sm font-medium text-gray-600 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    Nova solicitação
                </a>
                <a href="/solicitacoes/<%= sol.id %>/editar" class="flex items-center gap-2 w-full px-3 py-2 text-sm font-medium text-gray-600 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                    Editar solicitação
                </a>
            </div>

        </div>
    </div>

    
</div>

<script>
(function() {
    var currentStatus = '<%= sol.status %>';
    var SOL_ID = <%= sol.id %>;

    var statusColors = {
        pendente:    'bg-yellow-100 text-yellow-800',
        aprovado:    'bg-blue-100 text-blue-800',
        'produção':  'bg-indigo-100 text-indigo-800',
        'concluído': 'bg-teal-100 text-teal-800',
        finalizado:  'bg-green-100 text-green-800',
        cancelado:   'bg-red-100 text-red-700',
    };

    var ETAPAS = [
        { key: 'pendente',   label: 'Pendente'   },
        { key: 'aprovado',   label: 'Aprovado'   },
        { key: 'produção',   label: 'Produção'   },
        { key: 'concluído',  label: 'Concluído'  },
        { key: 'finalizado', label: 'Finalizado' },
    ];

    var CHECKMARK = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>';

    /* ── Atualiza apenas o DOM (sem AJAX) ──────────────────────────── */
    function applyStatusToUI(status) {
        currentStatus = status;

        // Badge
        var badge = document.getElementById('status-badge');
        if (badge) {
            badge.textContent = status;
            badge.className = 'inline-flex px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide ' + (statusColors[status] || 'bg-gray-100 text-gray-700');
        }

        // Botões do painel
        document.querySelectorAll('[id^="btn-"]').forEach(function(btn) {
            var s = btn.id.replace('btn-', '');
            if (s === status) {
                btn.classList.add('ring-2', 'ring-offset-1', 'ring-current');
                btn.classList.remove('opacity-70');
            } else {
                btn.classList.remove('ring-2', 'ring-offset-1', 'ring-current');
                btn.classList.add('opacity-70');
            }
        });

        // Timeline
        var idx = ETAPAS.findIndex(function(e) { return e.key === status; });
        var isCanceled = status === 'cancelado';
        ETAPAS.forEach(function(etapa, i) {
            var isDone   = i < idx && !isCanceled;
            var isActive = i === idx && !isCanceled;
            var dot   = document.getElementById('tl-dot-' + i);
            var label = document.getElementById('tl-label-' + i);
            var line  = document.getElementById('tl-line-' + i);
            if (dot) {
                dot.className = 'w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold border-2 transition ' +
                    (isCanceled ? 'border-gray-200 bg-gray-50 text-gray-300' :
                     isDone     ? 'border-green-500 bg-green-500 text-white' :
                     isActive   ? 'border-blue-500 bg-blue-500 text-white'  :
                                  'border-gray-200 bg-white text-gray-300');
                dot.innerHTML = (!isCanceled && isDone) ? CHECKMARK : String(i + 1);
            }
            if (label) {
                label.className = 'text-[10px] font-bold uppercase tracking-wide ' +
                    (isCanceled ? 'text-gray-300' :
                     isDone     ? 'text-green-600' :
                     isActive   ? 'text-blue-600'  :
                                  'text-gray-400');
            }
            if (line) {
                line.className = 'h-0.5 flex-1 mx-1 mb-5 ' +
                    (isCanceled ? 'bg-gray-100' : isDone ? 'bg-green-400' : 'bg-gray-200');
            }
        });

        // Banners cancelado / finalizado
        var bCanc = document.getElementById('banner-cancelado');
        var bFin  = document.getElementById('banner-finalizado');
        if (bCanc) bCanc.classList.toggle('hidden', status !== 'cancelado');
        if (bFin)  bFin.classList.toggle('hidden',  status !== 'finalizado');
    }

    /* ── Recarrega seção de feed via fetch (sem reload de página) ──── */
    function refreshFeed() {
        fetch('/solicitacoes/' + SOL_ID)
            .then(function(r) { return r.text(); })
            .then(function(html) {
                var doc = new DOMParser().parseFromString(html, 'text/html');
                var newFeed = doc.getElementById('feed');
                var cur = document.getElementById('feed');
                if (newFeed && cur) cur.innerHTML = newFeed.innerHTML;
            })
            .catch(function() {});
    }

    /* ── setStatus (chama AJAX e depois atualiza UI) ──────────────── */
    window.setStatus = function(status) {
        if (status === currentStatus) return;
        fetch('/solicitacoes/' + SOL_ID + '/status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: status })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (!data.ok) { alert(data.error || 'Erro ao atualizar status'); return; }
            applyStatusToUI(status);
            refreshFeed();
            var msg = document.getElementById('status-msg');
            if (msg) {
                msg.classList.remove('hidden'); msg.classList.add('flex');
                setTimeout(function() { msg.classList.add('hidden'); msg.classList.remove('flex'); }, 3000);
            }
        })
        .catch(function() { alert('Erro de conexão.'); });
    };

    /* ── SSE handler ──────────────────────────────────────────────── */
    window.onSSEUpdate = function(data) {
        if (data.type === 'solicitacao_status' && data.id === SOL_ID) {
            if (data.status === currentStatus) return;
            applyStatusToUI(data.status);
            refreshFeed();
        }
        if (data.type === 'solicitacao_comentario' && data.id === SOL_ID) {
            refreshFeed();
        }
    };

    /* ── Utilitários ──────────────────────────────────────────────── */
    window.showFilePreview = function(input) {
        if (input.files && input.files[0]) {
            document.getElementById('file-name').textContent = input.files[0].name;
            document.getElementById('file-preview').classList.remove('hidden');
        }
    };

    window.clearFile = function() {
        document.getElementById('arquivo-input').value = '';
        document.getElementById('file-preview').classList.add('hidden');
    };

    if (window.location.hash === '#feed') {
        setTimeout(function() {
            var el = document.getElementById('feed');
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 150);
    }
}());
</script>
