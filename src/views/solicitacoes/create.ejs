<script>
document.addEventListener('alpine:init', function() {
    Alpine.data('solCreateForm', function() {
        return {
            criarEvento: false,
            selectedSec: <%- (user.role === 'secretaria' || user.role === 'secom') && user.secretaria_id ? user.secretaria_id : 'null' %>,
            allUsers: <%- JSON.stringify(users.map(function(u){ return { id: u.id, nome: u.nome, secretaria_id: u.secretaria_id }; })) %>,
            responsaveis: [],
            tiposSelecionados: [],
            get filteredUsers() {
                if (!this.selectedSec) return this.allUsers;
                var sec = this.selectedSec;
                return this.allUsers.filter(function(u){ return u.secretaria_id == sec; });
            },
            toggleResp: function(id) {
                var i = this.responsaveis.indexOf(id);
                if (i >= 0) this.responsaveis.splice(i, 1); else this.responsaveis.push(id);
            },
            isResp: function(id) { return this.responsaveis.indexOf(id) >= 0; },
            toggleTipo: function(v) {
                var i = this.tiposSelecionados.indexOf(v);
                if (i >= 0) this.tiposSelecionados.splice(i, 1); else this.tiposSelecionados.push(v);
            },
            isTipo: function(v) { return this.tiposSelecionados.indexOf(v) >= 0; },
            get tiposLabel() {
                if (this.tiposSelecionados.length === 0) return 'Selecione os tipos…';
                return this.tiposSelecionados.join(', ');
            },
        };
    });
});
</script>

<div class="max-w-6xl mx-auto space-y-5" x-data="solCreateForm">
    <div class="flex items-center gap-3">
        <a href="/solicitacoes" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </a>
        <div>
            <h1 class="text-xl font-bold text-gray-900">Abrir Chamado</h1>
            <p class="text-sm text-gray-500 mt-0.5">Solicite produção de material à equipe de comunicação.</p>
        </div>
    </div>

    <form action="/solicitacoes" method="POST" class="bg-white rounded-xl border border-gray-200 shadow-sm">

        <!-- 2-column grid -->
        <div class="p-6 grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-x-8 gap-y-5">

            <!-- ─── Coluna esquerda ─── -->
            <div class="space-y-5">

                <div id="tour-titulo">
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Título <span class="text-red-500">*</span></label>
                    <input type="text" name="titulo" required placeholder="Ex: Nota sobre abertura de inscrições"
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
                </div>

                <div id="tour-descricao" class="flex-1">
                    <label class="block text-sm font-semibold text-gray-700 mb-1.5">Descrição / Briefing <span class="text-red-500">*</span></label>
                    <textarea name="descricao" required rows="14"
                        placeholder="Descreva com detalhes o que precisa ser produzido: contexto, público-alvo, referências visuais, informações importantes e qualquer prazo relevante..."
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition resize-y min-h-[280px]"></textarea>
                    <p class="text-xs text-gray-400 mt-1">Quanto mais detalhes, melhor o resultado da produção.</p>
                </div>

            </div>

            <!-- ─── Coluna direita ─── -->
            <div class="space-y-5">

                <div class="bg-gray-50 rounded-xl border border-gray-100 p-5 space-y-5">

                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Configurações do Chamado</p>

                    <!-- Tipos de Mídia -->
                    <div id="tour-tipos">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            Tipo(s) de Mídia <span class="text-red-500">*</span>
                        </label>
                        <p class="text-xs text-gray-400 mb-2">Selecione um ou mais — cada tipo vira uma demanda separada.</p>
                        <div class="flex flex-wrap gap-2">
                            <% ['Nota','Release','Post para Redes Sociais','Arte Gráfica','Vídeo','Foto','Outros'].forEach(function(tipo) { %>
                            <button type="button" @click="toggleTipo('<%= tipo %>')"
                                class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border text-sm font-medium transition select-none"
                                :class="isTipo('<%= tipo %>')
                                    ? 'bg-blue-600 text-white border-blue-600 shadow-sm'
                                    : 'bg-white text-gray-700 border-gray-300 hover:border-blue-400 hover:text-blue-600'">
                                <svg x-show="isTipo('<%= tipo %>')" class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                <%= tipo %>
                            </button>
                            <% }) %>
                        </div>
                        <p x-show="tiposSelecionados.length === 0" class="mt-2 text-xs text-red-400">Selecione pelo menos um tipo de mídia.</p>
                        <p x-show="tiposSelecionados.length > 1" class="mt-2 text-xs text-blue-600 font-medium">
                            <svg class="w-3.5 h-3.5 inline -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Serão criadas <span x-text="tiposSelecionados.length"></span> demandas separadas.
                        </p>
                        <template x-for="t in tiposSelecionados" :key="t">
                            <input type="hidden" name="tipos_midia" :value="t">
                        </template>
                    </div>

                    <!-- Prioridade + Prazo -->
                    <div id="tour-finalizar" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Prioridade <span class="text-red-500">*</span></label>
                            <select name="prioridade" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                                <option value="baixa">Baixa</option>
                                <option value="media" selected>Média</option>
                                <option value="alta">Alta — Urgente</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1.5">
                                Prazo de Entrega
                                <span class="text-gray-400 font-normal">(opcional)</span>
                            </label>
                            <input type="date" name="prazo"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 bg-white focus:ring-2 focus:ring-orange-500 focus:border-orange-500 outline-none transition text-sm">
                        </div>
                    </div>

                    <% if(['admin', 'secom', 'super_admin'].includes(user.role)) { %>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Secretaria <span class="text-red-500">*</span></label>
                        <select name="secretaria_id" required
                            @change="selectedSec = parseInt($event.target.value) || null; responsaveis = []"
                            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 bg-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                            <option value="">Selecione...</option>
                            <% secretarias.forEach(function(s) { %>
                                <option value="<%= s.id %>"><%= s.nome %></option>
                            <% }) %>
                        </select>
                    </div>
                    <% } %>

                </div>

                <!-- Criar Evento Toggle -->
                <div class="border border-gray-200 rounded-xl overflow-hidden">
                    <button type="button" @click="criarEvento = !criarEvento"
                        class="w-full flex items-center gap-3 px-4 py-3 text-left transition"
                        :class="criarEvento ? 'bg-purple-50 border-b border-purple-200' : 'bg-gray-50 hover:bg-gray-100'">
                        <div class="w-5 h-5 rounded border-2 flex items-center justify-center shrink-0 transition"
                            :class="criarEvento ? 'border-purple-600 bg-purple-600' : 'border-gray-400 bg-white'">
                            <svg x-show="criarEvento" class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-gray-800">Criar evento também</p>
                            <p class="text-xs text-gray-500">Cadastrar um evento no calendário ao abrir este chamado.</p>
                        </div>
                        <svg class="w-4 h-4 text-gray-400 transition-transform shrink-0" :class="criarEvento ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    <input type="hidden" name="criar_evento" :value="criarEvento ? '1' : '0'">

                    <div x-show="criarEvento" x-cloak class="p-4 space-y-4 bg-white">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Início <span class="text-red-500">*</span></label>
                                <input type="datetime-local" name="data_inicio" :required="criarEvento"
                                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">Fim <span class="text-red-500">*</span></label>
                                <input type="datetime-local" name="data_fim" :required="criarEvento"
                                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition text-sm">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Local</label>
                            <input type="text" name="local" placeholder="Ex: Teatro Municipal"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Evento <span class="text-red-500">*</span></label>
                            <select name="tipo_evento" :required="criarEvento"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none transition text-sm">
                                <option value="">Selecione...</option>
                                <option value="Coletiva de Imprensa">Coletiva de Imprensa</option>
                                <option value="Inauguração">Inauguração</option>
                                <option value="Cerimônia">Cerimônia</option>
                                <option value="Reunião">Reunião</option>
                                <option value="Evento Cultural">Evento Cultural</option>
                                <option value="Ação Social">Ação Social</option>
                                <option value="Outros">Outros</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Responsáveis pelo Evento</label>
                            <div x-show="filteredUsers.length > 0" class="flex flex-wrap gap-2">
                                <template x-for="u in filteredUsers" :key="u.id">
                                    <button type="button" @click="toggleResp(u.id)"
                                        class="flex items-center gap-2 px-3 py-1.5 rounded-full border text-sm font-medium transition select-none"
                                        :class="isResp(u.id) ? 'bg-purple-600 text-white border-purple-600 shadow-sm' : 'bg-white text-gray-700 border-gray-300 hover:border-purple-400'">
                                        <span class="w-5 h-5 rounded-full flex items-center justify-center text-[11px] font-bold"
                                            :class="isResp(u.id) ? 'bg-purple-500 text-white' : 'bg-gray-100 text-gray-500'"
                                            x-text="u.nome.charAt(0)"></span>
                                        <span x-text="u.nome"></span>
                                    </button>
                                </template>
                            </div>
                            <p x-show="filteredUsers.length === 0" class="text-sm text-gray-400 italic">Nenhum usuário disponível.</p>
                            <template x-for="id in responsaveis" :key="id">
                                <input type="hidden" name="responsaveis[]" :value="id">
                            </template>
                        </div>
                    </div>
                </div>

            </div>

        </div>

        <div class="px-6 py-4 border-t border-gray-100 flex justify-between items-center bg-gray-50 rounded-b-xl">
            <a href="/solicitacoes" class="px-5 py-2.5 rounded-lg border border-gray-300 text-gray-600 font-medium hover:bg-white transition text-sm">Cancelar</a>
            <button type="submit"
                :disabled="tiposSelecionados.length === 0"
                :class="tiposSelecionados.length === 0 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-700'"
                class="px-6 py-2.5 bg-blue-600 text-white rounded-lg font-semibold transition shadow-sm inline-flex items-center gap-2 text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span x-text="tiposSelecionados.length > 1 ? 'Criar ' + tiposSelecionados.length + ' Demandas' : 'Enviar Solicitação'"></span>
            </button>
        </div>
    </form>
</div>
