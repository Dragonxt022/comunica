<div class="space-y-6">
    <div class="flex items-center gap-3">
        <a href="/solicitacoes/<%= sol.id %>" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Editar Solicitação <span class="text-gray-400 font-normal">#<%= sol.id %></span></h2>
            <p class="text-gray-500 text-sm">Atualize as informações do chamado.</p>
        </div>
    </div>

    <form action="/solicitacoes/<%= sol.id %>/editar" method="POST" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título <span class="text-red-500">*</span></label>
            <input type="text" name="titulo" required value="<%= sol.titulo %>"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Descrição / Briefing <span class="text-red-500">*</span></label>
            <textarea name="descricao" required rows="4"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition resize-none"><%= sol.descricao %></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de Mídia <span class="text-red-500">*</span></label>
                <select name="tipo_midia" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
                    <option value="">Selecione...</option>
                    <% ['Nota','Release','Post para Redes Sociais','Arte Gráfica','Vídeo','Foto','Outros'].forEach(function(t) { %>
                        <option value="<%= t %>" <%= sol.tipo_midia === t ? 'selected' : '' %>><%= t %></option>
                    <% }) %>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Prioridade <span class="text-red-500">*</span></label>
                <select name="prioridade" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
                    <option value="baixa" <%= sol.prioridade === 'baixa' ? 'selected' : '' %>>Baixa</option>
                    <option value="media" <%= sol.prioridade === 'media' ? 'selected' : '' %>>Média</option>
                    <option value="alta"  <%= sol.prioridade === 'alta'  ? 'selected' : '' %>>Alta — Urgente</option>
                </select>
            </div>
        </div>

        <% if(user.role === 'admin' || user.role === 'secom') { %>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Secretaria <span class="text-red-500">*</span></label>
            <select name="secretaria_id" required class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition">
                <option value="">Selecione...</option>
                <% secretarias.forEach(function(s) { %>
                    <option value="<%= s.id %>" <%= sol.secretaria_id == s.id ? 'selected' : '' %>><%= s.nome %></option>
                <% }) %>
            </select>
        </div>
        <% } %>

        <div class="pt-2 flex justify-end gap-3">
            <a href="/solicitacoes/<%= sol.id %>" class="px-5 py-2.5 rounded-lg border border-gray-300 text-gray-600 font-medium hover:bg-gray-50 transition">Cancelar</a>
            <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Salvar Alterações
            </button>
        </div>
    </form>
</div>
