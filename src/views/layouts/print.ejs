<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Relatório' %></title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            font-size: 10pt;
            color: #1a1a1a;
            background: white;
        }

        @page {
            size: A4 portrait;
            margin: 14mm 14mm 16mm 14mm;
        }

        .page-wrap {
            width: 210mm;
            min-height: 297mm;
            margin: 0 auto;
            padding: 14mm 12mm;
        }

        /* Cabeçalho */
        .report-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            padding-bottom: 10pt;
            border-bottom: 2.5pt solid #1e293b;
            margin-bottom: 14pt;
        }
        .report-header .brand { font-size: 18pt; font-weight: 800; color: #1e293b; }
        .report-header .brand-sub { font-size: 8pt; color: #64748b; margin-top: 2pt; }
        .report-header .meta  { text-align: right; font-size: 8pt; color: #64748b; line-height: 1.7; }

        h1.report-title {
            font-size: 13pt;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 3pt;
        }
        .report-subtitle { font-size: 9pt; color: #64748b; margin-bottom: 14pt; }

        /* Cards de sumário */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 7pt;
            margin-bottom: 14pt;
        }
        .summary-card {
            border: 0.5pt solid #e2e8f0;
            border-radius: 5pt;
            padding: 8pt 10pt;
            background: #f8fafc;
        }
        .summary-card .num  { font-size: 20pt; font-weight: 800; color: #1e293b; line-height: 1; }
        .summary-card .lbl  { font-size: 7.5pt; color: #64748b; margin-top: 2pt; }
        .summary-card.accent-green  { border-left: 3pt solid #16a34a; }
        .summary-card.accent-blue   { border-left: 3pt solid #2563eb; }
        .summary-card.accent-teal   { border-left: 3pt solid #0d9488; }
        .summary-card.accent-amber  { border-left: 3pt solid #d97706; }

        /* Gráficos */
        .charts-row {
            display: grid;
            grid-template-columns: 1fr 1.3fr 1.3fr;
            gap: 8pt;
            margin-bottom: 18pt;
            page-break-inside: avoid;
        }
        .chart-card {
            border: 0.5pt solid #e2e8f0;
            border-radius: 5pt;
            padding: 8pt;
            background: #fafafa;
        }
        .chart-card-title {
            font-size: 8pt;
            font-weight: 700;
            color: #475569;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 6pt;
            text-align: center;
        }
        .chart-card canvas { display: block; margin: 0 auto; }

        /* Seções */
        .section { margin-bottom: 18pt; }
        .section-title {
            font-size: 11pt;
            font-weight: 700;
            color: #1e293b;
            border-bottom: 1pt solid #e2e8f0;
            padding-bottom: 4pt;
            margin-bottom: 8pt;
        }

        /* Seção por secretaria */
        .sec-section {
            page-break-inside: avoid;
            margin-bottom: 16pt;
        }
        .sec-section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 5pt 10pt;
            border-radius: 4pt 4pt 0 0;
            margin-bottom: 0;
            background: #f1f5f9;
            border-left: 4pt solid #94a3b8;
        }
        .sec-section-nome {
            font-size: 9.5pt;
            font-weight: 700;
            color: #1e293b;
        }
        .sec-section-count {
            font-size: 8pt;
            color: #64748b;
            font-weight: 600;
        }
        .sec-stats {
            display: flex;
            gap: 10pt;
            margin: 4pt 0 0 0;
            padding: 3pt 10pt;
            background: #f8fafc;
            border-left: 4pt solid #94a3b8;
        }
        .sec-stat-item { font-size: 7.5pt; color: #64748b; }
        .sec-stat-item strong { color: #1e293b; }

        /* Tabela */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 8.5pt;
            page-break-inside: auto;
        }
        thead { background: #f1f5f9; }
        th {
            padding: 4pt 6pt;
            text-align: left;
            font-size: 7.5pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #475569;
            border-bottom: 1pt solid #cbd5e1;
        }
        td {
            padding: 4pt 6pt;
            vertical-align: middle;
            border-bottom: 0.5pt solid #e2e8f0;
            line-height: 1.4;
        }
        tr:last-child td { border-bottom: none; }
        tr { page-break-inside: avoid; }

        /* Badges */
        .badge {
            display: inline-block;
            padding: 1.5pt 5pt;
            border-radius: 20pt;
            font-size: 7.5pt;
            font-weight: 700;
        }
        .badge-pub     { background: #dcfce7; color: #166534; }
        .badge-pend    { background: #fef9c3; color: #854d0e; }
        .badge-prod    { background: #dbeafe; color: #1d4ed8; }
        .badge-conc    { background: #ccfbf1; color: #134e4a; }
        .badge-canc    { background: #fee2e2; color: #991b1b; }
        .badge-sec     { display: inline-block; padding: 1.5pt 5pt; border-radius: 20pt; font-size: 7.5pt; font-weight: 700; }

        /* Arte final */
        .arte-final-img {
            max-width: 52pt;
            max-height: 40pt;
            object-fit: cover;
            border-radius: 3pt;
            border: 0.5pt solid #e2e8f0;
        }
        .link-pub { color: #2563eb; font-size: 8pt; }

        /* Divisor de página antes de cada secretaria (quando muitas) */
        .sec-page-break { page-break-before: auto; }

        /* Rodapé */
        .report-footer {
            margin-top: 20pt;
            padding-top: 8pt;
            border-top: 0.5pt solid #e2e8f0;
            font-size: 7.5pt;
            color: #94a3b8;
            display: flex;
            justify-content: space-between;
        }

        .empty-msg { color: #94a3b8; font-style: italic; font-size: 9pt; padding: 8pt 0; }

        @media print {
            .page-wrap { padding: 0; }
            .no-print { display: none; }
        }
    </style>
</head>
<body>
<div class="page-wrap">
    <%- body %>
</div>
<script>
    window.onload = function() {
        setTimeout(function() { window.print(); }, 900);
    };
</script>
</body>
</html>
