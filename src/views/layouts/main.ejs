<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comunica — <%= typeof title !== 'undefined' ? title : 'Plataforma de Comunicação' %></title>
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="<%= config && config.titulo_site ? config.titulo_site : 'Comunica' %>">
    <meta name="theme-color" content="#0f172a">
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <% if(user) { %><script src="/js/chat.js"></script><% } %>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <% if(typeof useQuill !== 'undefined' && useQuill) { %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css">
    <style>
        .ql-container { font-size: 15px; font-family: 'Inter', sans-serif; }
        .ql-editor { min-height: 320px; }
        .ql-toolbar { border-radius: 8px 8px 0 0; border-color: #d1d5db !important; background: #f9fafb; }
        .ql-container { border-radius: 0 0 8px 8px; border-color: #d1d5db !important; }
        .ql-editor.ql-blank::before { color: #9ca3af; font-style: normal; }
    </style>
    <% } %>
    <style>
        body { font-family: 'Inter', sans-serif; }
        [x-cloak] { display: none !important; }
        aside nav, main { scrollbar-width: none; -ms-overflow-style: none; }
        aside nav::-webkit-scrollbar, main::-webkit-scrollbar { display: none; }

        /* ── Sidebar collapsed ──────────────────────────────────────────── */
        aside[data-collapsed="true"] .nav-label         { display: none; }
        aside[data-collapsed="true"] .nav-section-label { display: none; }
        aside[data-collapsed="true"] .nav-badge         { display: none !important; }
        aside[data-collapsed="true"] .sidebar-user-info  { display: none; }
        aside[data-collapsed="true"] .sidebar-logout-btn { display: none; }
        aside[data-collapsed="true"] nav a.nav-link      { justify-content: center; gap: 0; padding-left: 0.5rem; padding-right: 0.5rem; }
        aside[data-collapsed="true"] a.nav-btn-chamado   { justify-content: center; gap: 0; padding-left: 0.5rem; padding-right: 0.5rem; }
        aside[data-collapsed="true"] .sidebar-footer     { justify-content: center; padding-left: 0.5rem; padding-right: 0.5rem; }

        /* ── Quick access chips ─────────────────────────────────────────── */
        .qa-chip {
            display: inline-flex; align-items: center;
            padding: 0.25rem 0.625rem;
            font-size: 0.7rem; font-weight: 500; white-space: nowrap;
            color: #4b5563; background: #f3f4f6;
            border-radius: 9999px; border: 1px solid transparent;
            transition: background 0.15s, color 0.15s, border-color 0.15s;
            text-decoration: none;
        }
        .qa-chip:hover { background: #e0e7ff; color: #4338ca; border-color: #c7d2fe; }
    </style>
</head>
<body class="bg-gray-50 h-screen flex overflow-hidden"
      x-data="{ sidebarOpen: false, sc: localStorage.getItem('sc') === '1' }">

    <!-- Mobile backdrop -->
    <div
        x-show="sidebarOpen"
        x-cloak
        class="fixed inset-0 bg-black/40 z-30 lg:hidden"
        @click="sidebarOpen = false">
    </div>

    <!-- Sidebar -->
    <aside
        :data-collapsed="sc ? 'true' : 'false'"
        :class="[sidebarOpen ? 'translate-x-0' : '-translate-x-full', sc ? 'w-14' : 'w-56']"
        class="fixed inset-y-0 left-0 z-40 bg-slate-900 flex flex-col transition-all duration-300 lg:translate-x-0 lg:static lg:shrink-0">

        <!-- Logo / Toggle -->
        <div class="border-b border-slate-800/60 shrink-0">
            <!-- Expandido: logo + título + botão recolher -->
            <div x-show="!sc" class="px-4 py-4 flex items-center gap-2.5">
                <img src="/icon.svg" alt="Comunica" class="w-7 h-7 shrink-0">
                <span class="text-white font-semibold text-sm truncate flex-1">
                    <%= config && config.titulo_site ? config.titulo_site : 'Comunica' %>
                </span>
                <button @click="sc = true; localStorage.setItem('sc', '1')"
                    title="Recolher menu"
                    class="shrink-0 p-1 text-slate-500 hover:text-slate-200 hover:bg-white/10 rounded-md transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
                    </svg>
                </button>
            </div>
            <!-- Recolhido: somente ícone para expandir -->
            <button x-show="sc" x-cloak
                @click="sc = false; localStorage.setItem('sc', '0')"
                title="Expandir menu"
                class="w-full py-[1.125rem] flex items-center justify-center text-slate-400 hover:text-white transition">
                <img src="/icon.svg" alt="Comunica" class="w-7 h-7">
            </button>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-2 py-3 space-y-0.5 overflow-y-auto">

            <a id="tour-btn-chamado" href="/solicitacoes/nova"
               class="nav-btn-chamado flex items-center justify-center gap-2 mx-1 mb-3 px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white text-[12px] font-semibold rounded-lg transition shadow-sm"
               title="Abrir Chamado">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
                <span class="nav-label">Abrir Chamado</span>
            </a>

            <a href="/" title="Dashboard"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path === '/' ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                <span class="nav-label">Dashboard</span>
            </a>

            <a href="/eventos" title="Calendário"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/eventos') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span class="nav-label">Calendário</span>
            </a>

            <a href="/planejamento" title="Planejamento"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/planejamento') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                <span class="nav-label">Planejamento</span>
            </a>

            <% if(user && (user.role === 'admin' || user.role === 'secom' || user.role === 'secretaria' || user.role === 'super_admin')) { %>
            <a href="/inscricoes" title="Inscrições"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path === '/inscricoes' ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="nav-label">Inscrições</span>
            </a>
            <% } %>

            <a id="tour-nav-sol" href="/solicitacoes" title="Solicitações"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/solicitacoes') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <span class="nav-label flex-1">Solicitações</span>
                <span id="nav-sol-badge" class="nav-badge hidden min-w-[18px] h-[18px] bg-orange-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center px-1 leading-none"></span>
            </a>

            <% if(user && user.role !== 'secretaria') { %>
            <a href="/releases" title="Releases"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/releases') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM15 4v4h4"></path></svg>
                <span class="nav-label">Releases</span>
            </a>
            <% } %>

            <a href="/biblioteca" title="Biblioteca"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/biblioteca') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span class="nav-label">Biblioteca</span>
            </a>

            <% if(user && (user.role === 'admin' || user.role === 'secom' || user.role === 'super_admin')) { %>
            <a href="/relatorios" title="Relatórios"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/relatorios') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <span class="nav-label">Relatórios</span>
            </a>
            <a href="/formularios" title="Form. Inscrição"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/formularios') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                <span class="nav-label">Form. Inscrição</span>
            </a>
            <% } %>

            <div class="pt-4 pb-1.5">
                <p class="nav-section-label px-3 text-[10px] font-semibold text-slate-600 uppercase tracking-widest">Público</p>
            </div>
            <a href="/imprensa/agenda" title="Agenda Imprensa"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/imprensa') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                <span class="nav-label">Agenda Imprensa</span>
            </a>

            <% if(user && (user.role === 'admin' || user.role === 'super_admin')) { %>
            <div class="pt-4 pb-1.5">
                <p class="nav-section-label px-3 text-[10px] font-semibold text-slate-600 uppercase tracking-widest">Sistema</p>
            </div>
            <% if(user.role === 'super_admin') { %>
            <a href="/admin/municipios" title="Municípios"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/admin/municipios') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="nav-label">Municípios</span>
            </a>
            <% } %>
            <a href="/admin/secretarias" title="Secretarias"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/admin/secretarias') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                <span class="nav-label">Secretarias</span>
            </a>
            <a href="/admin/usuarios" title="Usuários"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/admin/usuarios') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                <span class="nav-label">Usuários</span>
            </a>
            <a href="/admin/configuracoes" title="Configurações"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/admin/configuracoes') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                <span class="nav-label">Configurações</span>
            </a>
            <a href="/admin/armazenamento" title="Armazenamento"
               class="nav-link flex items-center gap-2.5 px-3 py-2 rounded-md text-[13px] font-medium transition-colors <%= path.startsWith('/admin/armazenamento') ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-slate-100 hover:bg-white/5' %>">
                <svg class="w-[15px] h-[15px] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/></svg>
                <span class="nav-label">Armazenamento</span>
            </a>
            <% } %>
        </nav>

        <!-- User footer -->
        <% if(user) { %>
        <div class="sidebar-footer px-3 py-3 border-t border-slate-800/60 flex items-center gap-2 shrink-0">
            <a href="/perfil" class="w-7 h-7 rounded-full overflow-hidden shrink-0 transition ring-1 ring-slate-700 hover:ring-slate-500" title="Meu perfil">
                <% if(user.avatar) { %>
                <img src="<%= user.avatar %>" alt="Avatar" class="w-full h-full object-cover">
                <% } else { %>
                <span class="w-full h-full bg-slate-700 hover:bg-slate-600 flex items-center justify-center text-slate-200 text-xs font-bold transition"><%= user.nome.charAt(0).toUpperCase() %></span>
                <% } %>
            </a>
            <div class="sidebar-user-info min-w-0 flex-1">
                <a href="/perfil" class="text-[12px] text-slate-200 font-medium truncate leading-tight hover:text-white block transition"><%= user.nome %></a>
                <p class="text-[10px] text-slate-500 leading-tight capitalize"><%= user.role %></p>
            </div>
            <a href="/logout" title="Sair"
               class="sidebar-logout-btn p-1.5 text-slate-500 hover:text-slate-200 hover:bg-white/10 rounded-md transition shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
            </a>
        </div>
        <% } %>
    </aside>

    <!-- Wrapper direito -->
    <div class="flex-1 flex flex-col overflow-hidden min-w-0">

        <!-- Topbar -->
        <header class="bg-white border-b border-gray-200 px-4 py-2.5 flex items-center gap-3 shrink-0 z-20">
            <!-- Hamburger mobile -->
            <button @click="sidebarOpen = !sidebarOpen" class="lg:hidden p-1.5 hover:bg-gray-100 rounded-md">
                <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
            <img src="/icon.svg" alt="Comunica" class="lg:hidden w-6 h-6">
            <span class="lg:hidden text-sm font-semibold text-gray-800 truncate">
                <%= config && config.titulo_site ? config.titulo_site : 'Comunica' %>
            </span>

            <!-- Quick Access (desktop only) -->
            <div id="qa-links" class="hidden lg:flex items-center gap-1 ml-1 overflow-x-auto" style="max-width:420px;scrollbar-width:none"></div>

            <div class="flex-1"></div>

            <% if (user && user.role === 'super_admin' && typeof municipiosNav !== 'undefined' && municipiosNav.length > 0) { %>
            <form method="POST" action="/admin/municipio-ativo" id="form-mun-nav" class="hidden sm:block">
                <div class="relative">
