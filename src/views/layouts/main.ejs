    <% if(user) { %>
    <script>
    (function() {
        var _currentUserId = <%= user.id %>;

        /* ── Toast ────────────────────────────────────────────────── */
        window.showToast = function(msg, type) {
            var bg = type === 'success' ? 'bg-green-600'
                   : type === 'warning' ? 'bg-orange-500'
                   : 'bg-gray-800';
            var t = document.createElement('div');
            t.className = 'pointer-events-auto flex items-center gap-2 px-4 py-3 rounded-xl shadow-lg text-sm font-semibold text-white max-w-sm opacity-0 translate-y-2 transition-all duration-300 ' + bg;
            t.textContent = msg;
            var c = document.getElementById('toast-container');
            if (!c) return;
            c.appendChild(t);
            requestAnimationFrame(function() {
                requestAnimationFrame(function() { t.classList.remove('opacity-0','translate-y-2'); });
            });
            setTimeout(function() {
                t.classList.add('opacity-0','translate-y-2');
                setTimeout(function() { t.remove(); }, 300);
            }, 4500);
        };

        /* ── SSE ───────────────────────────────────────────────────── */
        var _sseDropped = false;

        function dispatchChat(name, data) {
            // name = 'chat-msg', 'chat-conversa', 'chat-lida', 'chat-digitando', 'chat-reconectado'
            window.dispatchEvent(new CustomEvent(name, { detail: data }));
        }

        function connect() {
            var es = new EventSource('/sse');

            es.addEventListener('connected', function() {
                if (_sseDropped) {
                    _sseDropped = false;
                    dispatchChat('chat-reconectado', {});
                }
            });

            es.addEventListener('update', function(e) {
                try {
                    var data = JSON.parse(e.data);
                    if (window.onSSEUpdate) window.onSSEUpdate(data);
                    document.dispatchEvent(new CustomEvent('comunica:sseData', { detail: data }));
                    if (data.updatedById !== _currentUserId) {
                        var msg = '';
                        if (data.type === 'solicitacao_status') {
                            msg = data.updatedBy + ' alterou o chamado #' + data.id + ' → "' + data.status + '"';
                        } else if (data.type === 'solicitacao_comentario') {
                            msg = data.autor + ' comentou no chamado #' + data.id;
                        } else if (data.type === 'evento_status') {
                            msg = data.updatedBy + ' alterou status de evento → "' + data.status + '"';
                        }
                        if (msg) window.showToast(msg, 'info');
                    }
                } catch(err) {}
            });

            // Chat: direct mapping to the event names Alpine widget listens for
            es.addEventListener('chat:mensagem', function(e) {
                try { dispatchChat('chat-msg', JSON.parse(e.data)); } catch(err) {}
            });
            es.addEventListener('chat:nova_conversa', function(e) {
                try { dispatchChat('chat-conversa', JSON.parse(e.data)); } catch(err) {}
            });
            es.addEventListener('chat:lida', function(e) {
                try { dispatchChat('chat-lida', JSON.parse(e.data)); } catch(err) {}
            });
            es.addEventListener('chat:digitando', function(e) {
                try { dispatchChat('chat-digitando', JSON.parse(e.data)); } catch(err) {}
            });

            es.onerror = function() { _sseDropped = true; };
        }
        connect();

        /* ── Push Notifications ────────────────────────────────────── */
        async function urlBase64ToUint8Array(base64String) {
            var padding = '='.repeat((4 - base64String.length % 4) % 4);
            var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
            var raw = atob(base64);
            var arr = new Uint8Array(raw.length);
            for (var i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
            return arr;
        }

        async function registerPush() {
            if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
            try {
                var reg = await navigator.serviceWorker.register('/sw.js');
                var existing = await reg.pushManager.getSubscription();
                if (existing) return;
                var res = await fetch('/push/vapid-public-key');
                var { key } = await res.json();
                if (!key) return;
                var sub = await reg.pushManager.subscribe({
                    userVisibleOnly: true,
                    applicationServerKey: await urlBase64ToUint8Array(key),
                });
                await fetch('/push/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(sub.toJSON()),
                });
            } catch(e) {}
        }

        var overlay = document.getElementById('push-permission-overlay');
        var btnAtivar = document.getElementById('btn-push-ativar');
        var btnPular  = document.getElementById('btn-push-pular');

        async function marcarAsked() {
            await fetch('/push/mark-asked', { method: 'POST' }).catch(() => {});
        }

        if (overlay && typeof Notification !== 'undefined' && Notification.permission === 'granted') {
            marcarAsked().then(() => registerPush());
            overlay.remove();
        }

        if (btnAtivar) {
            btnAtivar.addEventListener('click', async function() {
                btnAtivar.disabled = true;
                btnAtivar.textContent = 'Aguardando…';
                var permission = await Notification.requestPermission();
                if (permission === 'granted') await registerPush();
                await marcarAsked();
                if (overlay) overlay.remove();
            });
        }

        if (btnPular) {
            btnPular.addEventListener('click', async function() {
                await marcarAsked();
                if (overlay) overlay.remove();
            });
        }

        <% if(user && user.pushPermissionAsked) { %>
        if (typeof Notification !== 'undefined' && Notification.permission === 'granted') registerPush();
        <% } %>

        /* ── Quick Access ──────────────────────────────────────────── */
        (function() {
            var QA_LABELS = {
                '/': 'Dashboard',
                '/eventos': 'Calendário',
                '/planejamento': 'Planejamento',
                '/solicitacoes': 'Solicitações',
                '/releases': 'Releases',
                '/biblioteca': 'Biblioteca',
                '/relatorios': 'Relatórios',
                '/formularios': 'Formulários',
                '/imprensa': 'Imprensa',
                '/inscricoes': 'Inscrições',
            };

            function basePath(p) {
                if (p === '/' || p === '') return '/';
                var m = p.match(/^\/[^\/]*/);
                return m ? m[0] : p;
            }

            var curPath = basePath(window.location.pathname);

            try {
                var raw = localStorage.getItem('qa_v');
                var counts = raw ? JSON.parse(raw) : {};
                if (QA_LABELS[curPath]) {
                    counts[curPath] = (counts[curPath] || 0) + 1;
                    localStorage.setItem('qa_v', JSON.stringify(counts));
                }

                var container = document.getElementById('qa-links');
                if (!container) return;

                var entries = Object.keys(counts)
                    .filter(function(k) { return k !== curPath && QA_LABELS[k]; })
                    .sort(function(a, b) { return counts[b] - counts[a]; })
                    .slice(0, 4);

                if (entries.length < 2) return;

                var sep = '<span class="text-gray-300 text-xs select-none mx-0.5">·</span>';
                container.innerHTML = sep + entries.map(function(p) {
                    return '<a href="' + p + '" class="qa-chip">' + QA_LABELS[p] + '</a>';
                }).join(sep);
            } catch(e) {}
        }());

    }());
    </script>
    <% } %>

    <% if(user && (user.role === 'admin' || user.role === 'secom' || user.role === 'super_admin')) { %>
    <script>
    (function() {
        var badge = document.getElementById('nav-sol-badge');
        if (!badge) return;
        function atualizarBadge() {
            fetch('/solicitacoes/pendentes-count').then(function(r){ return r.json(); }).then(function(d) {
                if (d.count > 0) {
                    badge.textContent = d.count > 99 ? '99+' : d.count;
                    badge.classList.remove('hidden');
                    badge.classList.add('flex');
                } else {
                    badge.classList.add('hidden');
                    badge.classList.remove('flex');
                }
            }).catch(function(){});
        }
        atualizarBadge();
        document.addEventListener('comunica:sseData', function(e) {
            if (e.detail && e.detail.type === 'solicitacao_status') atualizarBadge();
        });
    }());
    </script>
    <% } %>

    <% if(user) { %>
    <script>
    function notifBell() {
        var ICONS = {
            solicitacao_nova:       '/icons/notif/sol-nova.svg',
            solicitacao_producao:   '/icons/notif/sol-producao.svg',
            solicitacao_concluida:  '/icons/notif/sol-concluida.svg',
            solicitacao_aprovada:   '/icons/notif/sol-aprovada.svg',
            solicitacao_revisao:    '/icons/notif/sol-revisao.svg',
            solicitacao_comentario: '/icons/notif/sol-comentario.svg',
            solicitacao_cancelada:  '/icons/notif/sol-cancelada.svg',
            evento_novo:            '/icons/notif/evento-novo.svg',
            evento_atualizado:      '/icons/notif/evento-edit.svg',
            evento_publicado:       '/icons/notif/evento-pub.svg',
            evento_cancelado:       '/icons/notif/evento-x.svg',
            evento_lembrete:        '/icons/notif/evento-alarm.svg',
            acao_prazo_vencido:     '/icons/notif/prazo-alert.svg',
        };
        var BGS = {
            solicitacao_nova:       'bg-blue-100',
            solicitacao_producao:   'bg-orange-100',
            solicitacao_concluida:  'bg-purple-100',
            solicitacao_aprovada:   'bg-green-100',
            solicitacao_revisao:    'bg-amber-100',
            solicitacao_comentario: 'bg-slate-100',
            solicitacao_cancelada:  'bg-red-100',
            evento_novo:            'bg-blue-100',
            evento_atualizado:      'bg-indigo-100',
            evento_publicado:       'bg-green-100',
            evento_cancelado:       'bg-red-100',
            evento_lembrete:        'bg-yellow-100',
            acao_prazo_vencido:     'bg-orange-100',
        };
        return {
            open: false, unread: 0, items: [],
            init() {
                this.carregar();
                document.addEventListener('comunica:notif', function(e) {
                    this.unread++;
                    this.carregar();
                }.bind(this));
            },
            async carregar() {
                try {
                    var r = await fetch('/notificacoes/latest');
                    var data = await r.json();
                    if (data.ok) { this.items = data.items; this.unread = data.unread; }
                } catch(e) {}
            },
            toggle() { this.open = !this.open; if (this.open) this.carregar(); },
            icon(tipo) { return ICONS[tipo] || '/icons/notif/bell-default.svg'; },
            bgClass(tipo) { return BGS[tipo] || 'bg-gray-100'; },
            timeAgo(dateStr) {
                var d = new Date(dateStr), now = new Date();
                var diff = Math.floor((now - d) / 1000);
                if (diff < 60)    return 'agora mesmo';
                if (diff < 3600)  return Math.floor(diff / 60) + 'm atrás';
                if (diff < 86400) return Math.floor(diff / 3600) + 'h atrás';
                return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
            },
            async abrirNotif(n) {
                if (!n.lida) {
                    await fetch('/notificacoes/' + n.id + '/lida', { method: 'POST' }).catch(function(){});
                    n.lida = true;
                    this.unread = Math.max(0, this.unread - 1);
                }
                if (n.url) window.location.href = n.url;
            },
            async marcarTodas() {
                await fetch('/notificacoes/all-lida', { method: 'POST' }).catch(function(){});
                this.items.forEach(function(n) { n.lida = true; });
                this.unread = 0;
            },
        };
    }

    document.addEventListener('DOMContentLoaded', function() {
        var currentUserId = <%= user.id %>;
        if (!window._sseListenerAdded) {
            window._sseListenerAdded = true;
            document.addEventListener('comunica:sseData', function(e) {
                var data = e.detail;
                if (data && data.type === 'notificacao_nova' && data.userId === currentUserId) {
                    document.dispatchEvent(new CustomEvent('comunica:notif'));
                }
            });
        }
    });
    </script>
    <% } %>

