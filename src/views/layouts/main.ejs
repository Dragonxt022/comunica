            { page: null, target: null, icon: '👋', title: 'Bem-vindo ao Comunica!', desc: 'Em 5 passos vamos mostrar como abrir e acompanhar uma solicitação de produção de material. Clique em Começar!', next: 'Começar →' },
            { page: '/solicitacoes/nova', target: 'tour-titulo', icon: '✏️', title: 'Título da Solicitação', desc: 'Escreva um título claro e objetivo — por exemplo: "Post para lançamento do programa X". Isso ajuda a equipe a identificar o pedido rapidamente.', next: 'Próximo →' },
            { page: '/solicitacoes/nova', target: 'tour-descricao', icon: '📝', title: 'Briefing / Descrição', desc: 'Descreva com detalhes o que precisa ser produzido: contexto, público-alvo, referências visuais, informações importantes e qualquer prazo relevante.', next: 'Próximo →' },
            { page: '/solicitacoes/nova', target: 'tour-tipos', icon: '🎨', title: 'Tipo de Mídia', desc: 'Selecione o(s) tipo(s) de material: Nota, Release, Post, Arte Gráfica, Vídeo, Foto ou Outros. Cada tipo selecionado vira uma demanda separada com acompanhamento próprio.', next: 'Próximo →' },
            { page: '/solicitacoes/nova', target: 'tour-finalizar', icon: '⏰', title: 'Prioridade e Prazo', desc: 'Informe a urgência (Baixa, Média ou Alta) e, se houver, a data de entrega. Depois é só clicar em "Enviar Solicitação" — a equipe SECOM receberá o pedido imediatamente.', next: 'Ver acompanhamento →' },
            { page: '/solicitacoes', target: 'tour-sol-board', icon: '📊', title: 'Acompanhe em Tempo Real', desc: 'Aqui você monitora todas as suas solicitações e os contadores por status. Ao clicar em um item você vê detalhes, comentários e histórico. Você também recebe notificações a cada atualização.', next: 'Concluir ✓' },
        ];

        var cur  = parseInt(localStorage.getItem(STEP_KEY) || '0', 10);
        var path = window.location.pathname;
        var step = steps[cur];

        if (step.page && path !== step.page) {
            localStorage.setItem(STEP_KEY, String(cur));
            window.location.href = step.page;
            return;
        }

        var backdrop  = document.getElementById('tour-backdrop');
        var spotlight = document.getElementById('tour-spotlight');
        var card      = document.getElementById('tour-card');
        var progress  = document.getElementById('tour-progress');
        var counter   = document.getElementById('tour-counter');
        var elIcon    = document.getElementById('tour-icon');
        var elTitle   = document.getElementById('tour-title');
        var elDesc    = document.getElementById('tour-desc');
        var btnNext   = document.getElementById('tour-next');

        function finish() {
            localStorage.setItem(DONE_KEY, '1');
            localStorage.removeItem(STEP_KEY);
            backdrop.style.opacity  = '0';
            card.style.opacity      = '0';
            spotlight.style.opacity = '0';
            setTimeout(function() {
                backdrop.style.display  = 'none';
                card.style.display      = 'none';
                spotlight.style.display = 'none';
            }, 300);
        }

        function placeCard(targetEl) {
            var vw = window.innerWidth, vh = window.innerHeight;
            var cw = 320, ch = card.offsetHeight || 300, pad = 14;
            if (!targetEl) {
                spotlight.style.display = 'none';
                spotlight.classList.remove('pulsing');
                backdrop.style.background = 'rgba(15,23,42,0.72)';
                card.style.top  = Math.round((vh - ch) / 2) + 'px';
                card.style.left = Math.round((vw - cw) / 2) + 'px';
                return;
            }
            targetEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            setTimeout(function() {
                var r = targetEl.getBoundingClientRect();
                backdrop.style.background = 'transparent';
                spotlight.style.display   = 'block';
                spotlight.style.top    = (r.top    - pad) + 'px';
                spotlight.style.left   = (r.left   - pad) + 'px';
                spotlight.style.width  = (r.width  + pad * 2) + 'px';
                spotlight.style.height = (r.height + pad * 2) + 'px';
                spotlight.classList.add('pulsing');
                var cx, cy;
                if (r.right + cw + 20 <= vw) { cx = r.right + 18; cy = Math.max(16, Math.min(r.top, vh - ch - 16)); }
                else if (r.left - cw - 20 >= 0) { cx = r.left - cw - 18; cy = Math.max(16, Math.min(r.top, vh - ch - 16)); }
                else { cx = Math.max(16, Math.min(r.left + r.width / 2 - cw / 2, vw - cw - 16)); cy = Math.min(r.bottom + 18, vh - ch - 16); }
                card.style.left = cx + 'px';
                card.style.top  = cy + 'px';
            }, 350);
        }

        function render() {
            var s = steps[cur];
            var pct = Math.round((cur / (steps.length - 1)) * 100);
            progress.style.width = pct + '%';
            counter.textContent  = 'Passo ' + (cur + 1) + ' de ' + steps.length;
            elIcon.textContent   = s.icon;
            elTitle.textContent  = s.title;
            elDesc.textContent   = s.desc;
            btnNext.textContent  = s.next;
            localStorage.setItem(STEP_KEY, String(cur));
            var targetEl = s.target ? document.getElementById(s.target) : null;
            placeCard(targetEl);
        }

        btnNext.addEventListener('click', function() {
            var next = cur + 1;
            if (next >= steps.length) { finish(); return; }
            var nextPage = steps[next].page;
            if (nextPage && window.location.pathname !== nextPage) {
                localStorage.setItem(STEP_KEY, String(next));
                window.location.href = nextPage;
            } else { cur = next; render(); }
        });

        document.getElementById('tour-cancel').addEventListener('click', finish);
        document.getElementById('tour-x').addEventListener('click', finish);

        setTimeout(function() {
            backdrop.style.transition  = 'opacity .3s, background .3s';
            card.style.transition      = 'opacity .3s, top .35s ease, left .35s ease';
            spotlight.style.transition = 'opacity .3s';
            backdrop.style.display  = 'block';
            card.style.display      = 'block';
            backdrop.style.opacity  = '0';
            card.style.opacity      = '0';
            spotlight.style.opacity = '0';
            requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                    backdrop.style.opacity  = '1';
                    card.style.opacity      = '1';
                    spotlight.style.opacity = '1';
                    render();
                });
            });
        }, 750);
    }());
    </script>
    <% } %>
</body>
</html>
