<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Releases</h2>
            <p class="text-gray-500">Gerencie os releases e notas para a imprensa.</p>
        </div>
        <a href="/releases/novo" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Novo Release
        </a>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <% if(releases.length === 0) { %>
            <div class="py-20 text-center">
                <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM15 4v4h4M9 12h6M9 16h4"></path></svg>
                <p class="text-gray-400">Nenhum release cadastrado.</p>
                <a href="/releases/novo" class="mt-3 inline-block text-blue-600 font-medium hover:underline text-sm">Criar o primeiro release</a>
            </div>
        <% } else { %>
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Título</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Publicado em</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Criado em</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200 text-sm">
                <% releases.forEach(r => { %>
                <tr class="hover:bg-gray-50 transition">
                    <td class="px-6 py-4">
                        <div class="font-semibold text-gray-900"><%= r.titulo %></div>
                        <% if(r.subtitulo) { %>
                            <div class="text-xs text-gray-400 mt-0.5"><%= r.subtitulo %></div>
                        <% } %>
                    </td>
                    <td class="px-6 py-4">
                        <% if(r.publicado) { %>
                            <span class="px-2.5 py-1 text-xs font-bold bg-green-100 text-green-700 rounded-full">Publicado</span>
                        <% } else { %>
                            <span class="px-2.5 py-1 text-xs font-bold bg-yellow-100 text-yellow-700 rounded-full">Rascunho</span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 text-gray-500">
                        <%= r.publicado_em ? new Date(r.publicado_em).toLocaleDateString('pt-BR') : '—' %>
                    </td>
                    <td class="px-6 py-4 text-gray-500">
                        <%= new Date(r.createdAt).toLocaleDateString('pt-BR') %>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end items-center gap-2">
                            <form action="/releases/<%= r.id %>/publicar" method="POST">
                                <button type="submit" class="text-xs font-semibold px-3 py-1.5 rounded-lg border transition
                                    <%= r.publicado ? 'border-yellow-300 text-yellow-700 hover:bg-yellow-50' : 'border-green-300 text-green-700 hover:bg-green-50' %>">
                                    <%= r.publicado ? 'Despublicar' : 'Publicar' %>
                                </button>
                            </form>
                            <a href="/releases/<%= r.id %>/editar" class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 transition">Editar</a>
                            <form action="/releases/<%= r.id %>/excluir" method="POST" onsubmit="return confirm('Excluir este release?')">
                                <button type="submit" class="text-xs font-semibold px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
