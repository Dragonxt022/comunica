<div class="space-y-5">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-xl font-semibold text-gray-900">Releases</h2>
            <p class="text-sm text-gray-400 mt-0.5">Gerencie os releases e notas para a imprensa.</p>
        </div>
        <a href="/releases/novo" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Novo Release
        </a>
    </div>

    <!-- Filtros -->
    <form method="GET" action="/releases" class="bg-white rounded-lg border border-gray-200 p-4 flex flex-wrap gap-3 items-end">
        <div class="flex-1 min-w-[200px]">
            <label class="block text-xs font-medium text-gray-500 mb-1">Buscar</label>
            <div class="relative">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" name="q" value="<%= q %>" placeholder="Buscar pelo título…"
                    class="w-full pl-9 pr-4 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
            </div>
        </div>
        <div class="min-w-[160px]">
            <label class="block text-xs font-medium text-gray-500 mb-1">Secretaria</label>
            <select name="secretaria" class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                <option value="">Todas</option>
                <% secretarias.forEach(function(s) { %>
                    <option value="<%= s.id %>" <%= filtroSecretaria == s.id ? 'selected' : '' %>><%= s.nome %></option>
                <% }) %>
            </select>
        </div>
        <div class="min-w-[140px]">
            <label class="block text-xs font-medium text-gray-500 mb-1">Status</label>
            <select name="status" class="w-full px-3 py-2 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none">
                <option value="">Todos</option>
                <option value="publicado" <%= filtroStatus === 'publicado' ? 'selected' : '' %>>Publicado</option>
                <option value="agendado"  <%= filtroStatus === 'agendado'  ? 'selected' : '' %>>Agendado</option>
                <option value="rascunho"  <%= filtroStatus === 'rascunho'  ? 'selected' : '' %>>Rascunho</option>
            </select>
        </div>
        <div class="flex gap-2">
            <button type="submit" class="px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800 transition">Filtrar</button>
            <a href="/releases" class="px-4 py-2 border border-gray-300 text-gray-600 text-sm font-medium rounded-lg hover:bg-gray-50 transition">Limpar</a>
        </div>
    </form>

    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <% if(releases.length === 0) { %>
            <div class="py-20 text-center">
                <svg class="w-12 h-12 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM15 4v4h4M9 12h6M9 16h4"></path></svg>
                <p class="text-gray-400">Nenhum release encontrado.</p>
                <a href="/releases/novo" class="mt-3 inline-block text-blue-600 font-medium hover:underline text-sm">Criar o primeiro release</a>
            </div>
        <% } else { %>
        <table class="min-w-full divide-y divide-gray-100">
            <thead>
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400">Título</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400">Secretaria</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-400">Data</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-400">Ações</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-100 text-sm">
                <% releases.forEach(function(r) { %>
                <tr class="hover:bg-gray-50/60 transition">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <% if(r.imagem_capa) { %>
                                <img src="<%= r.imagem_capa %>" alt="" class="w-11 h-11 rounded-md object-cover flex-shrink-0 border border-gray-100">
                            <% } else { %>
                                <div class="w-11 h-11 rounded-md bg-gray-100 flex-shrink-0 flex items-center justify-center">
                                    <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                </div>
                            <% } %>
                            <div class="min-w-0">
                                <div class="font-medium text-gray-900 truncate max-w-xs"><%= r.titulo %></div>
                                <% if(r.subtitulo) { %><div class="text-xs text-gray-400 mt-0.5 truncate max-w-xs"><%= r.subtitulo %></div><% } %>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <% if(r.secretaria) { %>
                        <span class="inline-flex px-2 py-0.5 rounded-full text-xs font-medium text-white"
                              style="background-color: <%= r.secretaria.cor %>">
                            <%= r.secretaria.nome %>
                        </span>
                        <% } else { %><span class="text-gray-400 text-xs">—</span><% } %>
                    </td>
                    <td class="px-6 py-4">
                        <% if(r.publicado) { %>
                            <span class="px-2 py-0.5 text-xs font-medium bg-green-100 text-green-700 rounded-full">Publicado</span>
                        <% } else if(r.agendado_para) { %>
                            <span class="px-2 py-0.5 text-xs font-medium bg-blue-100 text-blue-700 rounded-full">Agendado</span>
                        <% } else { %>
                            <span class="px-2 py-0.5 text-xs font-medium bg-yellow-100 text-yellow-700 rounded-full">Rascunho</span>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 text-gray-500 text-xs">
                        <% if(r.publicado && r.publicado_em) { %>
                            <div class="font-medium text-gray-700"><%= new Date(r.publicado_em).toLocaleDateString('pt-BR') %></div>
                            <div class="text-gray-400">publicado</div>
                        <% } else if(r.agendado_para) { %>
                            <div class="font-medium text-blue-700"><%= new Date(r.agendado_para).toLocaleDateString('pt-BR') %></div>
                            <div class="text-gray-400"><%= new Date(r.agendado_para).toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'}) %></div>
                        <% } else { %>
                            <div><%= new Date(r.createdAt).toLocaleDateString('pt-BR') %></div>
                        <% } %>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end items-center gap-2">
                            <% if(r.publicado) { %>
                            <a href="/imprensa/releases/<%= r.id %>" target="_blank"
                               class="text-xs font-medium px-3 py-1.5 rounded-lg border border-indigo-200 text-indigo-600 hover:bg-indigo-50 transition">Ver</a>
                            <% } %>
                            <form action="/releases/<%= r.id %>/publicar" method="POST">
                                <button type="submit" class="text-xs font-medium px-3 py-1.5 rounded-lg border transition
                                    <%= r.publicado ? 'border-yellow-300 text-yellow-700 hover:bg-yellow-50' : 'border-green-300 text-green-700 hover:bg-green-50' %>">
                                    <%= r.publicado ? 'Despublicar' : 'Publicar' %>
                                </button>
                            </form>
                            <a href="/releases/<%= r.id %>/editar" class="text-xs font-medium px-3 py-1.5 rounded-lg border border-gray-300 text-gray-600 hover:bg-gray-50 transition">Editar</a>
                            <form action="/releases/<%= r.id %>/excluir" method="POST" onsubmit="return confirm('Excluir este release?')">
                                <button type="submit" class="text-xs font-medium px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <div class="px-6 py-3 border-t border-gray-100 text-xs text-gray-400">
            <%= releases.length %> release<%= releases.length !== 1 ? 's' : '' %> encontrado<%= releases.length !== 1 ? 's' : '' %>
        </div>
        <% } %>
    </div>
</div>
