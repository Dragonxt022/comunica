<div class="max-w-3xl mx-auto space-y-6">
    <div class="flex items-center gap-3">
        <a href="/releases" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        </a>
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Editar Release</h2>
            <p class="text-gray-500 text-sm">Atualize o conteúdo do release.</p>
        </div>
    </div>

    <form action="/releases/<%= release.id %>" method="POST" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título <span class="text-red-500">*</span></label>
            <input type="text" name="titulo" required value="<%= release.titulo %>"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subtítulo</label>
            <input type="text" name="subtitulo" value="<%= release.subtitulo || '' %>"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Conteúdo <span class="text-red-500">*</span></label>
            <textarea name="conteudo" required rows="12"
                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition resize-y font-mono text-sm"><%= release.conteudo %></textarea>
        </div>

        <div class="flex items-center gap-3 p-4 bg-green-50 rounded-lg border border-green-200">
            <input type="checkbox" name="publicado" id="publicado" <%= release.publicado ? 'checked' : '' %> class="w-4 h-4 accent-green-600">
            <label for="publicado" class="text-sm font-medium text-green-800 cursor-pointer">Publicado</label>
            <% if(release.publicado_em) { %>
                <span class="text-xs text-green-600">desde <%= new Date(release.publicado_em).toLocaleDateString('pt-BR') %></span>
            <% } %>
        </div>

        <div class="pt-2 flex justify-end gap-3">
            <a href="/releases" class="px-5 py-2.5 rounded-lg border border-gray-300 text-gray-600 font-medium hover:bg-gray-50 transition">Cancelar</a>
            <button type="submit" class="px-5 py-2.5 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition shadow-sm inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Salvar Alterações
            </button>
        </div>
    </form>
</div>
