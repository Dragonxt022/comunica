<div class="space-y-6">
    <div>
        <h2 class="text-xl font-semibold text-gray-900">Meu Perfil</h2>
        <p class="text-sm text-gray-400 mt-0.5">Gerencie suas informações e segurança da conta.</p>
    </div>

    <form action="/perfil" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- Card de identidade + avatar -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 flex flex-col items-center text-center gap-4">

            <!-- Avatar com upload -->
            <div class="relative group cursor-pointer" onclick="document.getElementById('avatar-input').click()" title="Clique para trocar a foto">
                <div class="w-20 h-20 rounded-full overflow-hidden bg-slate-800 flex items-center justify-center ring-2 ring-white ring-offset-2 ring-offset-gray-100">
                    <% if(usuario.avatar) { %>
                    <img id="avatar-preview" src="<%= usuario.avatar %>" alt="Foto de perfil" class="w-full h-full object-cover">
                    <span id="avatar-initials" class="text-white font-bold text-2xl hidden"><%= usuario.nome.charAt(0).toUpperCase() %></span>
                    <% } else { %>
                    <img id="avatar-preview" src="" alt="" class="w-full h-full object-cover hidden">
                    <span id="avatar-initials" class="text-white font-bold text-2xl"><%= usuario.nome.charAt(0).toUpperCase() %></span>
                    <% } %>
                </div>
                <!-- Overlay ao passar o mouse -->
                <div class="absolute inset-0 bg-black/50 rounded-full flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition pointer-events-none">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span class="text-white text-[10px] font-semibold mt-1">Trocar foto</span>
                </div>
                <input type="file" id="avatar-input" name="avatar" accept="image/jpeg,image/png,image/webp"
                    class="hidden" onchange="previewAvatar(this)">
            </div>
            <p class="text-[11px] text-gray-400 -mt-2">Clique para trocar a foto</p>

            <div>
                <p class="font-semibold text-gray-900 text-base"><%= usuario.nome %></p>
                <p class="text-sm text-gray-400 mt-0.5"><%= usuario.email %></p>
                <% if(usuario.celular) { %>
                <p class="text-xs text-gray-400 mt-0.5"><%= usuario.celular %></p>
                <% } %>
            </div>

            <div class="flex flex-col items-center gap-2 w-full">
                <span class="px-3 py-1 text-xs font-semibold rounded-full capitalize
                    <%= usuario.role === 'admin'    ? 'bg-purple-100 text-purple-700' :
                       usuario.role === 'secom'     ? 'bg-blue-100 text-blue-700' :
                       usuario.role === 'imprensa'  ? 'bg-orange-100 text-orange-700' :
                       'bg-gray-100 text-gray-600' %>">
                    <%= usuario.role === 'admin' ? 'Administrador' : usuario.role === 'secom' ? 'SECOM' : usuario.role === 'imprensa' ? 'Imprensa' : 'Secretaria' %>
                </span>
                <% if(usuario.secretaria) { %>
                <div class="flex items-center gap-1.5 text-xs text-gray-500">
                    <span class="w-2 h-2 rounded-full shrink-0" style="background-color: <%= usuario.secretaria.cor %>"></span>
                    <%= usuario.secretaria.nome %>
                </div>
                <% } %>
            </div>

            <div class="w-full pt-3 border-t border-gray-100 space-y-1.5 text-left">
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Conta criada</span>
                    <span class="text-gray-600 font-medium"><%= new Date(usuario.createdAt).toLocaleDateString('pt-BR') %></span>
                </div>
                <% if(usuario.ultimo_login) { %>
                <div class="flex justify-between text-xs">
                    <span class="text-gray-400">Último acesso</span>
                    <span class="text-gray-600 font-medium"><%= new Date(usuario.ultimo_login).toLocaleDateString('pt-BR') %></span>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Formulário de edição -->
        <div class="lg:col-span-2 space-y-4">

            <% if(success) { %>
            <div class="p-4 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700 flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Perfil atualizado com sucesso.
            </div>
            <% } %>
            <% if(error) { %>
            <div class="p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700 flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <%= error %>
            </div>
            <% } %>

            <div class="bg-white rounded-xl border border-gray-200 p-6 space-y-5">

                <div>
                    <h3 class="text-sm font-semibold text-gray-800 mb-4">Dados pessoais</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Nome completo</label>
                            <input type="text" name="nome" required value="<%= usuario.nome %>"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">E-mail</label>
                            <input type="email" name="email" required value="<%= usuario.email %>"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                        </div>
                        <div class="sm:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">
                                Celular
                                <span class="text-gray-400 font-normal">(opcional)</span>
                            </label>
                            <input type="tel" name="celular"
                                value="<%= usuario.celular || '' %>"
                                placeholder="(XX) 9XXXX-XXXX"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                        </div>
                    </div>
                </div>

                <div class="pt-4 border-t border-gray-100 space-y-4">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-800">Alterar senha</h3>
                        <p class="text-xs text-gray-400 mt-0.5">Deixe em branco para manter a senha atual.</p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Senha atual</label>
                            <input type="password" name="senha_atual" placeholder="••••••••"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Nova senha</label>
                            <input type="password" name="nova_senha" minlength="6" placeholder="Mínimo 6 caracteres"
                                class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition text-sm">
                        </div>
                    </div>
                </div>

                <div class="flex justify-end pt-2">
                    <button type="submit"
                        class="px-6 py-2.5 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 transition inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Salvar alterações
                    </button>
                </div>
            </div>
        </div>

    </form>
</div>

<script>
function previewAvatar(input) {
    if (!input.files || !input.files[0]) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        var preview  = document.getElementById('avatar-preview');
        var initials = document.getElementById('avatar-initials');
        preview.src = e.target.result;
        preview.classList.remove('hidden');
        if (initials) initials.classList.add('hidden');
    };
    reader.readAsDataURL(input.files[0]);
}
</script>
