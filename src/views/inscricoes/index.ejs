<div class="max-w-6xl mx-auto px-4 py-8">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div class="flex items-center gap-3">
      <a href="/eventos" class="text-gray-500 hover:text-gray-700 transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
      </a>
      <div>
        <h1 class="text-xl font-bold text-gray-900">Inscritos</h1>
        <p class="text-sm text-gray-500 mt-0.5"><%= evento.titulo %> · <span class="font-medium"><%= new Date(evento.data_inicio).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %></span></p>
      </div>
    </div>
    <div class="flex gap-2 shrink-0">
      <a href="/eventos/<%= evento.id %>/inscricoes/exportar?<%= new URLSearchParams({q, status: filtroStatus}).toString() %>"
        class="inline-flex items-center gap-1.5 px-3 py-2 bg-green-50 text-green-700 text-sm font-medium rounded-lg hover:bg-green-100 transition border border-green-200">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
        Exportar CSV
      </a>
      <a href="/eventos/<%= evento.id %>/inscricoes/config" class="inline-flex items-center gap-1.5 px-3 py-2 bg-gray-100 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-200 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        Configurar
      </a>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= total %></p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Confirmados</p>
      <p class="text-2xl font-bold text-green-600 mt-1"><%= totalConfirmados %></p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Vagas</p>
      <p class="text-2xl font-bold text-gray-900 mt-1">
        <% if (evento.max_inscricoes) { %>
          <%= Math.max(0, evento.max_inscricoes - totalConfirmados) %>/<%= evento.max_inscricoes %>
        <% } else { %>
          <span class="text-base text-gray-400">Ilimitado</span>
        <% } %>
      </p>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Situação</p>
      <p class="mt-1">
        <% if (evento.inscricoes_abertas) { %>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-green-600"><span class="w-2 h-2 bg-green-500 rounded-full"></span>Abertas</span>
        <% } else { %>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-red-600"><span class="w-2 h-2 bg-red-500 rounded-full"></span>Fechadas</span>
        <% } %>
      </p>
    </div>
  </div>

  <!-- Filtros e busca -->
  <form method="GET" action="/eventos/<%= evento.id %>/inscricoes" class="flex flex-wrap gap-2 mb-4">
    <input type="text" name="q" value="<%= q %>" placeholder="Buscar por nome, e-mail ou nº..."
      class="flex-1 min-w-48 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
    <select name="status" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value="">Todos os status</option>
      <option value="confirmado" <%= filtroStatus === 'confirmado' ? 'selected' : '' %>>Confirmado</option>
      <option value="pendente" <%= filtroStatus === 'pendente' ? 'selected' : '' %>>Pendente</option>
      <option value="cancelado" <%= filtroStatus === 'cancelado' ? 'selected' : '' %>>Cancelado</option>
    </select>
    <select name="ordenar" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
      <option value="createdAt_DESC" <%= ordenar === 'createdAt_DESC' ? 'selected' : '' %>>Mais recentes</option>
      <option value="createdAt_ASC" <%= ordenar === 'createdAt_ASC' ? 'selected' : '' %>>Mais antigos</option>
      <option value="nome_ASC" <%= ordenar === 'nome_ASC' ? 'selected' : '' %>>Nome A→Z</option>
      <option value="nome_DESC" <%= ordenar === 'nome_DESC' ? 'selected' : '' %>>Nome Z→A</option>
    </select>
    <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Filtrar</button>
    <% if (q || filtroStatus) { %>
    <a href="/eventos/<%= evento.id %>/inscricoes" class="px-4 py-2 bg-gray-100 text-gray-600 text-sm rounded-lg hover:bg-gray-200 transition">Limpar</a>
    <% } %>
  </form>

  <!-- Tabela -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <% if (inscricoes.length === 0) { %>
    <div class="text-center py-16">
      <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
      <p class="text-gray-500 text-sm">Nenhuma inscrição encontrada.</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 whitespace-nowrap">Nº Inscrição</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Nome</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden sm:table-cell">E-mail</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden md:table-cell">Telefone</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Status</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden lg:table-cell">Data</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% inscricoes.forEach(function(ins) { %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3 font-mono text-xs text-gray-600"><%= ins.numero_inscricao %></td>
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900"><%= ins.nome %></div>
            </td>
            <td class="px-4 py-3 text-gray-600 hidden sm:table-cell"><%= ins.email %></td>
            <td class="px-4 py-3 text-gray-600 hidden md:table-cell"><%= ins.telefone || '—' %></td>
            <td class="px-4 py-3">
              <% const statusMap = { confirmado: 'bg-green-100 text-green-700', pendente: 'bg-yellow-100 text-yellow-700', cancelado: 'bg-red-100 text-red-600' }; %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= statusMap[ins.status] || 'bg-gray-100 text-gray-600' %>">
                <%= ins.status %>
              </span>
            </td>
            <td class="px-4 py-3 text-gray-500 hidden lg:table-cell whitespace-nowrap"><%= new Date(ins.createdAt).toLocaleString('pt-BR', { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit' }) %></td>
            <td class="px-4 py-3">
              <div class="flex items-center justify-end gap-2">
                <a href="/eventos/<%= evento.id %>/inscricoes/<%= ins.id %>" class="text-xs px-2.5 py-1.5 bg-gray-100 text-gray-700 rounded-md hover:bg-gray-200 transition font-medium">Ver</a>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- Paginação -->
  <% if (totalPages > 1) { %>
  <div class="flex items-center justify-between mt-4">
    <p class="text-sm text-gray-500">Mostrando <%= (currentPage - 1) * 25 + 1 %>–<%= Math.min(currentPage * 25, total) %> de <%= total %></p>
    <div class="flex gap-1">
      <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %>&q=<%= encodeURIComponent(q) %>&status=<%= filtroStatus %>&ordenar=<%= ordenar %>"
        class="px-3 py-1.5 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition">Anterior</a>
      <% } %>
      <% for(var p = Math.max(1, currentPage - 2); p <= Math.min(totalPages, currentPage + 2); p++) { %>
      <a href="?page=<%= p %>&q=<%= encodeURIComponent(q) %>&status=<%= filtroStatus %>&ordenar=<%= ordenar %>"
        class="px-3 py-1.5 text-sm border rounded-md transition <%= p === currentPage ? 'bg-blue-600 text-white border-blue-600' : 'border-gray-300 hover:bg-gray-50' %>">
        <%= p %>
      </a>
      <% } %>
      <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %>&q=<%= encodeURIComponent(q) %>&status=<%= filtroStatus %>&ordenar=<%= ordenar %>"
        class="px-3 py-1.5 text-sm border border-gray-300 rounded-md hover:bg-gray-50 transition">Próximo</a>
      <% } %>
    </div>
  </div>
  <% } %>
</div>
