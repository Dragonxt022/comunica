<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-gray-900">Inscrições</h1>
      <p class="text-sm text-gray-500 mt-0.5">Eventos com formulário de inscrição ativo</p>
    </div>
    <% if(user && (user.role === 'admin' || user.role === 'secom')) { %>
    <a href="/formularios" class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
      Templates de formulário
    </a>
    <% } %>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 px-5 py-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">Eventos ativos</p>
      <p class="text-2xl font-bold text-gray-900"><%= eventos.length %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 px-5 py-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">Total inscritos</p>
      <p class="text-2xl font-bold text-blue-600"><%= totalInscricoes %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 px-5 py-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-1">Inscrições abertas</p>
      <p class="text-2xl font-bold text-green-600"><%= totalAbertos %></p>
    </div>
  </div>

  <% if (eventos.length === 0) { %>
  <div class="bg-white rounded-xl border border-dashed border-gray-300 p-12 text-center">
    <svg class="w-10 h-10 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
    <p class="text-gray-500 text-sm">Nenhum evento com inscrições ativas.</p>
    <a href="/eventos" class="mt-3 inline-block text-sm text-blue-600 hover:underline font-medium">Ir para eventos →</a>
  </div>
  <% } else { %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Evento</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden sm:table-cell">Secretaria</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden md:table-cell">Status</th>
          <th class="text-center px-4 py-3 font-semibold text-gray-600">Inscritos</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% eventos.forEach(function(evento) { %>
        <% var count = countMap[evento.id] || 0; %>
        <% var aberto = !!evento.inscricoes_abertas; %>
        <% var link = evento.token_inscricao ? (baseUrl + '/inscricao/' + evento.token_inscricao) : null; %>
        <tr class="hover:bg-gray-50 transition">
          <td class="px-4 py-3">
            <div class="font-medium text-gray-900 line-clamp-1"><%= evento.titulo %></div>
            <div class="text-xs text-gray-400 mt-0.5">
              <%= new Date(evento.data_inicio).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
            </div>
          </td>
          <td class="px-4 py-3 hidden sm:table-cell">
            <% if (evento.secretaria) { %>
            <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold text-white"
              style="background-color: <%= evento.secretaria.cor %>">
              <%= evento.secretaria.nome %>
            </span>
            <% } else { %>
            <span class="text-gray-300">—</span>
            <% } %>
          </td>
          <td class="px-4 py-3 hidden md:table-cell">
            <% if (aberto) { %>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-green-50 text-green-700 text-xs font-medium rounded-full">
              <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
              Aberta
            </span>
            <% } else { %>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-gray-100 text-gray-500 text-xs font-medium rounded-full">
              <span class="w-1.5 h-1.5 bg-gray-400 rounded-full"></span>
              Encerrada
            </span>
            <% } %>
          </td>
          <td class="px-4 py-3 text-center">
            <span class="inline-flex items-center justify-center w-10 h-7 bg-blue-50 text-blue-700 text-sm font-bold rounded-lg"><%= count %></span>
          </td>
          <td class="px-4 py-3">
            <div class="flex items-center justify-end gap-1.5">
              <a href="/eventos/<%= evento.id %>/inscricoes"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 text-white text-xs font-semibold rounded-lg hover:bg-blue-700 transition">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                Ver inscritos
              </a>
              <% if (link) { %>
              <button onclick="copiarLink('<%= link %>')" title="Copiar link público"
                class="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
              </button>
              <% } %>
              <a href="/eventos/<%= evento.id %>/inscricoes/config" title="Configurar inscrições"
                class="p-1.5 text-gray-400 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </a>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<div x-data="{ toast: '' }" @copiar.window="toast = $event.detail; setTimeout(() => toast = '', 2500)"
  x-show="toast" x-transition
  class="fixed bottom-6 right-6 z-50 px-5 py-3 bg-green-600 text-white text-sm font-semibold rounded-xl shadow-lg"
  x-text="toast" style="display:none">
</div>

<script>
function copiarLink(url) {
  navigator.clipboard.writeText(url).then(() => {
    window.dispatchEvent(new CustomEvent('copiar', { detail: 'Link copiado!' }));
  });
}
</script>
