<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 10pt; color: #1a1a1a; background: white; }
  @page { size: A4 portrait; margin: 20mm 20mm 20mm 20mm; }
  .comprovante { width: 170mm; min-height: 257mm; margin: 0 auto; }

  .header { display: flex; align-items: flex-start; justify-content: space-between; padding-bottom: 12pt; border-bottom: 2.5pt solid #1e293b; margin-bottom: 20pt; }
  .brand { font-size: 18pt; font-weight: 800; color: #1e293b; }
  .brand-sub { font-size: 8pt; color: #64748b; margin-top: 3pt; }
  .header-right { text-align: right; }
  .numero { font-size: 9pt; color: #64748b; }
  .numero strong { font-size: 12pt; color: #1e293b; font-weight: 800; display: block; margin-top: 2pt; }

  .titulo-bloco { margin-bottom: 20pt; }
  .label-grande { font-size: 7pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #64748b; margin-bottom: 4pt; }
  .titulo-evento { font-size: 15pt; font-weight: 800; color: #1e293b; margin-bottom: 6pt; }
  .evento-infos { display: flex; flex-wrap: wrap; gap: 12pt; margin-top: 6pt; }
  .evento-info-item { font-size: 9pt; color: #475569; }
  .evento-info-item strong { color: #1e293b; display: block; font-size: 8pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #64748b; margin-bottom: 2pt; }

  .divider { border: none; border-top: 1pt solid #e2e8f0; margin: 14pt 0; }

  .dados-titulo { font-size: 10pt; font-weight: 700; color: #1e293b; margin-bottom: 10pt; }
  .dados-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10pt 20pt; margin-bottom: 14pt; }
  .dado-item .dado-label { font-size: 7.5pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #94a3b8; margin-bottom: 2pt; }
  .dado-item .dado-valor { font-size: 10pt; color: #1e293b; font-weight: 500; }
  .dado-item.full { grid-column: 1 / -1; }

  .extras-section { margin-top: 12pt; }
  .extras-titulo { font-size: 8.5pt; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #64748b; border-bottom: 0.5pt solid #e2e8f0; padding-bottom: 4pt; margin-bottom: 8pt; }
  .extra-item { margin-bottom: 8pt; }
  .extra-label { font-size: 8pt; font-weight: 700; color: #475569; margin-bottom: 2pt; }
  .extra-valor { font-size: 9.5pt; color: #1e293b; }

  .status-badge { display: inline-flex; align-items: center; gap: 5pt; padding: 4pt 10pt; border-radius: 20pt; font-size: 9pt; font-weight: 700; margin-bottom: 14pt; }
  .status-confirmado { background: #dcfce7; color: #166534; border: 1pt solid #bbf7d0; }
  .status-pendente { background: #fef9c3; color: #854d0e; border: 1pt solid #fde68a; }
  .status-cancelado { background: #fee2e2; color: #991b1b; border: 1pt solid #fecaca; }

  .qr-area { display: flex; align-items: center; gap: 16pt; margin-top: 14pt; padding: 12pt; background: #f8fafc; border: 0.5pt solid #e2e8f0; border-radius: 6pt; }
  .qr-texto { flex: 1; }
  .qr-texto p { font-size: 8.5pt; color: #64748b; line-height: 1.5; }

  .footer { margin-top: auto; padding-top: 14pt; border-top: 0.5pt solid #e2e8f0; display: flex; justify-content: space-between; align-items: flex-end; font-size: 7.5pt; color: #94a3b8; }
  .footer .assinatura { text-align: right; }
  .footer .assinatura .linha { border-top: 0.5pt solid #cbd5e1; padding-top: 4pt; margin-top: 18pt; min-width: 80pt; text-align: center; }

  .marca-dagua { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-30deg); font-size: 48pt; font-weight: 900; color: rgba(37,99,235,0.04); white-space: nowrap; pointer-events: none; z-index: 0; }

  .pagina { position: relative; overflow: hidden; min-height: 257mm; display: flex; flex-direction: column; }

  @media print {
    .no-print { display: none !important; }
    body { margin: 0; }
  }
  @media screen {
    body { background: #f0f4f8; padding: 20px; }
    .comprovante { box-shadow: 0 4px 20px rgba(0,0,0,0.12); padding: 20mm; min-height: 257mm; }
    .no-print-bar { position: fixed; top: 0; left: 0; right: 0; background: #1e293b; color: white; padding: 10px 16px; display: flex; align-items: center; justify-between; gap: 12px; z-index: 100; font-family: system-ui, sans-serif; font-size: 13px; }
    .no-print-bar button { background: #2563eb; color: white; border: none; padding: 6px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; }
    .no-print-bar button:hover { background: #1d4ed8; }
  }
</style>

<!-- Barra de ação (somente tela) -->
<div class="no-print no-print-bar">
  <span>Comprovante de inscrição gerado com sucesso.</span>
  <button onclick="window.print()">Imprimir / Salvar PDF</button>
</div>

<div class="comprovante" style="margin-top: 50px">
  <div class="pagina">
    <div class="marca-dagua">INSCRIÇÃO</div>

    <!-- Cabeçalho -->
    <div class="header">
      <div>
        <div class="brand"><%= config && config.titulo_site ? config.titulo_site : 'Prefeitura Municipal' %></div>
        <div class="brand-sub">Comprovante de Inscrição em Evento</div>
      </div>
      <div class="header-right">
        <div class="numero">
          Nº de inscrição
          <strong><%= inscricao.numero_inscricao %></strong>
        </div>
        <div style="font-size:8pt;color:#94a3b8;margin-top:4pt"><%= new Date(inscricao.createdAt).toLocaleString('pt-BR') %></div>
      </div>
    </div>

    <!-- Status -->
    <% const statusClass = inscricao.status === 'confirmado' ? 'status-confirmado' : inscricao.status === 'cancelado' ? 'status-cancelado' : 'status-pendente'; %>
    <span class="status-badge <%= statusClass %>">
      ● Inscrição <%= inscricao.status === 'confirmado' ? 'Confirmada' : inscricao.status === 'cancelado' ? 'Cancelada' : 'Pendente' %>
    </span>

    <!-- Evento -->
    <div class="titulo-bloco">
      <div class="label-grande">Evento</div>
      <div class="titulo-evento"><%= evento.titulo %></div>
      <div class="evento-infos">
        <div class="evento-info-item">
          <strong>Data</strong>
          <%= new Date(evento.data_inicio).toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }) %>
          <% if (evento.data_fim && evento.data_fim !== evento.data_inicio) { %>
          até <%= new Date(evento.data_fim).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
          <% } %>
        </div>
        <% if (evento.local) { %>
        <div class="evento-info-item">
          <strong>Local</strong>
          <%= evento.local %>
        </div>
        <% } %>
        <% if (evento.secretaria) { %>
        <div class="evento-info-item">
          <strong>Organização</strong>
          <%= evento.secretaria.nome %>
        </div>
        <% } %>
      </div>
    </div>

    <hr class="divider">

    <!-- Dados do inscrito -->
    <div class="dados-titulo">Dados do Inscrito</div>
    <div class="dados-grid">
      <div class="dado-item full">
        <div class="dado-label">Nome completo</div>
        <div class="dado-valor"><%= inscricao.nome %></div>
      </div>
      <div class="dado-item">
        <div class="dado-label">E-mail</div>
        <div class="dado-valor"><%= inscricao.email %></div>
      </div>
      <div class="dado-item">
        <div class="dado-label">Telefone</div>
        <div class="dado-valor"><%= inscricao.telefone || '—' %></div>
      </div>
    </div>

    <!-- Dados extras -->
    <% if (campos && campos.length > 0) { %>
    <div class="extras-section">
      <div class="extras-titulo">Informações Adicionais</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8pt 20pt">
        <% campos.forEach(function(campo) { %>
        <% const val = dados[campo.id]; %>
        <% if (val !== undefined && val !== '') { %>
        <div class="extra-item">
          <div class="extra-label"><%= campo.label %></div>
          <div class="extra-valor"><%= Array.isArray(val) ? val.join(', ') : val %></div>
        </div>
        <% } %>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Espaçador -->
    <div style="flex:1"></div>

    <!-- Instruções -->
    <div class="qr-area">
      <div class="qr-texto">
        <p><strong>Este é o seu comprovante de inscrição.</strong></p>
        <p>Guarde este documento e apresente-o no dia do evento quando solicitado. Sua inscrição está registrada com o número <strong><%= inscricao.numero_inscricao %></strong>.</p>
        <p style="margin-top:6pt;font-size:8pt">Em caso de dúvidas, entre em contato com a organização do evento.</p>
      </div>
    </div>

    <!-- Rodapé -->
    <div class="footer">
      <div>
        <p><%= config && config.titulo_site ? config.titulo_site : 'Prefeitura Municipal' %></p>
        <% if (config && config.email_contato) { %><p><%= config.email_contato %></p><% } %>
        <p>Emitido em: <%= new Date().toLocaleString('pt-BR') %></p>
      </div>
      <div class="assinatura">
        <div class="linha">
          Secretaria Organizadora
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Não faz auto-print (para não incomodar na visualização em tela)
</script>
