<%
/* ── Cálculos para gráficos e agrupamentos ── */
var statusCounts = { pendente: 0, 'produção': 0, finalizado: 0, cancelado: 0, outros: 0 };
var tipoCounts   = {};
var secMap       = {};   // id → { nome, cor, items[] }

solicitacoes.forEach(function(s) {
    var st = s.status || '';
    if (st === 'pendente')          statusCounts.pendente++;
    else if (st === 'produção')     statusCounts['produção']++;
    else if (st === 'finalizado' || st === 'concluído') statusCounts.finalizado++;
    else if (st === 'cancelado')    statusCounts.cancelado++;
    else                            statusCounts.outros++;

    var tipo = s.tipo_midia || 'Outros';
    tipoCounts[tipo] = (tipoCounts[tipo] || 0) + 1;

    var secKey  = s.secretaria ? String(s.secretaria.id) : '__sem__';
    var secNome = s.secretaria ? s.secretaria.nome : 'Sem secretaria';
    var secCor  = s.secretaria ? s.secretaria.cor : '#64748b';
    if (!secMap[secKey]) secMap[secKey] = { nome: secNome, cor: secCor, items: [] };
    secMap[secKey].items.push(s);
});

var secList = Object.values(secMap).sort(function(a,b){ return b.items.length - a.items.length; });

var totalFinalizado = statusCounts.finalizado;
var totalProd       = statusCounts['produção'];
%>

<!-- ── Cabeçalho ── -->
<div class="report-header">
    <div>
        <div class="brand">Comunica</div>
        <div class="brand-sub">Secretaria de Comunicação Municipal</div>
    </div>
    <div class="meta">
        <div><strong>Relatório de Comunicação</strong></div>
        <div>Período: <%= periodoLabel %></div>
        <div>Gerado em: <%= geradoEm %></div>
    </div>
</div>

<h1 class="report-title">Relatório de Comunicação</h1>
<p class="report-subtitle">Período de referência: <strong><%= periodoLabel %></strong></p>

<!-- ── Cards de sumário ── -->
<div class="summary-grid">
    <div class="summary-card accent-blue">
        <div class="num"><%= releases.length %></div>
        <div class="lbl">Releases publicados</div>
    </div>
    <div class="summary-card accent-amber">
        <div class="num"><%= solicitacoes.length %></div>
        <div class="lbl">Solicitações de produção</div>
    </div>
    <div class="summary-card accent-teal">
        <div class="num"><%= totalProd %></div>
        <div class="lbl">Em produção</div>
    </div>
    <div class="summary-card accent-green">
        <div class="num"><%= totalFinalizado %></div>
        <div class="lbl">Produção concluída</div>
    </div>
</div>

<% if (solicitacoes.length > 0) { %>
<!-- ── Gráficos ── -->
<div class="charts-row">
    <div class="chart-card">
        <div class="chart-card-title">Status das Solicitações</div>
        <canvas id="chartStatus" width="160" height="155"></canvas>
    </div>
    <div class="chart-card">
        <div class="chart-card-title">Solicitações por Secretaria</div>
        <canvas id="chartSec" width="240" height="155"></canvas>
    </div>
    <div class="chart-card">
        <div class="chart-card-title">Tipos de Mídia</div>
        <canvas id="chartTipo" width="240" height="155"></canvas>
    </div>
</div>
<% } %>

<% if (releases.length > 0) { %>
<!-- ── Releases ── -->
<div class="section">
    <div class="section-title">Releases Publicados (<%= releases.length %>)</div>
    <table>
        <thead>
            <tr>
                <th style="width:35%">Título</th>
                <th style="width:22%">Secretaria</th>
                <th style="width:13%">Publicado em</th>
                <th style="width:18%">Link</th>
                <th style="width:12%">Print</th>
            </tr>
        </thead>
        <tbody>
            <% releases.forEach(function(r) { %>
            <tr>
                <td>
                    <strong><%= r.titulo %></strong>
                    <% if (r.subtitulo) { %><br><span style="color:#64748b;font-size:7.5pt"><%= r.subtitulo %></span><% } %>
                </td>
                <td>
                    <% if (r.secretaria) { %>
                    <span class="badge badge-sec" style="background:<%= r.secretaria.cor %>22;color:<%= r.secretaria.cor %>">
                        <%= r.secretaria.nome %>
                    </span>
                    <% } else { %>—<% } %>
                </td>
                <td>
                    <% if (r.publicado_em) { %><%= new Date(r.publicado_em).toLocaleDateString('pt-BR') %><% } else { %>—<% } %>
                </td>
                <td>
                    <% if (r.link_publicacao) { %>
                    <a href="<%= r.link_publicacao %>" class="link-pub" target="_blank">Ver publicação</a>
                    <% } else { %><span style="color:#94a3b8">—</span><% } %>
                </td>
                <td>
                    <% if (r.print_publicacao_url) { %>
                    <img src="<%= r.print_publicacao_url %>" class="arte-final-img" alt="Print">
                    <% } else { %><span style="color:#94a3b8">—</span><% } %>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<% } %>

<% if (solicitacoes.length > 0) { %>
<!-- ── Solicitações agrupadas por Secretaria ── -->
<div class="section-title" style="margin-bottom:12pt">
    Solicitações por Secretaria (<%= solicitacoes.length %> no total)
</div>

<% secList.forEach(function(sec, idx) {
    var fin  = sec.items.filter(function(s){ return s.status === 'finalizado' || s.status === 'concluído'; }).length;
    var prod = sec.items.filter(function(s){ return s.status === 'produção'; }).length;
    var pend = sec.items.filter(function(s){ return s.status === 'pendente'; }).length;
%>
<div class="sec-section">
    <div class="sec-section-header" style="border-left-color:<%= sec.cor %>">
        <span class="sec-section-nome"><%= sec.nome %></span>
        <span class="sec-section-count"><%= sec.items.length %> solicitaç<%= sec.items.length === 1 ? 'ão' : 'ões' %></span>
    </div>
    <div class="sec-stats" style="border-left-color:<%= sec.cor %>">
        <% if (fin > 0) { %><span class="sec-stat-item"><strong><%= fin %></strong> finalizado<%= fin !== 1 ? 's' : '' %></span><% } %>
        <% if (prod > 0) { %><span class="sec-stat-item"><strong><%= prod %></strong> em produção</span><% } %>
        <% if (pend > 0) { %><span class="sec-stat-item"><strong><%= pend %></strong> pendente<%= pend !== 1 ? 's' : '' %></span><% } %>
    </div>
    <table>
        <thead>
            <tr>
                <th style="width:5%">#</th>
                <th style="width:33%">Solicitação</th>
                <th style="width:15%">Tipo de Mídia</th>
                <th style="width:11%">Status</th>
                <th style="width:22%">Data</th>
                <th style="width:9%">Arte</th>
                <th style="width:5%">Link</th>
            </tr>
        </thead>
        <tbody>
            <% sec.items.forEach(function(s) {
                var badgeCls = s.status === 'pendente' ? 'badge-pend'
                             : (s.status === 'produção' ? 'badge-prod'
                             : (s.status === 'finalizado' || s.status === 'concluído' ? 'badge-conc'
                             : (s.status === 'cancelado' ? 'badge-canc' : '')));
            %>
            <tr>
                <td style="color:#94a3b8">#<%= s.id %></td>
                <td>
                    <strong><%= s.titulo %></strong>
                    <% if (s.prioridade === 'alta') { %><br><span style="color:#dc2626;font-size:7pt">● Alta prioridade</span><% } %>
                </td>
                <td><%= s.tipo_midia %></td>
                <td><span class="badge <%= badgeCls %>"><%= s.status %></span></td>
                <td style="font-size:7.5pt;color:#64748b">
                    <%= s.createdAt ? new Date(s.createdAt).toLocaleDateString('pt-BR') : '—' %>
                </td>
                <td>
                    <% if (s.arte_final_url) { %>
                    <img src="<%= s.arte_final_url %>" class="arte-final-img" alt="Arte">
                    <% } else { %><span style="color:#94a3b8">—</span><% } %>
                </td>
                <td>
                    <% if (s.link_publicacao) { %>
                    <a href="<%= s.link_publicacao %>" class="link-pub" target="_blank">ver</a>
                    <% } else { %><span style="color:#94a3b8">—</span><% } %>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<% }) %>
<% } %>

<% if (releases.length === 0 && solicitacoes.length === 0) { %>
<div class="empty-msg">Nenhum dado encontrado para o período e filtros selecionados.</div>
<% } %>

<!-- ── Rodapé ── -->
<div class="report-footer">
    <span>Comunica — Plataforma de Comunicação Municipal</span>
    <span>Gerado em <%= geradoEm %></span>
</div>

<% if (solicitacoes.length > 0) { %>
<script>
(function() {
    var statusData = <%- JSON.stringify(statusCounts) %>;
    var secData    = <%- JSON.stringify(secList.map(function(s){ return { nome: s.nome, cor: s.cor, total: s.items.length }; })) %>;
    var tipoData   = <%- JSON.stringify(tipoCounts) %>;

    /* ── Gráfico de status (donut) ── */
    var stLabels = [], stValues = [], stColors = [];
    var stColorMap = {
        pendente:    '#f59e0b',
        'produção':  '#3b82f6',
        finalizado:  '#10b981',
        cancelado:   '#ef4444',
        outros:      '#94a3b8'
    };
    Object.keys(statusData).forEach(function(k) {
        if (statusData[k] > 0) {
            stLabels.push(k.charAt(0).toUpperCase() + k.slice(1));
            stValues.push(statusData[k]);
            stColors.push(stColorMap[k] || '#94a3b8');
        }
    });
    new Chart(document.getElementById('chartStatus'), {
        type: 'doughnut',
        data: { labels: stLabels, datasets: [{ data: stValues, backgroundColor: stColors, borderWidth: 1, borderColor: '#fff' }] },
        options: {
            responsive: false,
            plugins: {
                legend: { position: 'bottom', labels: { font: { size: 8 }, padding: 6 } }
            }
        }
    });

    /* ── Gráfico por secretaria (barra horizontal) ── */
    var secLabels = secData.map(function(s) {
        return s.nome.length > 22 ? s.nome.substring(0, 22) + '…' : s.nome;
    });
    var secValues = secData.map(function(s) { return s.total; });
    var secColors = secData.map(function(s) { return s.cor + 'cc'; });
    new Chart(document.getElementById('chartSec'), {
        type: 'bar',
        data: { labels: secLabels, datasets: [{ data: secValues, backgroundColor: secColors, borderRadius: 3, borderWidth: 0 }] },
        options: {
            responsive: false,
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: {
                x: { ticks: { font: { size: 8 }, stepSize: 1 }, grid: { color: '#f1f5f9' } },
                y: { ticks: { font: { size: 7.5 } } }
            }
        }
    });

    /* ── Gráfico tipos de mídia (barra horizontal) ── */
    var tipoEntries = Object.entries(tipoData).sort(function(a,b){ return b[1]-a[1]; });
    var tipoLabels  = tipoEntries.map(function(e) {
        return e[0].length > 22 ? e[0].substring(0,22) + '…' : e[0];
    });
    var tipoValues  = tipoEntries.map(function(e){ return e[1]; });
    new Chart(document.getElementById('chartTipo'), {
        type: 'bar',
        data: { labels: tipoLabels, datasets: [{ data: tipoValues, backgroundColor: '#6366f1cc', borderRadius: 3, borderWidth: 0 }] },
        options: {
            responsive: false,
            indexAxis: 'y',
            plugins: { legend: { display: false } },
            scales: {
                x: { ticks: { font: { size: 8 }, stepSize: 1 }, grid: { color: '#f1f5f9' } },
                y: { ticks: { font: { size: 7.5 } } }
            }
        }
    });
})();
</script>
<% } %>
