# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3020
APP_URL="https://comunicacao.suaprefeitura.gov.br"

# ─── Session ─────────────────────────────────────────────────────────────────
# Gere com: node -e "require('crypto').randomBytes(48).toString('hex')"
SESSION_SECRET="change-this-to-a-long-random-string"

# ─── Database ────────────────────────────────────────────────────────────────
# Dialeto: sqlite | mysql | mariadb | postgres
DB_DIALECT="sqlite"

# SQLite — caminho relativo à raiz do projeto
DB_STORAGE="./database/app.sqlite"

# MySQL / MariaDB / PostgreSQL — descomente e preencha se não usar SQLite
# DB_HOST="localhost"
# DB_PORT="3306"
# DB_NAME="comunica"
# DB_USER="comunica_user"
# DB_PASS="strong_password_here"

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
# Obrigatório para push notifications funcionarem no navegador.
# Gere as chaves com: npx web-push generate-vapid-keys
# ATENÇÃO: uma vez que usuários se inscreveram, NÃO regenere estas chaves
# ou todas as inscrições existentes serão invalidadas.
VAPID_PUBLIC_KEY="sua-chave-publica-vapid-aqui"
VAPID_PRIVATE_KEY="sua-chave-privada-vapid-aqui"
VAPID_EMAIL="admin@comunicacao.suaprefeitura.gov.br"
