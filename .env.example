# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
APP_URL="https://comunicacao.suaprefeitura.gov.br"

# ─── Session ─────────────────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(48).toString('hex')"
SESSION_SECRET="change-this-to-a-long-random-string"

# ─── Database ────────────────────────────────────────────────────────────────
# sqlite | postgres | mysql | mariadb
DB_DIALECT="sqlite"

# SQLite only (relative path from project root)
DB_STORAGE="./database/app.sqlite"

# PostgreSQL / MySQL / MariaDB
# DB_HOST="localhost"
# DB_PORT="5432"
# DB_NAME="comunica"
# DB_USER="comunica_user"
# DB_PASS="strong_password_here"
