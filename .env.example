# =============================================================================
#  Comunica — Configuração do Ambiente
#  Copie este arquivo para .env e preencha os valores:
#    cp .env.example .env
#
#  Ou use o script de instalação automatizado:
#    bash setup.sh
# =============================================================================

# ─── Aplicação ───────────────────────────────────────────────────────────────

NODE_ENV="production"

# Porta em que a aplicação vai ouvir internamente (Nginx faz o proxy para fora)
PORT=3020

# URL pública completa, usada para gerar links absolutos
APP_URL="https://comunicacao.suaprefeitura.gov.br"

# Fuso horário do servidor — use um valor da lista IANA:
# America/Sao_Paulo | America/Porto_Velho | America/Manaus | America/Belem
# America/Fortaleza | America/Recife | America/Cuiaba | America/Rio_Branco
TZ="America/Sao_Paulo"

# ─── Segurança de Sessão ─────────────────────────────────────────────────────

# Chave secreta para assinar os cookies de sessão.
# OBRIGATÓRIO: gere um valor aleatório com:
#   node -e "require('crypto').randomBytes(48).toString('hex')"
SESSION_SECRET="troque-para-um-valor-longo-e-aleatorio"

# ─── Banco de Dados ──────────────────────────────────────────────────────────

# Dialeto: sqlite | mysql | mariadb | postgres
DB_DIALECT="sqlite"

# ── SQLite (padrão, zero configuração extra) ──────────────────────────────────
# Caminho relativo à raiz do projeto
DB_STORAGE="./database/app.sqlite"

# ── MySQL / MariaDB ───────────────────────────────────────────────────────────
# Descomente e preencha se usar MySQL ou MariaDB (DB_DIALECT="mysql" ou "mariadb")
# DB_HOST="localhost"
# DB_PORT="3306"
# DB_NAME="comunica"
# DB_USER="comunica_user"
# DB_PASS="senha-forte-aqui"

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Descomente e preencha se usar PostgreSQL (DB_DIALECT="postgres")
# DB_HOST="localhost"
# DB_PORT="5432"
# DB_NAME="comunica"
# DB_USER="comunica_user"
# DB_PASS="senha-forte-aqui"

# ─── Push Notifications (VAPID) ──────────────────────────────────────────────
#
# Necessário para enviar notificações aos navegadores dos usuários.
# O setup.sh gera essas chaves automaticamente.
#
# Para gerar manualmente:
#   npx web-push generate-vapid-keys
#
# ATENÇÃO: depois que usuários ativarem notificações,
# NÃO regenere estas chaves ou todas as inscrições serão invalidadas.

VAPID_PUBLIC_KEY="sua-chave-publica-aqui"
VAPID_PRIVATE_KEY="sua-chave-privada-aqui"
VAPID_EMAIL="admin@comunicacao.suaprefeitura.gov.br"
